---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Industries We Serve | SANMYRS — Textile & Print Chemical Suppliers"
  description="SANMYRS supplies screen printing studios, textile mills, digital print bureaus, and garment manufacturers across Pakistan with specialist printing inks and textile auxiliaries."
>

  <!-- ── NEOMINIMALIST HERO ────────────────────────────── -->
  <section class="relative pt-32 pb-20 lg:pt-40 lg:pb-32 bg-white overflow-hidden border-b border-gray-100">
    <!-- Abstract Tech/Industry Grid Background -->
    <div class="absolute inset-0 z-0">
      <div class="absolute inset-0 opacity-[0.02] mix-blend-multiply" style="background-image: linear-gradient(#1A1A2E 2px, transparent 2px), linear-gradient(90deg, #1A1A2E 2px, transparent 2px); background-size: 60px 60px; background-position: center center;"></div>
      <div class="absolute top-1/4 left-1/2 w-[800px] h-[300px] bg-[#0099AF] rounded-full blur-[150px] opacity-10 -translate-x-1/2 -rotate-12"></div>
    </div>
    
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10 text-center">
      <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-slate-50 border border-gray-200 shadow-sm mb-6" data-aos="fade-down">
        <span class="w-2 h-2 rounded-full bg-[#1A1A2E]"></span>
        <span class="text-xs font-bold uppercase tracking-widest text-[#1A1A2E]">4 Key Sectors</span>
      </div>
      <h1 class="text-5xl lg:text-7xl font-extrabold text-[#1A1A2E] tracking-tight leading-[1.05] mb-6 font-unison max-w-4xl mx-auto" data-aos="fade-up" data-aos-delay="100">
        Industry-Specific <br/>
        <span class="text-transparent bg-clip-text bg-gradient-to-r from-[#1A1A2E] to-[#0099AF]">Chemical Solutions.</span>
      </h1>
      <p class="text-lg lg:text-xl text-gray-600 leading-relaxed max-w-2xl mx-auto" data-aos="fade-up" data-aos-delay="150">
        From small garment decorators to large textile mills — SANMYRS products are trusted across Pakistan's full textile and printing manufacturing spectrum.
      </p>
    </div>
  </section>

  <!-- ── ALTERNATING INDUSTRIES LIST ─────────────────────── -->
  <section class="py-24 bg-slate-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 space-y-32">

      <!-- Industry 01: Screen Printing -->
      <article class="flex flex-col lg:flex-row gap-12 lg:gap-20 items-center justify-between group">
        <!-- Visual Half -->
        <div class="w-full lg:w-1/2 relative" data-aos="fade-right">
          <!-- Big background number -->
          <div class="absolute -top-16 -left-10 text-[12rem] lg:text-[16rem] font-black text-[#1A1A2E]/5 font-unison leading-none pointer-events-none select-none transition-transform duration-700 group-hover:-translate-y-4">01</div>
          
          <div class="relative z-10 bg-white rounded-[2rem] p-10 lg:p-14 border border-gray-100 shadow-xl shadow-gray-200/50">
            <div class="w-20 h-20 bg-[#1A1A2E] rounded-2xl flex items-center justify-center text-white mb-8 shadow-lg shadow-[#1A1A2E]/20">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-10 h-10" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M7 21a4 4 0 01-4-4V5a2 2 0 012-2h4a2 2 0 012 2v12a4 4 0 01-4 4zm0 0h12a2 2 0 002-2v-4a2 2 0 00-2-2h-2.343M11 7.343l1.657-1.657a2 2 0 012.828 0l2.829 2.829a2 2 0 010 2.828l-8.486 8.485M7 17h.01" /></svg>
            </div>
            <h2 class="text-3xl lg:text-4xl font-extrabold text-[#1A1A2E] mb-6 font-unison leading-tight">Screen Printing<br/>Studios</h2>
            <ul class="space-y-4">
              {[
                'Custom T-shirt and garment studios',
                'Commercial promo and branded apparel',
                'Sportswear and performance decoration',
                'Fashion brand in-house facilities',
              ].map(item => (
                <li class="flex items-start gap-3 text-gray-600">
                  <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-[#0099AF] shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
                  <span class="text-sm border-b border-transparent hover:border-gray-300 transition-colors">{item}</span>
                </li>
              ))}
            </ul>
          </div>
        </div>
        
        <!-- Text/Content Half -->
        <div class="w-full lg:w-1/2 relative z-10" data-aos="fade-left">
          <div class="prose prose-lg text-gray-600 mb-10">
            <p>
              Whether you operate a single manual press for custom T-shirts or a multi-head automatic press facility for high-volume garment contracts, SANMYRS has the ink system, additive, and specialty effect product to meet your production requirements.
            </p>
            <p>
              We stock plastisol inks for standard cotton printing, low-bleed formulations for polyester sportswear, high-density inks for raised 3D effects, and specialty inks including glow, metallic, glitter, and reflective. Our water-based range covers soft-hand fashion printing, discharge systems, and eco-compliant programs for international brands.
            </p>
          </div>
          
          <!-- Relevant Links Box -->
          <div class="bg-white rounded-2xl border border-gray-100 p-6 shadow-sm">
            <p class="text-xs font-bold uppercase tracking-widest text-[#0099AF] mb-4">Relevant Categories</p>
            <div class="flex flex-col gap-3">
              {[
                { name: 'Plastisol Standard & High Opacity Inks' },
                { name: 'Low Bleed Inks for Polyester' },
                { name: 'Water-Based Soft-Hand Inks' },
                { name: 'Specialty Effects: Metallic, Glitter, Glow' },
                { name: 'Plastisol & WB Additives' },
              ].map(p => (
                <a href="/products/screen-printing" class="group/link flex items-center gap-2 text-sm text-[#1A1A2E] font-semibold hover:text-[#0099AF] transition-colors w-fit">
                  <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-[#0099AF] transition-transform group-hover/link:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
                  {p.name}
                </a>
              ))}
            </div>
          </div>
        </div>
      </article>

      <!-- Industry 02: Textile Mills (Reversed) -->
      <article class="flex flex-col lg:flex-row-reverse gap-12 lg:gap-20 items-center justify-between group">
        <!-- Visual Half -->
        <div class="w-full lg:w-1/2 relative" data-aos="fade-left">
          <div class="absolute -top-16 -right-10 text-[12rem] lg:text-[16rem] font-black text-[#1A1A2E]/5 font-unison leading-none pointer-events-none select-none transition-transform duration-700 group-hover:-translate-y-4">02</div>
          
          <div class="relative z-10 bg-[#0099AF] rounded-[2rem] p-10 lg:p-14 shadow-xl shadow-[#0099AF]/20 text-white overflow-hidden">
            <div class="absolute inset-0 opacity-10 mix-blend-overlay bg-[url('data:image/svg+xml;base64,')]"></div>

            <div class="w-20 h-20 bg-white/10 rounded-2xl flex items-center justify-center text-white mb-8 border border-white/20 backdrop-blur-sm relative z-10">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-10 h-10" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-2 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" /></svg>
            </div>
            <h2 class="text-3xl lg:text-4xl font-extrabold text-white mb-6 font-unison leading-tight relative z-10">Textile Mills &amp;<br/>Dyeing Units</h2>
            <ul class="space-y-4 relative z-10">
              {[
                'Knitting, woven, and non-woven dyeing',
                'Garment dyeing and finishing departments',
                'Yarn package and beam dyeing',
                'Technical textile finishing mills',
              ].map(item => (
                <li class="flex items-start gap-3 text-white/90">
                  <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-white/50 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
                  <span class="text-sm">{item}</span>
                </li>
              ))}
            </ul>
          </div>
        </div>
        
        <!-- Text/Content Half -->
        <div class="w-full lg:w-1/2 relative z-10" data-aos="fade-right">
          <div class="prose prose-lg text-gray-600 mb-10">
             <p>
              Pakistan's textile export industry demands chemical consistency and technical reliability. SANMYRS's textile auxiliaries range covers every stage of the wet processing workflow — from pre-treatment and dyeing through to finishing and functional treatments.
            </p>
            <p>
              For dyeing departments, we supply wetting agents, sequestrants, leveling agents, dispersants, and dye fixing chemistry. For finishing, our range includes silicone softeners across all grades (PDMS, hydrophilic, amino-functional), wrinkle-free resins, water repellents, anti-pilling enzymes, and antistatic agents for every fiber type.
            </p>
          </div>
          
          <div class="bg-white rounded-2xl border border-gray-100 p-6 shadow-sm">
            <p class="text-xs font-bold uppercase tracking-widest text-[#0099AF] mb-4">Relevant Categories</p>
            <div class="flex flex-col gap-3">
              {[
                { name: 'Wetting, Leveling & Dispersing Agents' },
                { name: 'Sequestering & pH Buffer Chemistry' },
                { name: 'Dye Fixing & Soaping Agents' },
                { name: 'Silicone & Amino Silicone Softeners' },
                { name: 'Enzymes, Resins & Finishes' },
              ].map(p => (
                <a href="/products/textile-auxiliaries" class="group/link flex items-center gap-2 text-sm text-[#1A1A2E] font-semibold hover:text-[#0099AF] transition-colors w-fit">
                  <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-[#0099AF] transition-transform group-hover/link:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
                  {p.name}
                </a>
              ))}
            </div>
          </div>
        </div>
      </article>

      <!-- Industry 03: Digital Print Studios -->
      <article class="flex flex-col lg:flex-row gap-12 lg:gap-20 items-center justify-between group">
        <!-- Visual Half -->
        <div class="w-full lg:w-1/2 relative" data-aos="fade-right">
          <div class="absolute -top-16 -left-10 text-[12rem] lg:text-[16rem] font-black text-[#1A1A2E]/5 font-unison leading-none pointer-events-none select-none transition-transform duration-700 group-hover:-translate-y-4">03</div>
          
          <div class="relative z-10 bg-white rounded-[2rem] p-10 lg:p-14 border border-gray-100 shadow-xl shadow-gray-200/50">
            <div class="w-20 h-20 bg-[#1A1A2E] rounded-2xl flex items-center justify-center text-white mb-8 shadow-lg shadow-[#1A1A2E]/20">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-10 h-10" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>
            </div>
            <h2 class="text-3xl lg:text-4xl font-extrabold text-[#1A1A2E] mb-6 font-unison leading-tight">Digital Print<br/>Studios</h2>
            <ul class="space-y-4">
              {[
                'Digital textile print bureaus on all fabrics',
                'Sublimation printing on polyester and fashion',
                'Wide-format signage and banner studios',
                'On-demand, short-run sampling facilities',
              ].map(item => (
                <li class="flex items-start gap-3 text-gray-600">
                  <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-[#0099AF] shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
                  <span class="text-sm">{item}</span>
                </li>
              ))}
            </ul>
          </div>
        </div>
        
        <!-- Text/Content Half -->
        <div class="w-full lg:w-1/2 relative z-10" data-aos="fade-left">
          <div class="prose prose-lg text-gray-600 mb-10">
            <p>
              Digital textile printing is one of Pakistan's fastest growing production segments, driven by demand for short-run, fast-turnaround, and sustainable printing alternatives to conventional screen and rotary printing. SANMYRS supplies the full range of digital textile inks — reactive, disperse, sublimation, acid, and pigment.
            </p>
            <p>
              For wide-format graphic and advertising studios, we supply eco solvent, hard solvent, UV, latex, pigment, and dye inkjet inks for Epson, Roland, Mimaki, Mutoh, and HP compatible systems, covering all major signage, banner, and display media types.
            </p>
          </div>
          
          <div class="bg-white rounded-2xl border border-gray-100 p-6 shadow-sm">
            <p class="text-xs font-bold uppercase tracking-widest text-[#0099AF] mb-4">Relevant Categories</p>
            <div class="flex flex-col gap-3">
              {[
                { name: 'Reactive & Acid Digital Textile Inks' },
                { name: 'Sublimation & Disperse Inks' },
                { name: 'Pigment Textile Inks' },
                { name: 'Eco Solvent, UV & Latex Inks' },
                { name: 'Pretreatment & Cleaning Solutions' },
              ].map(p => (
                <a href="/products/digital-printing" class="group/link flex items-center gap-2 text-sm text-[#1A1A2E] font-semibold hover:text-[#0099AF] transition-colors w-fit">
                  <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-[#0099AF] transition-transform group-hover/link:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
                  {p.name}
                </a>
              ))}
            </div>
          </div>
        </div>
      </article>

      <!-- Industry 04: Garment Manufacturers (Reversed) -->
      <article class="flex flex-col lg:flex-row-reverse gap-12 lg:gap-20 items-center justify-between group pb-12">
        <!-- Visual Half -->
        <div class="w-full lg:w-1/2 relative" data-aos="fade-left">
          <div class="absolute -top-16 -right-10 text-[12rem] lg:text-[16rem] font-black text-[#1A1A2E]/5 font-unison leading-none pointer-events-none select-none transition-transform duration-700 group-hover:-translate-y-4">04</div>
          
          <div class="relative z-10 bg-[#1A1A2E] rounded-[2rem] p-10 lg:p-14 shadow-xl shadow-[#1A1A2E]/20 text-white overflow-hidden">
            <div class="w-20 h-20 bg-[#0099AF] rounded-2xl flex items-center justify-center text-white mb-8 shadow-lg shadow-[#0099AF]/20 relative z-10">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-10 h-10" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z" /></svg>
            </div>
            <h2 class="text-3xl lg:text-4xl font-extrabold text-white mb-6 font-unison leading-tight relative z-10">Garment<br/>Manufacturers</h2>
            <ul class="space-y-4 relative z-10">
              {[
                'Apparel export manufacturers for EU/US',
                'Sportswear and activewear brands',
                'Workwear, uniform, and safety garment producers',
                'Fashion brands requiring soft-hand eco-printing',
              ].map(item => (
                <li class="flex items-start gap-3 text-white/90">
                  <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-[#0099AF] shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
                  <span class="text-sm">{item}</span>
                </li>
              ))}
            </ul>
          </div>
        </div>
        
        <!-- Text/Content Half -->
        <div class="w-full lg:w-1/2 relative z-10" data-aos="fade-right">
          <div class="prose prose-lg text-gray-600 mb-10">
            <p>
              Pakistan's garment export sector faces increasing compliance demands from international buyers — OEKO-TEX compliance, formaldehyde-free chemistry, PFAS-free DWR finishes, and eco-certified ink systems. SANMYRS supports export-oriented manufacturers by stocking products that meet these requirements alongside standard commercial grades.
            </p>
            <p>
              For garment printing, we supply stretch-compatible plastisol PU inks, low-bleed inks for polyester, water-based eco systems, and hi-visibility reflective inks. For finishing, our softeners provide the hand-feel specification requested by international brand buyers.
            </p>
          </div>
          
          <div class="bg-white rounded-2xl border border-gray-100 p-6 shadow-sm">
            <p class="text-xs font-bold uppercase tracking-widest text-[#0099AF] mb-4">Relevant Categories</p>
            <div class="flex flex-col gap-3">
              {[
                { name: 'Plastisol PU & Stretch Inks', url: '/products/screen-printing' },
                { name: 'Water-Based Eco Printing Systems', url: '/products/screen-printing' },
                { name: 'Reflective & Hi-Vis Safety Inks', url: '/products/screen-printing' },
                { name: 'Amino Silicone & Reactive Softeners', url: '/products/textile-auxiliaries' },
                { name: 'Water Repellent & Functional Finishes', url: '/products/textile-auxiliaries' },
              ].map(p => (
                <a href={p.url} class="group/link flex items-center gap-2 text-sm text-[#1A1A2E] font-semibold hover:text-[#0099AF] transition-colors w-fit">
                  <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-[#0099AF] transition-transform group-hover/link:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
                  {p.name}
                </a>
              ))}
            </div>
          </div>
        </div>
      </article>

    </div>
  </section>

  <!-- ── CTA SPLIT ─────────────────────────────────────── -->
  <section class="border-t border-gray-100">
    <div class="grid grid-cols-1 md:grid-cols-2">
      <!-- Left (White) -->
      <div class="bg-white p-12 md:p-24 flex items-center justify-center md:justify-end text-center md:text-left">
        <div class="max-w-md">
          <h2 class="text-3xl md:text-4xl font-extrabold text-[#1A1A2E] font-unison leading-tight mb-4">Serving Your Industry.</h2>
          <p class="text-gray-500 mb-8 leading-relaxed">
            Tell us your production process and we'll recommend the right products for your specific needs. Our technical team has hands-on experience across all four sectors.
          </p>
          <a href="/contact" class="inline-flex justify-center items-center px-8 py-4 rounded-xl bg-[#0099AF] text-white font-bold tracking-wide transition-all hover:bg-[#007A8A] hover:-translate-y-1 shadow-lg shadow-[#0099AF]/20 w-full sm:w-auto">
            Speak to Our Team
          </a>
        </div>
      </div>
      
      <!-- Right (Navy) -->
      <div class="bg-[#1A1A2E] p-12 md:p-24 flex items-center justify-center md:justify-start text-center md:text-left relative overflow-hidden">
        <div class="absolute inset-0 opacity-10" style="background-image: radial-gradient(#ffffff 1px, transparent 1px); background-size: 24px 24px;"></div>
        <div class="max-w-md relative z-10">
          <div class="w-16 h-16 rounded-full bg-[#25D366]/20 text-[#25D366] flex items-center justify-center mb-6 mx-auto md:mx-0">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
          </div>
          <h2 class="text-3xl md:text-4xl font-extrabold text-white font-unison leading-tight mb-4">Urgent technical query?</h2>
          <p class="text-gray-400 mb-8 leading-relaxed">
            Send us a message detailing your process challenge and get an immediate technical response.
          </p>
          <a href="https://wa.me/923183755197" target="_blank" rel="noopener noreferrer" class="inline-flex justify-center items-center px-8 py-4 rounded-xl bg-white text-[#1A1A2E] border border-transparent font-bold tracking-wide transition-all hover:bg-gray-100 hover:-translate-y-1 w-full sm:w-auto">
            WhatsApp Us
          </a>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>

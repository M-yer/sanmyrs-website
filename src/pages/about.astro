---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="About SANMYRS | 18+ Years Supplying Pakistan's Textile Industry"
  description="SANMYRS has been supplying specialist screen printing inks, digital printing inks, and textile auxiliaries to Pakistan's textile and garment industry for over 18 years. Based in Karachi."
>

  <!-- ── HERO ─────────────────────────────────────────── -->
  <section class="ab-hero">
    <div class="ab-hero__glow" aria-hidden="true"></div>
    <div class="ab-container">
      <div class="ab-hero__inner" data-aos="fade-up">
        <div class="ab-eyebrow-pill">
          <span class="ab-gold-dot" aria-hidden="true"></span>
          18+ Years of Expertise
        </div>
        <h1 class="ab-hero__h1 font-unison">About SANMYRS.</h1>
        <p class="ab-hero__sub">
          18 years of specialist chemical supply to Pakistan's textile and printing industry —
          built on expertise, consistency, and trust.
        </p>
        <div class="ab-hero__accent-line" aria-hidden="true"></div>
      </div>
    </div>
  </section>

  <!-- ── STORY ─────────────────────────────────────────── -->
  <section class="ab-story">
    <div class="ab-container">
      <div class="ab-story__grid">

        <!-- Left: text -->
        <div data-aos="fade-up" data-aos-delay="80">
          <span class="ab-section-eyebrow">Our Story</span>
          <h2 class="ab-section-h2 font-unison">
            From Karachi to Every Corner of Pakistan's Textile Belt
          </h2>
          <div class="ab-story__body">
            <p>
              SANMYRS was established in Karachi with a single purpose: to bring professional-grade
              printing inks and textile chemicals to Pakistan's rapidly growing garment and textile
              manufacturing sector, with the technical knowledge to back every product we sell.
            </p>
            <p>
              Over 18 years, we have built deep expertise across three distinct chemical disciplines —
              screen printing inks (plastisol and water-based), digital printing inks (textile and
              graphic), and textile auxiliaries (dyeing and finishing). Our customers range from small
              screen printing studios in Karachi's industrial zones to large textile mills and garment
              export houses supplying international brands.
            </p>
            <p>
              We are not simply order-takers. Our team understands the technical realities of ink and
              dye chemistry, fabric behavior, and process conditions. When a customer faces a production
              problem — dye bleed on polyester, crease marks in the jet machine, a print film that's
              cracking on stretch fabric — we help solve it.
            </p>
          </div>
        </div>

        <!-- Right: brand card -->
        <div data-aos="fade-up" data-aos-delay="160">
          <div class="ab-brand-card">
            <div class="ab-brand-card__logo">
              SAN<span class="ab-brand-card__logo-teal">MYRS</span>
            </div>
            <div class="ab-brand-card__divider" aria-hidden="true"></div>
            <div class="ab-brand-card__stats">
              <div class="ab-brand-stat">
                <span class="ab-brand-stat__value">2006</span>
                <span class="ab-brand-stat__label">Year Founded</span>
              </div>
              <div class="ab-brand-stat">
                <span class="ab-brand-stat__value">18+</span>
                <span class="ab-brand-stat__label">Years of Expertise</span>
              </div>
              <div class="ab-brand-stat">
                <span class="ab-brand-stat__value">500+</span>
                <span class="ab-brand-stat__label">Clients Served</span>
              </div>
            </div>
            <p class="ab-brand-card__tagline">Specialist Printing Inks &amp; Textile Chemicals</p>
            <p class="ab-brand-card__location">Karachi, Pakistan</p>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ── STATS STRIP ────────────────────────────────────── -->
  <section class="ab-stats-strip" data-aos="fade-up">
    <div class="ab-container">
      <div class="ab-stats-strip__grid">
        {[
          { value: '2006', label: 'Year Founded' },
          { value: '18+',  label: 'Years of Expertise' },
          { value: '50+',  label: 'Products in Range' },
          { value: '500+', label: 'Satisfied Customers' },
        ].map(stat => (
          <div class="ab-stats-strip__item">
            <span class="ab-stats-strip__value font-unison">{stat.value}</span>
            <span class="ab-stats-strip__label">{stat.label}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ── VALUES ─────────────────────────────────────────── -->
  <section class="ab-values">
    <div class="ab-container">
      <div class="ab-section-header" data-aos="fade-up">
        <span class="ab-section-eyebrow">Our Principles</span>
        <h2 class="ab-section-h2 font-unison">What We Stand For.</h2>
      </div>

      <div class="ab-cards-grid">
        {[
          {
            num: '01',
            icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z" /></svg>`,
            title: 'Quality Without Compromise',
            body: 'Every product in our range is selected and tested to perform consistently in production conditions. We do not compromise on raw material quality or batch consistency.',
          },
          {
            num: '02',
            icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" /></svg>`,
            title: 'Knowledge-Led Service',
            body: 'We invest in understanding the industries we serve. Our team can discuss dye chemistry, ink rheology, and process parameters — not just product specifications.',
          },
          {
            num: '03',
            icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z" /></svg>`,
            title: 'Long-Term Partnerships',
            body: 'We build relationships with customers who want a reliable supply partner, not just a vendor. Many of our clients have purchased from SANMYRS for over a decade.',
          },
        ].map((v, i) => (
          <div
            class="ab-value-card"
            data-aos="fade-up"
            data-aos-delay={i === 0 ? '80' : i === 1 ? '160' : '240'}
          >
            <span class="ab-value-card__num font-unison" aria-hidden="true">{v.num}</span>
            <div class="ab-value-card__icon-box">
              <Fragment set:html={v.icon} />
            </div>
            <h3 class="ab-value-card__title">{v.title}</h3>
            <p class="ab-value-card__body">{v.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ── TEAM ───────────────────────────────────────────── -->
  <section class="ab-team">
    <div class="ab-container">
      <div class="ab-section-header" data-aos="fade-up">
        <span class="ab-section-eyebrow">The People Behind It</span>
        <h2 class="ab-section-h2 font-unison">Our Team.</h2>
      </div>

      <div class="ab-cards-grid">
        {[
          { role: 'Founder & Director',         area: 'Screen Printing Chemistry & Business Development', years: '18+ years in textile chemicals' },
          { role: 'Technical Manager',           area: 'Textile Auxiliaries & Dyeing Process Support',    years: '14+ years in wet processing'   },
          { role: 'Digital Printing Specialist', area: 'Inkjet Inks & Digital Textile Systems',           years: '10+ years in digital print'    },
        ].map((member, i) => (
          <div
            class="ab-team-card"
            data-aos="fade-up"
            data-aos-delay={i === 0 ? '80' : i === 1 ? '160' : '240'}
          >
            <div class="ab-team-card__avatar">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
              </svg>
            </div>
            <h3 class="ab-team-card__role">{member.role}</h3>
            <p class="ab-team-card__area">{member.area}</p>
            <span class="ab-team-card__badge">{member.years}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ── CTA ───────────────────────────────────────────── -->
  <section class="ab-cta">
    <div class="ab-container">
      <div class="ab-cta__inner" data-aos="fade-up">

        <div class="ab-cta__left">
          <span class="ab-cta__eyebrow-label">Ready to Partner Up?</span>
          <h2 class="ab-cta__h2 font-unison">Ready to work with SANMYRS.</h2>
          <p class="ab-cta__sub">
            Whether you're looking for a specific product or need guidance on a process
            challenge, our team is ready to help.
          </p>
        </div>

        <div class="ab-cta__actions">
          <a href="/contact" class="ab-cta__btn-primary">
            Contact Us Today
            <svg xmlns="http://www.w3.org/2000/svg" class="ab-btn-icon" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
            </svg>
          </a>
          <a
            href="https://wa.me/923183755197"
            target="_blank"
            rel="noopener noreferrer"
            class="ab-cta__btn-ghost"
          >
            WhatsApp Us
          </a>
        </div>

      </div>
    </div>
  </section>

</BaseLayout>

<style>
  /* ── Container ───────────────────────────────────────── */
  .ab-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 clamp(16px, 4vw, 32px);
  }

  /* ── Shared section eyebrow ─────────────────────────── */
  .ab-section-eyebrow {
    display: block;
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: #0099AF;
    margin-bottom: 0.5rem;
  }

  /* ── Shared section h2 ──────────────────────────────── */
  .ab-section-h2 {
    font-size: clamp(1.8rem, 3.5vw, 2.8rem);
    font-weight: 800;
    color: #0F172A;
    line-height: 1.15;
    margin: 0 0 0.5rem;
  }

  /* ── Shared section header (centered) ──────────────── */
  .ab-section-header {
    text-align: center;
    margin-bottom: 3rem;
  }
  .ab-section-header .ab-section-eyebrow {
    display: inline-block;
  }

  /* ── Shared cards grid ──────────────────────────────── */
  .ab-cards-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
  }
  @media (min-width: 640px) {
    .ab-cards-grid { grid-template-columns: repeat(3, 1fr); }
  }

  /* ── HERO ────────────────────────────────────────────── */
  .ab-hero {
    position: relative;
    background: #1A1A2E;
    overflow: hidden;
    padding: clamp(80px, 12vw, 130px) 0 clamp(64px, 8vw, 96px);
  }

  .ab-hero__glow {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }
  .ab-hero__glow::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse 55% 90% at 105% -15%, rgba(0,153,175,0.18) 0%, transparent 60%);
  }

  .ab-hero__inner {
    position: relative;
    z-index: 1;
    max-width: 680px;
  }

  .ab-eyebrow-pill {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    background: rgba(0,153,175,0.15);
    border: 1px solid rgba(0,153,175,0.3);
    color: #0099AF;
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    padding: 0.3rem 0.85rem;
    border-radius: 4px;
    margin-bottom: 1.25rem;
  }

  .ab-gold-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: #F5A623;
    flex-shrink: 0;
  }

  .ab-hero__h1 {
    font-size: clamp(2.8rem, 6vw, 4.5rem);
    font-weight: 800;
    color: #ffffff;
    line-height: 1.05;
    margin: 0 0 1.25rem;
  }

  .ab-hero__sub {
    color: rgba(255,255,255,0.65);
    font-size: clamp(1rem, 2vw, 1.15rem);
    line-height: 1.7;
    max-width: 540px;
    margin: 0;
  }

  .ab-hero__accent-line {
    width: 3rem;
    height: 3px;
    background: #0099AF;
    border-radius: 2px;
    margin-top: 2rem;
  }

  /* ── STORY ───────────────────────────────────────────── */
  .ab-story {
    background: #ffffff;
    padding: clamp(64px, 8vw, 96px) 0;
  }

  .ab-story__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
    align-items: start;
  }
  @media (min-width: 1024px) {
    .ab-story__grid { grid-template-columns: 1fr 1fr; }
  }

  .ab-story__body {
    margin-top: 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    color: #475569;
    line-height: 1.75;
    font-size: 0.95rem;
  }

  /* Brand card */
  .ab-brand-card {
    background: #1A1A2E;
    border-radius: 16px;
    padding: 2rem;
    box-shadow: 0 20px 50px rgba(0,0,0,0.22);
  }

  .ab-brand-card__logo {
    font-family: 'UnisonPro', 'Outfit', sans-serif;
    font-size: 2.2rem;
    font-weight: 800;
    color: #ffffff;
    letter-spacing: -0.02em;
    margin-bottom: 1rem;
  }

  .ab-brand-card__logo-teal {
    color: #0099AF;
  }

  .ab-brand-card__divider {
    width: 3rem;
    height: 3px;
    background: #0099AF;
    border-radius: 4px;
    margin-bottom: 1.5rem;
  }

  .ab-brand-card__stats {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    margin-bottom: 1.5rem;
  }

  .ab-brand-stat {
    background: rgba(255,255,255,0.06);
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 8px;
    padding: 0.85rem 1rem;
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .ab-brand-stat__value {
    font-family: 'UnisonPro', 'Outfit', sans-serif;
    font-size: 1.7rem;
    font-weight: 800;
    color: #0099AF;
    min-width: 3.5rem;
    line-height: 1;
  }

  .ab-brand-stat__label {
    font-size: 0.82rem;
    color: rgba(255,255,255,0.60);
    line-height: 1.3;
  }

  .ab-brand-card__tagline {
    font-size: 0.82rem;
    color: rgba(255,255,255,0.45);
    margin: 0 0 0.25rem;
  }

  .ab-brand-card__location {
    font-size: 0.78rem;
    color: rgba(255,255,255,0.3);
    margin: 0;
  }

  /* ── STATS STRIP ─────────────────────────────────────── */
  .ab-stats-strip {
    background: #0099AF;
    padding: clamp(40px, 6vw, 64px) 0;
  }

  .ab-stats-strip__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
    text-align: center;
  }
  @media (min-width: 640px) {
    .ab-stats-strip__grid { grid-template-columns: repeat(4, 1fr); }
  }

  .ab-stats-strip__item {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .ab-stats-strip__value {
    font-size: clamp(2.4rem, 4vw, 3rem);
    font-weight: 800;
    color: #ffffff;
    line-height: 1;
  }

  .ab-stats-strip__label {
    font-size: 0.82rem;
    color: rgba(255,255,255,0.8);
    margin-top: 0.15rem;
  }

  /* ── VALUES ──────────────────────────────────────────── */
  .ab-values {
    background: #F8FAFC;
    padding: clamp(64px, 8vw, 96px) 0;
  }

  .ab-value-card {
    background: #ffffff;
    border: 1px solid #E2E8F0;
    border-top: 3px solid #0099AF;
    border-radius: 16px;
    padding: 1.75rem;
    position: relative;
    transition: box-shadow 200ms ease, transform 200ms ease;
    cursor: default;
  }
  .ab-value-card:hover {
    box-shadow: 0 16px 40px rgba(0,0,0,0.10);
    transform: translateY(-3px);
  }

  .ab-value-card__num {
    position: absolute;
    top: 1.25rem;
    right: 1.25rem;
    font-size: 3rem;
    font-weight: 800;
    color: rgba(0,153,175,0.08);
    line-height: 1;
    pointer-events: none;
  }

  .ab-value-card__icon-box {
    width: 48px;
    height: 48px;
    background: rgba(0,153,175,0.10);
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #0099AF;
    margin-bottom: 1rem;
  }

  .ab-value-card__title {
    font-size: 1rem;
    font-weight: 700;
    color: #0F172A;
    margin: 0 0 0.6rem;
  }

  .ab-value-card__body {
    font-size: 0.875rem;
    color: #475569;
    line-height: 1.7;
    margin: 0;
  }

  /* ── TEAM ────────────────────────────────────────────── */
  .ab-team {
    background: #ffffff;
    padding: clamp(48px, 6vw, 72px) 0;
  }

  .ab-team-card {
    background: #F8FAFC;
    border: 1px solid #E2E8F0;
    border-left: 3px solid #0099AF;
    border-radius: 16px;
    padding: 1.75rem;
    text-align: center;
    transition: box-shadow 200ms ease, transform 200ms ease;
    cursor: default;
  }
  .ab-team-card:hover {
    box-shadow: 0 16px 40px rgba(0,0,0,0.10);
    transform: translateY(-3px);
  }

  .ab-team-card__avatar {
    width: 56px;
    height: 56px;
    border-radius: 50%;
    background: rgba(0,153,175,0.10);
    border: 1px solid rgba(0,153,175,0.20);
    display: flex;
    align-items: center;
    justify-content: center;
    color: #0099AF;
    margin: 0 auto 1.1rem;
  }

  .ab-team-card__role {
    font-size: 0.95rem;
    font-weight: 700;
    color: #0F172A;
    margin: 0 0 0.35rem;
  }

  .ab-team-card__area {
    font-size: 0.82rem;
    color: #475569;
    line-height: 1.5;
    margin: 0 0 0.75rem;
  }

  .ab-team-card__badge {
    display: inline-block;
    background: rgba(0,153,175,0.10);
    color: #0099AF;
    font-size: 0.72rem;
    font-weight: 700;
    padding: 0.2rem 0.7rem;
    border-radius: 999px;
  }

  /* ── CTA ─────────────────────────────────────────────── */
  .ab-cta {
    background: #1A1A2E;
    border-top: 3px solid #0099AF;
    padding: clamp(56px, 7vw, 80px) 0;
  }

  .ab-cta__inner {
    display: flex;
    flex-direction: column;
    gap: 2rem;
    align-items: flex-start;
  }
  @media (min-width: 768px) {
    .ab-cta__inner {
      flex-direction: row;
      align-items: center;
      justify-content: space-between;
    }
  }

  .ab-cta__eyebrow-label {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    background: rgba(0,153,175,0.15);
    border: 1px solid rgba(0,153,175,0.3);
    color: #0099AF;
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    padding: 0.3rem 0.85rem;
    border-radius: 4px;
    margin-bottom: 1rem;
  }

  .ab-cta__h2 {
    font-size: clamp(1.6rem, 3vw, 2.2rem);
    font-weight: 800;
    color: #ffffff;
    margin: 0 0 0.7rem;
    line-height: 1.15;
  }

  .ab-cta__sub {
    color: rgba(255,255,255,0.65);
    font-size: 0.95rem;
    line-height: 1.65;
    margin: 0;
    max-width: 460px;
  }

  .ab-cta__actions {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    flex-shrink: 0;
  }

  .ab-cta__btn-primary {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    background: #0099AF;
    color: #ffffff;
    font-weight: 700;
    font-size: 0.9rem;
    padding: 0.8rem 1.75rem;
    border-radius: 8px;
    text-decoration: none;
    transition: background 150ms ease, transform 150ms ease;
    white-space: nowrap;
  }
  .ab-cta__btn-primary:hover {
    background: #007A8A;
    transform: translateY(-1px);
  }

  .ab-cta__btn-ghost {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    background: rgba(255,255,255,0.08);
    border: 1.5px solid rgba(255,255,255,0.2);
    color: #ffffff;
    font-weight: 700;
    font-size: 0.9rem;
    padding: 0.8rem 1.75rem;
    border-radius: 8px;
    text-decoration: none;
    transition: background 150ms ease, transform 150ms ease;
    white-space: nowrap;
  }
  .ab-cta__btn-ghost:hover {
    background: rgba(255,255,255,0.14);
    transform: translateY(-1px);
  }


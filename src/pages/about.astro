---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="About SANMYRS | 18+ Years Supplying Pakistan's Textile Industry"
  description="SANMYRS has been supplying specialist screen printing inks, digital printing inks, and textile auxiliaries to Pakistan's textile and garment industry for over 18 years. Based in Karachi."
>

  <!-- ── NEOMINIMALIST SPLIT HERO ─────────────────────── -->
  <section class="relative pt-32 pb-20 lg:pt-40 lg:pb-32 overflow-hidden bg-slate-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
        
        <!-- Left: Typography & Story Hook -->
        <div data-aos="fade-right">
          <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-white border border-gray-200 shadow-sm mb-6">
            <span class="w-2 h-2 rounded-full bg-[#0099AF] animate-pulse"></span>
            <span class="text-xs font-bold uppercase tracking-widest text-[#1A1A2E]">Since 2006</span>
          </div>
          <h1 class="text-4xl sm:text-5xl lg:text-7xl font-extrabold text-[#1A1A2E] tracking-tight leading-[1.05] mb-6 font-unison">
            18 Years of <br/>
            <span class="text-transparent bg-clip-text bg-gradient-to-r from-[#1A1A2E] to-[#0099AF]">Chemical Expertise.</span>
          </h1>
          <p class="text-lg lg:text-xl text-gray-600 leading-relaxed mb-8 max-w-lg">
            Specialist chemical supply to Pakistan's textile, digital, and screen printing industries — built on technical knowledge, consistency, and absolute trust.
          </p>
          <div class="flex flex-col sm:flex-row gap-4">
            <a href="#mission" class="inline-flex justify-center items-center px-8 py-4 rounded-xl bg-[#1A1A2E] text-white font-bold text-sm tracking-wide transition-all hover:-translate-y-1 hover:shadow-xl hover:shadow-[#1A1A2E]/20">
              Our Mission
            </a>
            <a href="/contact" class="inline-flex justify-center items-center px-8 py-4 rounded-xl bg-white border border-gray-200 text-[#1A1A2E] font-bold text-sm tracking-wide transition-all hover:bg-gray-50">
              Get in Touch
            </a>
          </div>
        </div>

        <!-- Right: Abstract Industrial Grid Graphic -->
        <div class="relative w-full h-full min-h-[400px] lg:min-h-[500px]" data-aos="fade-left" data-aos-delay="150">
          <div class="absolute inset-0 bg-[#1A1A2E] rounded-[2rem] overflow-hidden shadow-2xl shadow-[#1A1A2E]/10">
            <!-- decorative mesh pattern -->
            <div class="absolute inset-0 opacity-10" style="background-image: radial-gradient(#0099AF 2px, transparent 2px); background-size: 24px 24px;"></div>
            <!-- glowing orb -->
            <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-64 h-64 bg-[#0099AF] blur-[100px] rounded-full opacity-40"></div>
            
            <!-- content inside graphic -->
            <div class="absolute bottom-6 left-6 right-6 p-6 bg-white/10 backdrop-blur-md rounded-2xl border border-white/10 text-white">
              <div class="font-unison text-2xl font-bold mb-1">SANMYRS</div>
              <div class="text-white/70 text-sm">F-126, Korangi Industrial Area, Karachi</div>
            </div>
          </div>
          <!-- decorative accent shape -->
          <div class="absolute -top-6 -right-6 w-32 h-32 bg-[#0099AF] rounded-full blur-2xl opacity-20 MixBlendMode-multiply"></div>
        </div>
      </div>
    </div>
  </section>

  <!-- ── STATS STRIP ────────────────────────────────────── -->
  <section class="border-y border-gray-200 bg-white relative z-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-2 md:grid-cols-4 divide-x divide-gray-100">
        {[
          { value: '2006', label: 'Year Founded' },
          { value: '18+',  label: 'Years of Expertise' },
          { value: '50+',  label: 'Products in Range' },
          { value: '500+', label: 'Satisfied Customers' },
        ].map((stat, i) => (
          <div class="p-8 text-center" data-aos="fade-up" data-aos-delay={i * 100}>
            <div class="text-4xl md:text-5xl font-extrabold text-[#1A1A2E] font-unison tracking-tighter mb-2">{stat.value}</div>
            <div class="text-xs font-bold uppercase tracking-widest text-[#0099AF]">{stat.label}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ── TIMELINE STORY ─────────────────────────────────── -->
  <section id="mission" class="py-24 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      
      <div class="max-w-3xl mb-16" data-aos="fade-up">
        <h2 class="text-SM font-bold uppercase tracking-widest text-[#0099AF] mb-3">Our Origins</h2>
        <h3 class="text-3xl md:text-4xl font-extrabold text-[#1A1A2E] font-unison leading-tight">From Karachi to Every Corner of Pakistan's Textile Belt.</h3>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-12 gap-12">
        <!-- Modern Timeline Graphic (mobile hidden, desktop visible) -->
        <div class="hidden md:flex col-span-1 flex-col items-center">
          <div class="w-4 h-4 rounded-full bg-[#1A1A2E] ring-4 ring-slate-100 z-10"></div>
          <div class="w-0.5 h-full bg-gradient-to-b from-[#1A1A2E] via-gray-200 to-transparent my-2"></div>
        </div>

        <div class="col-span-1 md:col-span-11 space-y-12">
          <div class="bg-slate-50 p-8 rounded-2xl border border-gray-100 transition-all hover:shadow-lg hover:-translate-y-1" data-aos="fade-up">
            <h4 class="text-xl font-bold text-[#1A1A2E] mb-3">A Single Purpose</h4>
            <p class="text-gray-600 leading-relaxed">
              SANMYRS was established in Karachi with a single purpose: to bring professional-grade printing inks and textile chemicals to Pakistan's rapidly growing garment and textile manufacturing sector, with the technical knowledge to back every product we sell.
            </p>
          </div>
          
          <div class="bg-slate-50 p-8 rounded-2xl border border-gray-100 transition-all hover:shadow-lg hover:-translate-y-1" data-aos="fade-up" data-aos-delay="100">
            <h4 class="text-xl font-bold text-[#1A1A2E] mb-3">Deep Expertise</h4>
            <p class="text-gray-600 leading-relaxed">
              Over 18 years, we have built deep expertise across three distinct chemical disciplines — screen printing inks (plastisol and water-based), digital printing inks (textile and graphic), and textile auxiliaries (dyeing and finishing). Our customers range from small screen printing studios in Karachi's industrial zones to large textile mills and garment export houses supplying international brands.
            </p>
          </div>

          <div class="bg-[#1A1A2E] p-8 rounded-2xl text-white transition-all shadow-xl hover:-translate-y-1" data-aos="fade-up" data-aos-delay="200">
            <div class="w-12 h-12 rounded-full bg-[#0099AF]/20 flex items-center justify-center mb-6 text-[#0099AF]">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" /></svg>
            </div>
            <h4 class="text-xl font-bold mb-3">Solving Real Production Problems</h4>
            <p class="text-gray-300 leading-relaxed">
              We are not simply order-takers. Our team understands the technical realities of ink and dye chemistry, fabric behavior, and process conditions. When a customer faces a production problem — dye bleed on polyester, crease marks in the jet machine, a print film that's cracking on stretch fabric — we help solve it.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ── BENTO GRID VALUES ─────────────────────────────── -->
  <section class="py-24 bg-slate-50 border-t border-gray-100">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      
      <div class="text-center max-w-2xl mx-auto mb-16" data-aos="fade-up">
        <h2 class="text-sm font-bold uppercase tracking-widest text-[#0099AF] mb-3">Our Core Principles</h2>
        <h3 class="text-3xl md:text-5xl font-extrabold text-[#1A1A2E] font-unison leading-tight">What We Stand For.</h3>
      </div>

      <!-- Bento Grid Container -->
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        
        <!-- Bento Item 1 -->
        <div class="md:col-span-2 bg-white rounded-3xl p-10 border border-gray-100 shadow-sm relative overflow-hidden group transition-all hover:shadow-xl hover:border-[#0099AF]/30" data-aos="fade-up">
          <div class="absolute -right-10 -top-10 text-[10rem] font-black text-gray-50 opacity-50 group-hover:text-[#0099AF]/5 transition-colors duration-500 font-unison pointer-events-none">01</div>
          <div class="w-14 h-14 rounded-2xl bg-slate-50 flex items-center justify-center mb-8 border border-gray-100 text-[#0099AF] relative z-10 group-hover:scale-110 transition-transform duration-300">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z" /></svg>
          </div>
          <h3 class="text-2xl font-bold text-[#1A1A2E] mb-4 relative z-10">Quality Without Compromise</h3>
          <p class="text-gray-600 leading-relaxed max-w-md relative z-10">
            Every product in our range is selected and tested to perform consistently in production conditions. We do not compromise on raw material quality or batch consistency. 
          </p>
        </div>

        <!-- Bento Item 2 -->
        <div class="md:col-span-1 bg-[#1A1A2E] rounded-3xl p-10 relative overflow-hidden group transition-all hover:shadow-xl hover:shadow-[#1A1A2E]/20" data-aos="fade-up" data-aos-delay="100">
          <div class="absolute inset-0 opacity-10" style="background-image: radial-gradient(white 1px, transparent 1px); background-size: 16px 16px;"></div>
          <div class="w-14 h-14 rounded-2xl bg-white/10 flex items-center justify-center mb-8 border border-white/5 text-white relative z-10 backdrop-blur-sm">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" /></svg>
          </div>
          <h3 class="text-2xl font-bold text-white mb-4 relative z-10">Knowledge-Led Service</h3>
          <p class="text-gray-300 leading-relaxed relative z-10 text-sm">
            We invest in understanding the industries we serve. Our team can discuss dye chemistry, ink rheology, and process parameters — not just specs.
          </p>
        </div>

        <!-- Bento Item 3 -->
        <div class="md:col-span-3 bg-gradient-to-br from-white to-gray-50 rounded-3xl p-10 border border-gray-100 shadow-sm relative overflow-hidden group transition-all hover:shadow-xl" data-aos="fade-up" data-aos-delay="200">
          <div class="flex flex-col md:flex-row items-center justify-between gap-8 relative z-10">
            <div class="max-w-xl">
              <div class="w-14 h-14 rounded-2xl bg-slate-50 flex items-center justify-center mb-6 border border-gray-100 text-[#0099AF]">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
              </div>
              <h3 class="text-2xl md:text-3xl font-bold text-[#1A1A2E] mb-4">Long-Term Partnerships</h3>
              <p class="text-gray-600 leading-relaxed">
                We build relationships with customers who want a reliable supply partner, not just a vendor. Many of our clients have purchased from SANMYRS for over a decade.
              </p>
            </div>
            
            <div class="shrink-0">
               <div class="grid grid-cols-2 gap-3 relative">
                 <div class="absolute inset-0 bg-[#0099AF] blur-3xl opacity-20 transform -rotate-12"></div>
                 <div class="w-24 h-24 rounded-2xl bg-white shadow-xl flex items-center justify-center border border-gray-100 relative z-10 animate-float-slow">
                   <span class="font-unison text-3xl font-black text-[#1A1A2E]">01</span>
                 </div>
                 <div class="w-24 h-24 rounded-2xl bg-white shadow-xl flex items-center justify-center border border-gray-100 relative z-10 mt-6 animate-float-slower">
                   <span class="font-unison text-3xl font-black text-[#1A1A2E]">02</span>
                 </div>
               </div>
            </div>
          </div>
        </div>
        
      </div>
    </div>
  </section>

  <!-- ── TEAM / EXPERTS ─────────────────────────────────── -->
  <section class="py-24 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex flex-col md:flex-row justify-between items-end gap-8 mb-16" data-aos="fade-up">
        <div class="max-w-2xl">
          <h2 class="text-sm font-bold uppercase tracking-widest text-[#0099AF] mb-3">The People Behind It</h2>
          <h3 class="text-3xl md:text-5xl font-extrabold text-[#1A1A2E] font-unison leading-tight">Our Experts.</h3>
        </div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {[
          { role: 'Founder & Director',         area: 'Screen Printing Chemistry & Business Development', years: '18+ years' },
          { role: 'Technical Manager',           area: 'Textile Auxiliaries & Dyeing Process Support',    years: '14+ years'   },
          { role: 'Digital Printing Specialist', area: 'Inkjet Inks & Digital Textile Systems',           years: '10+ years'    },
        ].map((member, i) => (
          <div class="bg-slate-50 rounded-2xl p-8 border border-gray-100 transition-all hover:-translate-y-2 hover:shadow-lg group" data-aos="fade-up" data-aos-delay={i * 100}>
            <div class="w-16 h-16 rounded-full bg-white border border-gray-200 flex items-center justify-center mb-6 text-[#0099AF] group-hover:bg-[#0099AF] group-hover:text-white transition-colors duration-300">
               <svg xmlns="http://www.w3.org/2000/svg" class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
              </svg>
            </div>
            <div class="inline-block px-3 py-1 bg-white border border-gray-200 rounded-full text-xs font-bold text-[#0099AF] mb-4 shadow-sm">
              {member.years} Experience
            </div>
            <h3 class="text-xl font-bold text-[#1A1A2E] mb-2">{member.role}</h3>
            <p class="text-gray-500 text-sm leading-relaxed">{member.area}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ── CTA HIGH CONTRAST BLOCK ────────────────────────── -->
  <section class="py-24 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="bg-[#1A1A2E] rounded-[2.5rem] p-12 lg:p-20 relative overflow-hidden shadow-2xl" data-aos="fade-up">
        
        <!-- Background Accents -->
        <div class="absolute top-0 right-0 w-[800px] h-[800px] bg-[#0099AF] rounded-full blur-[120px] opacity-20 -translate-y-1/2 translate-x-1/3 pointer-events-none"></div>
        <div class="absolute inset-0 opacity-10" style="background-image: radial-gradient(#ffffff 1px, transparent 1px); background-size: 24px 24px;"></div>
        
        <div class="relative z-10 flex flex-col md:flex-row items-center justify-between gap-12">
          <div class="max-w-2xl">
            <h2 class="text-3xl lg:text-5xl font-extrabold text-white font-unison leading-tight mb-6">
              Ready to work with SANMYRS.
            </h2>
            <p class="text-lg text-gray-300 leading-relaxed mb-0">
              Whether you're looking for a specific product or need guidance on a process challenge, our team is ready to help.
            </p>
          </div>
          
          <div class="flex flex-col sm:flex-row gap-4 shrink-0 w-full md:w-auto">
            <a href="/contact" class="inline-flex justify-center items-center px-8 py-4 rounded-xl bg-[#0099AF] text-white font-bold text-sm tracking-wide transition-all hover:bg-[#007A8A] hover:-translate-y-1 shadow-lg shadow-[#0099AF]/30">
              Contact Us Today
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 ml-2" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
            </a>
            <a href="https://wa.me/923183755197" target="_blank" rel="noopener noreferrer" class="inline-flex justify-center items-center px-8 py-4 rounded-xl bg-white/10 border border-white/20 text-white font-bold text-sm tracking-wide transition-all hover:bg-white/20 backdrop-blur-sm">
              WhatsApp Us
            </a>
          </div>
        </div>
        
      </div>
    </div>
  </section>

</BaseLayout>

<style>
/* Custom animations to complement AOS */
@keyframes float-slow {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-10px); }
}
@keyframes float-slower {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-15px); }
}
.animate-float-slow {
  animation: float-slow 4s ease-in-out infinite;
}
.animate-float-slower {
  animation: float-slower 6s ease-in-out infinite;
}
</style>

---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="About SANMYRS | 18+ Years Supplying Pakistan's Textile Industry"
  description="SANMYRS has been supplying specialist screen printing inks, digital printing inks, and textile auxiliaries to Pakistan's textile and garment industry for over 18 years. Based in Karachi."
>

  <!-- ─── HERO ─────────────────────────────────────────────── -->
  <section class="about-hero">
    <!-- SVG dot-grid pattern -->
    <svg class="about-hero__dots" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
      <defs>
        <pattern id="dotgrid" x="0" y="0" width="32" height="32" patternUnits="userSpaceOnUse">
          <circle cx="2" cy="2" r="1.4" fill="rgba(0,153,175,0.18)" />
        </pattern>
      </defs>
      <rect width="100%" height="100%" fill="url(#dotgrid)" />
    </svg>
    <!-- SVG triangle-stroke checker pattern -->
    <svg class="about-hero__checker" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
      <defs>
        <pattern id="checker" x="0" y="0" width="64" height="64" patternUnits="userSpaceOnUse">
          <polyline points="0,64 32,0 64,64" fill="none" stroke="rgba(255,255,255,0.05)" stroke-width="1" />
        </pattern>
      </defs>
      <rect width="100%" height="100%" fill="url(#checker)" />
    </svg>

    <div class="about-hero__inner" data-aos="fade-up">
      <!-- Eyebrow pill -->
      <div class="about-eyebrow-pill">
        <span class="about-eyebrow-dot"></span>
        18+ Years of Expertise
      </div>
      <h1 class="about-hero__h1">
        About <span class="about-gradient-text">SANMYRS.</span>
      </h1>
      <p class="about-hero__sub">
        18 years of specialist chemical supply to Pakistan's textile and printing industry —
        built on expertise, consistency, and trust.
      </p>
    </div>
  </section>

  <!-- ─── STORY ─────────────────────────────────────────────── -->
  <section class="about-story">
    <div class="about-container">
      <div class="about-story__grid">

        <!-- Left: text -->
        <div data-aos="fade-up" data-aos-delay="80">
          <span class="about-section-eyebrow">Our Story</span>
          <h2 class="about-section-h2" style="margin-top:0.6rem;">
            From Karachi to Every Corner of Pakistan's Textile Belt
          </h2>
          <div class="about-story__body">
            <p>
              SANMYRS was established in Karachi with a single purpose: to bring professional-grade
              printing inks and textile chemicals to Pakistan's rapidly growing garment and textile
              manufacturing sector, with the technical knowledge to back every product we sell.
            </p>
            <p>
              Over 18 years, we have built deep expertise across three distinct chemical disciplines —
              screen printing inks (plastisol and water-based), digital printing inks (textile and
              graphic), and textile auxiliaries (dyeing and finishing). Our customers range from small
              screen printing studios in Karachi's industrial zones to large textile mills and garment
              export houses supplying international brands.
            </p>
            <p>
              We are not simply order-takers. Our team understands the technical realities of ink and
              dye chemistry, fabric behavior, and process conditions. When a customer faces a production
              problem — dye bleed on polyester, crease marks in the jet machine, a print film that's
              cracking on stretch fabric — we help solve it.
            </p>
          </div>
        </div>

        <!-- Right: brand card -->
        <div data-aos="fade-up" data-aos-delay="160">
          <div class="about-brand-card">
            <div class="about-brand-card__logo">
              SAN<span style="color:#0099AF;">MYRS</span>
            </div>
            <div class="about-brand-card__divider"></div>
            <div class="about-brand-card__stats">
              <div class="about-brand-stat">
                <span class="about-brand-stat__value">2006</span>
                <span class="about-brand-stat__label">Year Founded</span>
              </div>
              <div class="about-brand-stat">
                <span class="about-brand-stat__value">18+</span>
                <span class="about-brand-stat__label">Years of Expertise</span>
              </div>
              <div class="about-brand-stat">
                <span class="about-brand-stat__value">500+</span>
                <span class="about-brand-stat__label">Clients Served</span>
              </div>
            </div>
            <p class="about-brand-card__tagline">
              Specialist Printing Inks &amp; Textile Chemicals
            </p>
            <p class="about-brand-card__location">Karachi, Pakistan</p>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ─── STATS STRIP ───────────────────────────────────────── -->
  <section class="about-stats-strip" data-aos="fade-up">
    <div class="about-container">
      <div class="about-stats-strip__grid">
        {[
          { value: '2006', label: 'Year Founded' },
          { value: '18+',  label: 'Years of Expertise' },
          { value: '50+',  label: 'Products in Range' },
          { value: '500+', label: 'Satisfied Customers' },
        ].map(stat => (
          <div class="about-stats-strip__item">
            <span class="about-stats-strip__value">{stat.value}</span>
            <span class="about-stats-strip__label">{stat.label}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ─── VALUES ────────────────────────────────────────────── -->
  <section class="about-values">
    <div class="about-container">
      <div class="about-section-header" data-aos="fade-up">
        <span class="about-section-eyebrow">Our Principles</span>
        <h2 class="about-section-h2">What We Stand For.</h2>
      </div>

      <div class="about-cards-grid">
        {[
          {
            num: '01',
            icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z" /></svg>`,
            title: 'Quality Without Compromise',
            body: 'Every product in our range is selected and tested to perform consistently in production conditions. We do not compromise on raw material quality or batch consistency.',
          },
          {
            num: '02',
            icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" /></svg>`,
            title: 'Knowledge-Led Service',
            body: 'We invest in understanding the industries we serve. Our team can discuss dye chemistry, ink rheology, and process parameters — not just product specifications.',
          },
          {
            num: '03',
            icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z" /></svg>`,
            title: 'Long-Term Partnerships',
            body: 'We build relationships with customers who want a reliable supply partner, not just a vendor. Many of our clients have purchased from SANMYRS for over a decade.',
          },
        ].map((v, i) => (
          <div class="about-value-card" data-aos="fade-up" data-aos-delay={i === 0 ? '80' : i === 1 ? '160' : '240'}>
            <span class="about-value-card__num">{v.num}</span>
            <div class="about-value-card__icon-box">
              <Fragment set:html={v.icon} />
            </div>
            <h3 class="about-value-card__title">{v.title}</h3>
            <p class="about-value-card__body">{v.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ─── TEAM ───────────────────────────────────────────────── -->
  <section class="about-team">
    <div class="about-container">
      <div class="about-section-header" data-aos="fade-up">
        <span class="about-section-eyebrow">The People Behind It</span>
        <h2 class="about-section-h2">Our Team.</h2>
      </div>

      <div class="about-cards-grid">
        {[
          { role: 'Founder & Director',        area: 'Screen Printing Chemistry & Business Development', years: '18+ years in textile chemicals' },
          { role: 'Technical Manager',          area: 'Textile Auxiliaries & Dyeing Process Support',    years: '14+ years in wet processing'   },
          { role: 'Digital Printing Specialist', area: 'Inkjet Inks & Digital Textile Systems',          years: '10+ years in digital print'    },
        ].map((member, i) => (
          <div class="about-team-card" data-aos="fade-up" data-aos-delay={i === 0 ? '80' : i === 1 ? '160' : '240'}>
            <div class="about-team-card__avatar">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
              </svg>
            </div>
            <h3 class="about-team-card__role">{member.role}</h3>
            <p class="about-team-card__area">{member.area}</p>
            <span class="about-team-card__badge">{member.years}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ─── CTA ───────────────────────────────────────────────── -->
  <section class="about-cta">
    <div class="about-container">
      <div class="about-cta__inner" data-aos="fade-up">

        <!-- Left -->
        <div class="about-cta__left">
          <span class="about-cta__eyebrow">Ready to Partner Up?</span>
          <h2 class="about-cta__h2">Ready to work with SANMYRS.</h2>
          <p class="about-cta__sub">
            Whether you're looking for a specific product or need guidance on a process
            challenge, our team is ready to help.
          </p>
        </div>

        <!-- Right: buttons -->
        <div class="about-cta__actions">
          <a href="/contact" class="about-cta__btn-primary">
            Contact Us Today
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
            </svg>
          </a>
          <a href="https://wa.me/923183755197" target="_blank" rel="noopener noreferrer" class="about-cta__btn-ghost">
            WhatsApp Us
          </a>
        </div>

      </div>
    </div>
  </section>

</BaseLayout>

<style>
  /* ── Shared tokens ──────────────────────────────── */
  :root {
    --primary:   #0099AF;
    --navy:      #1A1A2E;
    --page-bg:   #F5F7F6;
    --body-text: #4A4A4A;
    --gold:      #F5A623;
  }

  /* ── Utility ────────────────────────────────────── */
  .about-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1.25rem;
  }
  @media (min-width: 640px)  { .about-container { padding: 0 1.5rem; } }
  @media (min-width: 1024px) { .about-container { padding: 0 2rem;   } }

  .about-section-eyebrow {
    display: block;
    text-transform: uppercase;
    font-size: 0.7rem;
    letter-spacing: 0.15em;
    color: var(--primary);
    font-weight: 600;
    margin-bottom: 0.5rem;
  }

  .about-section-h2 {
    font-family: 'Unison Pro', 'Outfit', sans-serif;
    font-size: clamp(1.7rem, 3.5vw, 2.4rem);
    font-weight: 800;
    color: var(--navy);
    line-height: 1.2;
    margin-top: 0;
    margin-bottom: 0;
  }

  .about-section-header {
    text-align: center;
    margin-bottom: 3rem;
  }
  .about-section-header .about-section-eyebrow { display: inline-block; }

  .about-cards-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
  }
  @media (min-width: 640px) {
    .about-cards-grid { grid-template-columns: repeat(3, 1fr); }
  }

  /* ── Hero ───────────────────────────────────────── */
  .about-hero {
    position: relative;
    background: var(--navy);
    overflow: hidden;
    padding: clamp(80px, 12vw, 128px) 1.25rem;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .about-hero__dots,
  .about-hero__checker {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
  }
  .about-hero__checker { z-index: 1; }
  .about-hero__dots    { z-index: 0; }

  .about-hero__inner {
    position: relative;
    z-index: 2;
    text-align: center;
    max-width: 700px;
    margin: 0 auto;
  }

  .about-eyebrow-pill {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    background: rgba(255,255,255,0.08);
    border: 1px solid rgba(255,255,255,0.14);
    border-radius: 999px;
    padding: 0.35rem 1rem;
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.82);
    margin-bottom: 1.4rem;
    backdrop-filter: blur(8px);
  }

  .about-eyebrow-dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: var(--gold);
    flex-shrink: 0;
  }

  .about-hero__h1 {
    font-family: 'Unison Pro', 'Outfit', sans-serif;
    font-size: clamp(2.4rem, 5vw, 4rem);
    font-weight: 800;
    color: #ffffff;
    line-height: 1.1;
    margin: 0 0 1.1rem;
  }

  .about-gradient-text {
    background: linear-gradient(125deg, #00c4d4, #0099AF);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .about-hero__sub {
    font-size: clamp(1rem, 2vw, 1.15rem);
    color: rgba(255,255,255,0.70);
    line-height: 1.65;
    max-width: 560px;
    margin: 0 auto;
  }

  /* ── Story ──────────────────────────────────────── */
  .about-story {
    background: #ffffff;
    padding: clamp(64px, 8vw, 96px) 1.25rem;
  }
  @media (min-width: 640px)  { .about-story { padding-left: 1.5rem; padding-right: 1.5rem; } }
  @media (min-width: 1024px) { .about-story { padding-left: 2rem;   padding-right: 2rem;   } }

  .about-story__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
    align-items: start;
  }
  @media (min-width: 1024px) {
    .about-story__grid { grid-template-columns: 1fr 1fr; }
  }

  .about-story__body {
    margin-top: 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    color: var(--body-text);
    line-height: 1.75;
    font-size: 0.95rem;
  }

  /* Brand card */
  .about-brand-card {
    background: var(--navy);
    border-radius: 1rem;
    padding: 2.25rem;
    box-shadow: 0 20px 50px rgba(0,0,0,0.22);
  }

  .about-brand-card__logo {
    font-family: 'Unison Pro', 'Outfit', sans-serif;
    font-size: 2.2rem;
    font-weight: 800;
    color: #ffffff;
    letter-spacing: -0.02em;
    margin-bottom: 1rem;
  }

  .about-brand-card__divider {
    width: 3rem;
    height: 3px;
    background: var(--primary);
    border-radius: 4px;
    margin-bottom: 1.5rem;
  }

  .about-brand-card__stats {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    margin-bottom: 1.5rem;
  }

  .about-brand-stat {
    background: rgba(255,255,255,0.06);
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 0.5rem;
    padding: 0.85rem 1rem;
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .about-brand-stat__value {
    font-family: 'Unison Pro', 'Outfit', sans-serif;
    font-size: 1.7rem;
    font-weight: 800;
    color: var(--primary);
    min-width: 3.5rem;
    line-height: 1;
  }

  .about-brand-stat__label {
    font-size: 0.82rem;
    color: rgba(255,255,255,0.60);
    line-height: 1.3;
  }

  .about-brand-card__tagline {
    font-size: 0.82rem;
    color: rgba(255,255,255,0.45);
    margin: 0 0 0.25rem;
  }

  .about-brand-card__location {
    font-size: 0.78rem;
    color: rgba(255,255,255,0.3);
    margin: 0;
  }

  /* ── Stats strip ────────────────────────────────── */
  .about-stats-strip {
    background: var(--primary);
    padding: 3rem 1.25rem;
  }
  @media (min-width: 640px)  { .about-stats-strip { padding-left: 1.5rem; padding-right: 1.5rem; } }
  @media (min-width: 1024px) { .about-stats-strip { padding-left: 2rem;   padding-right: 2rem;   } }

  .about-stats-strip__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
    text-align: center;
  }
  @media (min-width: 640px) {
    .about-stats-strip__grid { grid-template-columns: repeat(4, 1fr); }
  }

  .about-stats-strip__item {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .about-stats-strip__value {
    font-family: 'Unison Pro', 'Outfit', sans-serif;
    font-size: clamp(2rem, 4vw, 2.8rem);
    font-weight: 800;
    color: #ffffff;
    line-height: 1;
  }

  .about-stats-strip__label {
    font-size: 0.82rem;
    color: rgba(255,255,255,0.78);
    margin-top: 0.15rem;
  }

  /* ── Values ─────────────────────────────────────── */
  .about-values {
    background: var(--page-bg);
    padding: clamp(64px, 8vw, 96px) 1.25rem;
  }
  @media (min-width: 640px)  { .about-values { padding-left: 1.5rem; padding-right: 1.5rem; } }
  @media (min-width: 1024px) { .about-values { padding-left: 2rem;   padding-right: 2rem;   } }

  .about-value-card {
    background: #ffffff;
    border: 1px solid #e5e7eb;
    border-radius: 0.75rem;
    padding: 1.75rem;
    position: relative;
    transition: box-shadow 200ms ease, transform 200ms ease;
    cursor: default;
  }
  .about-value-card:hover {
    box-shadow: 0 8px 28px rgba(0,0,0,0.10);
    transform: translateY(-2px);
  }

  .about-value-card__num {
    position: absolute;
    top: 1.4rem;
    right: 1.4rem;
    font-family: 'Unison Pro', 'Outfit', sans-serif;
    font-size: 2rem;
    font-weight: 800;
    color: rgba(0,153,175,0.12);
    line-height: 1;
  }

  .about-value-card__icon-box {
    width: 2.75rem;
    height: 2.75rem;
    background: rgba(0,153,175,0.10);
    border-radius: 0.5rem;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--primary);
    margin-bottom: 1rem;
  }

  .about-value-card__title {
    font-size: 1rem;
    font-weight: 700;
    color: var(--navy);
    margin: 0 0 0.6rem;
  }

  .about-value-card__body {
    font-size: 0.875rem;
    color: var(--body-text);
    line-height: 1.7;
    margin: 0;
  }

  /* ── Team ───────────────────────────────────────── */
  .about-team {
    background: #ffffff;
    padding: clamp(48px, 6vw, 72px) 1.25rem;
  }
  @media (min-width: 640px)  { .about-team { padding-left: 1.5rem; padding-right: 1.5rem; } }
  @media (min-width: 1024px) { .about-team { padding-left: 2rem;   padding-right: 2rem;   } }

  .about-team-card {
    background: var(--page-bg);
    border: 1px solid #e5e7eb;
    border-radius: 0.75rem;
    padding: 1.75rem;
    text-align: center;
    transition: box-shadow 200ms ease, transform 200ms ease;
    cursor: default;
  }
  .about-team-card:hover {
    box-shadow: 0 6px 20px rgba(0,0,0,0.08);
    transform: translateY(-2px);
  }

  .about-team-card__avatar {
    width: 3rem;
    height: 3rem;
    border-radius: 50%;
    background: rgba(0,153,175,0.10);
    border: 1px solid rgba(0,153,175,0.20);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--primary);
    margin: 0 auto 1.1rem;
  }

  .about-team-card__role {
    font-size: 0.95rem;
    font-weight: 700;
    color: var(--navy);
    margin: 0 0 0.35rem;
  }

  .about-team-card__area {
    font-size: 0.82rem;
    color: var(--body-text);
    line-height: 1.5;
    margin: 0 0 0.75rem;
  }

  .about-team-card__badge {
    display: inline-block;
    background: rgba(0,153,175,0.10);
    color: var(--primary);
    font-size: 0.72rem;
    font-weight: 600;
    padding: 0.2rem 0.7rem;
    border-radius: 999px;
  }

  /* ── CTA ────────────────────────────────────────── */
  .about-cta {
    background: var(--navy);
    padding: clamp(56px, 7vw, 80px) 1.25rem;
  }
  @media (min-width: 640px)  { .about-cta { padding-left: 1.5rem; padding-right: 1.5rem; } }
  @media (min-width: 1024px) { .about-cta { padding-left: 2rem;   padding-right: 2rem;   } }

  .about-cta__inner {
    display: flex;
    flex-direction: column;
    gap: 2rem;
    align-items: flex-start;
  }
  @media (min-width: 768px) {
    .about-cta__inner {
      flex-direction: row;
      align-items: center;
      justify-content: space-between;
    }
  }

  .about-cta__eyebrow {
    display: block;
    text-transform: uppercase;

---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Certifications & Quality Assurance | SANMYRS"
  description="SANMYRS supplies products meeting OEKO-TEX, REACH, GOTS, and international quality standards for Pakistan's export-oriented textile and printing industry."
>

  <!-- ── HERO ─────────────────────────────────────────── -->
  <section class="cr-hero">
    <div class="cr-hero__glow" aria-hidden="true"></div>
    <div class="cr-container">
      <div class="cr-hero__inner" data-aos="fade-up">
        <div class="cr-eyebrow-pill">
          <span class="cr-gold-dot" aria-hidden="true"></span>
          Quality &amp; Compliance
        </div>
        <h1 class="cr-hero__h1 font-unison">Standards We Uphold.</h1>
        <p class="cr-hero__sub">
          We supply products aligned with international quality standards and compliance requirements
          for Pakistan's export-oriented textile industry.
        </p>
        <div class="cr-hero__accent-line" aria-hidden="true"></div>
      </div>
    </div>
  </section>

  <!-- ── QUALITY COMMITMENTS ───────────────────────────── -->
  <section class="cr-quality">
    <div class="cr-container">

      <div class="cr-section-header" data-aos="fade-up">
        <span class="cr-section-eyebrow">Our Process</span>
        <h2 class="cr-section-h2 font-unison">Quality at Every Stage.</h2>
        <p class="cr-section-intro">
          Consistent quality is the foundation of SANMYRS's business. Our customers rely on us to
          supply products that perform the same way every batch, every order. We work only with
          suppliers and raw material sources that meet our quality criteria, and we carry out incoming
          inspection on every delivery to verify batch consistency before products are offered for sale.
        </p>
      </div>

      <div class="cr-steps-grid">
        {[
          {
            num: '01',
            icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z" /></svg>`,
            title: 'Batch Consistency',
            body: 'Every incoming batch is checked against reference standards before entering stock. Customers receive consistent-performing product across all orders.',
          },
          {
            num: '02',
            icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2" /></svg>`,
            title: 'Technical Data Sheets',
            body: 'Technical data sheets are available for all products in our range, covering application guidance, curing parameters, compatibility, and safety information.',
          },
          {
            num: '03',
            icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>`,
            title: 'Compliance Grades',
            body: 'We stock formaldehyde-free, PFAS-free, and APEO-free grades across our textile auxiliaries range for customers with strict export-market compliance requirements.',
          },
          {
            num: '04',
            icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" /></svg>`,
            title: 'Supplier Traceability',
            body: 'We maintain full supplier traceability for all products in our range, enabling us to trace product origin and provide documentation for buyer compliance audits.',
          },
        ].map((step, i) => (
          <div
            class="cr-step-card"
            data-aos="fade-up"
            data-aos-delay={String(i * 80)}
          >
            <div class="cr-step-card__num-circle">{step.num}</div>
            <div class="cr-step-card__icon-box">
              <Fragment set:html={step.icon} />
            </div>
            <h3 class="cr-step-card__title font-unison">{step.title}</h3>
            <p class="cr-step-card__body">{step.body}</p>
          </div>
        ))}
      </div>

    </div>
  </section>

  <!-- ── STANDARDS SECTION ─────────────────────────────── -->
  <section class="cr-standards">
    <div class="cr-container">

      <div class="cr-section-header" data-aos="fade-up">
        <span class="cr-section-eyebrow">Standards</span>
        <h2 class="cr-section-h2 font-unison">International Compliance Frameworks.</h2>
        <p class="cr-section-intro">
          Products in our range are available in grades aligned with the following international
          textile and chemical standards. Contact us to confirm compliance grade availability for
          specific products.
        </p>
      </div>

      <div class="cr-cert-grid">
        {[
          {
            name: 'OEKO-TEX Standard 100',
            abbr: 'OEKO-TEX',
            description: "The world's leading textile safety label. We stock OEKO-TEX compliant grades of softeners, fixing agents, and finishing chemicals that meet all restricted substance limits under Annex 6 of the OEKO-TEX Standard 100.",
            accentColor: '#0369A1',
            badgeBg: '#EFF6FF',
            badgeText: '#1D4ED8',
          },
          {
            name: 'REACH Regulation (EU)',
            abbr: 'REACH',
            description: 'European chemical regulation restricting hazardous substances in textile articles. Our textile auxiliaries and printing chemical range includes REACH-compliant grades for manufacturers exporting to EU markets.',
            accentColor: '#059669',
            badgeBg: '#ECFDF5',
            badgeText: '#065F46',
          },
          {
            name: 'GOTS — Global Organic Textile Standard',
            abbr: 'GOTS',
            description: 'For customers processing certified organic cotton, we can supply GOTS-approved auxiliary chemistry including detergents, wetting agents, and softeners that meet GOTS Annex 6 approved inputs criteria.',
            accentColor: '#047857',
            badgeBg: '#D1FAE5',
            badgeText: '#064E3B',
          },
          {
            name: 'Bluesign System',
            abbr: 'bluesign',
            description: 'The bluesign standard for sustainable textile chemical management. We can source bluesign-approved chemical alternatives across our softener and finishing auxiliary range for certified sportswear and outdoor apparel supply chains.',
            accentColor: '#0284C7',
            badgeBg: '#E0F2FE',
            badgeText: '#075985',
          },
        ].map((cert, i) => (
          <div
            class="cr-cert-card"
            style={`--cr-accent:${cert.accentColor}; --cr-badge-bg:${cert.badgeBg}; --cr-badge-text:${cert.badgeText};`}
            data-aos="fade-up"
            data-aos-delay={String(i * 80)}
          >
            <div class="cr-cert-card__top-row">
              <span class="cr-cert-card__badge">{cert.abbr}</span>
              <div class="cr-cert-card__shield-box" aria-hidden="true">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
                </svg>
              </div>
            </div>
            <h3 class="cr-cert-card__name font-unison">{cert.name}</h3>
            <p class="cr-cert-card__desc">{cert.description}</p>
          </div>
        ))}
      </div>

      <!-- Disclaimer -->
      <div class="cr-disclaimer" data-aos="fade-up" data-aos-delay="80">
        <div class="cr-disclaimer__icon" aria-hidden="true">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
        </div>
        <p class="cr-disclaimer__text">
          <strong>Note:</strong> Certification status is product-specific. Not all products in our range are available in all compliance grades. Contact our team with your specific compliance requirements and we will confirm product availability and provide relevant documentation.
        </p>
      </div>

    </div>
  </section>

  <!-- ── CTA ───────────────────────────────────────────── -->
  <section class="cr-cta">
    <div class="cr-container">
      <div class="cr-cta__inner" data-aos="fade-up">

        <div class="cr-cta__text" data-aos="fade-up" data-aos-delay="80">
          <h2 class="cr-cta__h2 font-unison">Compliance Questions?</h2>
          <p class="cr-cta__sub">
            Share your buyer's compliance requirements and we'll confirm which grades of our products
            meet them and provide the relevant documentation.
          </p>
        </div>

        <div class="cr-cta__buttons" data-aos="fade-up" data-aos-delay="160">
          <a href="/contact" class="cr-cta__btn-primary">
            Request Compliance Information
            <svg xmlns="http://www.w3.org/2000/svg" class="cr-btn-icon" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
            </svg>
          </a>
          <a
            href="https://wa.me/923183755197?text=Hi%2C%20I%20have%20a%20compliance%20question."
            target="_blank"
            rel="noopener noreferrer"
            class="cr-cta__btn-ghost"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="cr-btn-icon" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/>
              <path d="M12 0C5.373 0 0 5.373 0 12c0 2.124.554 4.118 1.528 5.852L.057 23.625a.75.75 0 00.918.918l5.773-1.471A11.943 11.943 0 0012 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 21.75a9.718 9.718 0 01-4.952-1.352l-.354-.212-3.668.935.952-3.576-.232-.368A9.718 9.718 0 012.25 12C2.25 6.615 6.615 2.25 12 2.25S21.75 6.615 21.75 12 17.385 21.75 12 21.75z"/>
            </svg>
            WhatsApp Us
          </a>
        </div>

      </div>
    </div>
  </section>

</BaseLayout>

<style>
  /* ── Container ───────────────────────────────────────── */
  .cr-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 clamp(16px, 4vw, 32px);
  }

  /* ── HERO ────────────────────────────────────────────── */
  .cr-hero {
    position: relative;
    background: #1A1A2E;
    overflow: hidden;
    padding: clamp(80px, 12vw, 130px) 0 clamp(64px, 8vw, 96px);
  }

  .cr-hero__glow {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }
  .cr-hero__glow::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse 55% 90% at 105% -15%, rgba(0,153,175,0.18) 0%, transparent 60%);
  }

  .cr-hero__inner {
    position: relative;
    z-index: 1;
    max-width: 680px;
  }

  .cr-eyebrow-pill {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    background: rgba(0,153,175,0.15);
    border: 1px solid rgba(0,153,175,0.3);
    color: #0099AF;
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    padding: 0.3rem 0.85rem;
    border-radius: 4px;
    margin-bottom: 1.25rem;
  }

  .cr-gold-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: #F5A623;
    flex-shrink: 0;
  }

  .cr-hero__h1 {
    font-size: clamp(2.8rem, 6vw, 4.5rem);
    font-weight: 800;
    color: #ffffff;
    line-height: 1.05;
    margin: 0 0 1.25rem;
  }

  .cr-hero__sub {
    color: rgba(255,255,255,0.65);
    font-size: clamp(1rem, 2vw, 1.15rem);
    line-height: 1.7;
    max-width: 540px;
    margin: 0;
  }

  .cr-hero__accent-line {
    width: 3rem;
    height: 3px;
    background: #0099AF;
    border-radius: 2px;
    margin-top: 2rem;
  }

  /* ── Shared section header ──────────────────────────── */
  .cr-section-header {
    text-align: center;
    max-width: 700px;
    margin: 0 auto clamp(2.5rem, 5vw, 3.5rem);
  }

  .cr-section-eyebrow {
    display: inline-block;
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #0099AF;
    margin-bottom: 0.5rem;
  }

  .cr-section-h2 {
    font-size: clamp(1.8rem, 3.5vw, 2.8rem);
    font-weight: 800;
    color: #0F172A;
    line-height: 1.15;
    margin: 0 0 0.75rem;
  }

  .cr-section-intro {
    color: #475569;
    font-size: 1rem;
    line-height: 1.75;
    margin: 0;
  }

  /* ── Quality Commitments ─────────────────────────────── */
  .cr-quality {
    background: #ffffff;
    padding: clamp(64px, 8vw, 96px) 0;
  }

  .cr-steps-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
  }
  @media (min-width: 640px)  { .cr-steps-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (min-width: 1024px) { .cr-steps-grid { grid-template-columns: repeat(4, 1fr); } }

  .cr-step-card {
    background: #ffffff;
    border: 1px solid #E2E8F0;
    border-top: 3px solid #0099AF;
    border-radius: 16px;
    padding: 1.75rem;
    transition: box-shadow 200ms ease, transform 200ms ease;
    cursor: default;
  }
  .cr-step-card:hover {
    box-shadow: 0 16px 40px rgba(0,0,0,0.10);
    transform: translateY(-3px);
  }

  .cr-step-card__num-circle {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2rem;
    height: 2rem;
    border-radius: 50%;
    background: rgba(0,153,175,0.10);
    color: #0099AF;
    font-size: 0.7rem;
    font-weight: 800;
    letter-spacing: 0.04em;
    margin-bottom: 0.875rem;
  }

  .cr-step-card__icon-box {
    width: 44px;
    height: 44px;
    background: rgba(0,153,175,0.10);
    border-radius: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #0099AF;
    margin-bottom: 0.875rem;
  }

  .cr-step-card__title {
    font-size: 0.95rem;
    font-weight: 700;
    color: #0F172A;
    margin: 0 0 0.5rem;
    line-height: 1.3;
  }

  .cr-step-card__body {
    font-size: 0.875rem;
    color: #475569;
    line-height: 1.65;
    margin: 0;
  }

  /* ── Standards Section ───────────────────────────────── */
  .cr-standards {
    background: #F8FAFC;
    padding: clamp(64px, 8vw, 96px) 0;
  }

  .cr-cert-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
    margin-bottom: 2rem;
  }
  @media (min-width: 768px)  { .cr-cert-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (min-width: 1024px) { .cr-cert-grid { grid-template-columns: repeat(4, 1fr); } }

  .cr-cert-card {
    background: #ffffff;
    border: 1px solid #E2E8F0;
    border-top: 3px solid var(--cr-accent, #0099AF);
    border-radius: 16px;
    padding: 1.75rem;
    display: flex;
    flex-direction: column;
    transition: box-shadow 200ms ease, transform 200ms ease;
    cursor: default;
  }
  .cr-cert-card:hover {
    box-shadow: 0 16px 40px rgba(0,0,0,0.10);
    transform: translateY(-3px);
  }

  .cr-cert-card__top-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 1rem;
  }

  .cr-cert-card__badge {
    display: inline-block;
    font-size: 0.6875rem;
    font-weight: 800;
    letter-spacing: 0.06em;
    padding: 0.25rem 0.625rem;
    border-radius: 999px;
    background: var(--cr-badge-bg, rgba(0,153,175,0.10));
    color: var(--cr-badge-text, #0099AF);
  }

  .cr-cert-card__shield-box {
    width: 2.25rem;
    height: 2.25rem;
    border-radius: 8px;
    background: rgba(0,0,0,0.04);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--cr-accent, #0099AF);
    flex-shrink: 0;
  }

  .cr-cert-card__name {
    font-size: 0.9375rem;
    font-weight: 700;
    color: #0F172A;
    margin: 0 0 0.75rem;
    line-height: 1.35;
  }

  .cr-cert-card__desc {
    font-size: 0.875rem;
    color: #475569;
    line-height: 1.65;
    flex-grow: 1;
    margin: 0;
  }

  /* ── Disclaimer ──────────────────────────────────────── */
  .cr-disclaimer {
    background: #ffffff;
    border: 1px solid #E2E8F0;
    border-left: 3px solid #0099AF;
    border-radius: 12px;
    padding: 1.25rem 1.5rem;
    max-width: 52rem;
    margin: 0 auto;
    display: flex;
    align-items: flex-start;
    gap: 0.875rem;
  }

  .cr-disclaimer__icon {
    flex-shrink: 0;
    margin-top: 0.1rem;
    color: #0099AF;
  }

  .cr-disclaimer__text {
    font-size: 0.875rem;
    color: #475569;
    line-height: 1.65;
    margin: 0;
  }

  .cr-disclaimer__text strong {
    color: #0099AF;
    font-weight: 700;
  }

  /* ── CTA ─────────────────────────────────────────────── */
  .cr-cta {
    background: #1A1A2E;
    border-top: 3px solid #0099AF;
    padding: clamp(56px, 7vw, 80px) 0;
  }

  .cr-cta__inner {
    display: flex;
    flex-direction: column;
    gap: 2rem;
    align-items: flex-start;
  }
  @media (min-width: 768px) {
    .cr-cta__inner {
      flex-direction: row;
      align-items: center;
      justify-content: space-between;
    }
  }

  .cr-cta__text {
    flex: 1;
    min-width: 0;
  }

  .cr-cta__h2 {
    font-size: clamp(1.75rem, 3.5vw, 2.5rem);
    font-weight: 800;
    color: #ffffff;
    line-height: 1.15;
    margin: 0 0 0.75rem;
  }

  .cr-cta__sub {
    color: rgba(255,255,255,0.65);
    font-size: 1rem;
    line-height: 1.7;
    margin: 0;
    max-width: 480px;
  }

  .cr-cta__buttons {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    flex-shrink: 0;
  }
  @media (min-width: 480px) {
    .cr-cta__buttons {
      flex-direction: row;
      align-items: center;
    }
  }

  .cr-cta__btn-primary {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    background: #0099AF;
    color: #ffffff;
    font-weight: 700;
    font-size: 0.9rem;
    padding: 0.8rem 1.75rem;
    border-radius: 8px;
    text-decoration: none;
    transition: background 150ms ease, transform 150ms ease;
    white-space: nowrap;
  }
  .cr-cta__btn-primary:hover {
    background: #007A8A;
    transform: translateY(-1px);
  }

  .cr-cta__btn-ghost {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    background: rgba(255,255,255,0.08);
    border: 1.5px solid rgba(255,255,255,0.2);
    color: #ffffff;
    font-weight: 700;
    font-size: 0.9rem;
    padding: 0.8rem 1.75rem;
    border-radius: 8px;
    text-decoration: none;
    transition: background 150ms ease, transform 150ms ease;
    white-space: nowrap;
  }
  .cr-cta__btn-ghost:hover {
    background: rgba(255,255,255,0.14);
    transform: translateY(-1px);
  }

  .cr-btn-icon {
    width: 16px;
    height: 16px;
    flex-shrink: 0;
  }
</style>

---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Certifications & Quality Assurance | SANMYRS"
  description="SANMYRS supplies products meeting OEKO-TEX, REACH, GOTS, and international quality standards for Pakistan's export-oriented textile and printing industry."
>

  <!-- ── NEOMINIMALIST HERO: TYPOGRAPHY FOCUS ──────────── -->
  <section class="relative pt-32 pb-24 lg:pt-44 lg:pb-32 bg-white overflow-hidden border-b border-gray-100">
    <div class="absolute inset-0 bg-[radial-gradient(#1A1A2E_1px,transparent_1px)] [background-size:24px_24px] opacity-[0.03]"></div>
    <div class="absolute top-0 right-0 w-[500px] h-[500px] bg-[#0099AF] rounded-full blur-[150px] opacity-10 -translate-y-1/2 translate-x-1/2"></div>
    
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10 text-center">
      <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-slate-50 border border-gray-200 shadow-sm mb-6" data-aos="fade-down">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-[#0099AF]" viewBox="0 0 20 20" fill="currentColor">
          <path fill-rule="evenodd" d="M2.166 4.999A11.954 11.954 0 0010 1.944 11.954 11.954 0 0017.834 5c.11.65.166 1.32.166 2.001 0 5.225-3.34 9.67-8 11.317C5.34 16.67 2 12.225 2 7c0-.682.057-1.35.166-2.001zm11.541 3.708a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
        </svg>
        <span class="text-xs font-bold uppercase tracking-widest text-[#1A1A2E]">Quality & Compliance</span>
      </div>
      <h1 class="text-4xl sm:text-5xl lg:text-7xl font-extrabold text-[#1A1A2E] tracking-tight leading-[1.05] mb-6 font-unison max-w-4xl mx-auto" data-aos="fade-up" data-aos-delay="100">
        The Highest Standards <br/>
        <span class="text-transparent bg-clip-text bg-gradient-to-r from-[#1A1A2E] to-[#0099AF]">We Uphold.</span>
      </h1>
      <p class="text-lg lg:text-xl text-gray-600 leading-relaxed max-w-2xl mx-auto mb-10" data-aos="fade-up" data-aos-delay="150">
        We supply products aligned with international quality standards and compliance requirements for Pakistan's export-oriented textile industry.
      </p>
    </div>
  </section>

  <!-- ── PROCESS PIPELINE ──────────────────────────────── -->
  <section class="py-24 bg-slate-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      
      <div class="flex flex-col md:flex-row gap-12 items-start mb-20" data-aos="fade-up">
        <div class="max-w-md shrink-0">
          <h2 class="text-sm font-bold uppercase tracking-widest text-[#0099AF] mb-3">Our Process</h2>
          <h3 class="text-3xl md:text-5xl font-extrabold text-[#1A1A2E] font-unison leading-tight">Quality at Every Stage.</h3>
        </div>
        <div class="bg-white p-6 rounded-2xl border border-gray-100 shadow-sm text-gray-600 leading-relaxed">
          Consistent quality is the foundation of SANMYRS's business. Our customers rely on us to supply products that perform the same way every batch, every order. We work only with suppliers and raw material sources that meet our criteria.
        </div>
      </div>

      <!-- Pipeline Container -->
      <div class="relative">
        <!-- Connecting Line (Desktop) -->
        <div class="hidden lg:block absolute top-[4.5rem] left-[10%] right-[10%] h-[2px] bg-gradient-to-r from-[#1A1A2E]/10 via-[#0099AF]/50 to-[#1A1A2E]/10 pointer-events-none"></div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
          {[
            {
              num: '01',
              title: 'Batch Consistency',
              body: 'Every incoming batch is checked against reference standards. Customers receive consistent-performing product across all orders.',
            },
            {
              num: '02',
              title: 'Technical Docs',
              body: 'Technical sheets are available for all products, covering application guidance, curing parameters, and safety information.',
            },
            {
              num: '03',
              title: 'Compliance Grades',
              body: 'We stock formaldehyde-free, PFAS-free, and APEO-free grades for customers with strict export compliance requirements.',
            },
            {
              num: '04',
              title: 'Traceability',
              body: 'We maintain full traceability for our range, enabling us to trace origin and provide documentation for buyer audits.',
            },
          ].map((step, i) => (
            <div class="relative group" data-aos="fade-up" data-aos-delay={i * 100}>
              <div class="bg-white rounded-[2rem] p-8 border border-gray-100 shadow-sm transition-all duration-300 group-hover:-translate-y-2 group-hover:shadow-xl relative z-10 pt-16 h-full text-center lg:text-left">
                
                <!-- Number Node (overlapping line on desktop) -->
                <div class="absolute -top-6 left-1/2 lg:left-8 -translate-x-1/2 lg:translate-x-0 w-12 h-12 rounded-2xl bg-[#1A1A2E] text-white flex items-center justify-center font-unison text-xl font-bold shadow-lg shadow-[#1A1A2E]/20 ring-4 ring-slate-50 transition-transform group-hover:scale-110 group-hover:bg-[#0099AF]">
                  {step.num}
                </div>

                <h3 class="text-xl font-bold text-[#1A1A2E] mb-3">{step.title}</h3>
                <p class="text-gray-500 text-sm leading-relaxed">{step.body}</p>
              </div>
            </div>
          ))}
        </div>
      </div>

    </div>
  </section>

  <!-- ── STANDARDS ROW CARDS ───────────────────────────── -->
  <section class="py-24 bg-white border-t border-gray-100">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      
      <div class="text-center max-w-2xl mx-auto mb-16" data-aos="fade-up">
        <h2 class="text-sm font-bold uppercase tracking-widest text-[#0099AF] mb-3">Standards</h2>
        <h3 class="text-3xl md:text-5xl font-extrabold text-[#1A1A2E] font-unison leading-tight mb-6">International Compliance.</h3>
        <p class="text-gray-600">
          We offer products aligned with international textile and chemical standards. Contact us to confirm compliance grade availability for specific items.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-16">
        {[
          {
            name: 'OEKO-TEX Standard 100',
            abbr: 'OEKO-TEX',
            desc: "The leading textile safety label. We stock OEKO-TEX compliant grades of softeners and fixing agents meeting Annex 6 limits.",
            icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9"/></svg>`,
            style: 'hover:shadow-[#0369A1]/20 hover:border-[#0369A1]/30',
            bg: 'bg-gradient-to-br from-[#EFF6FF] to-white',
            text: 'text-[#0369A1]'
          },
          {
            name: 'REACH Regulation (EU)',
            abbr: 'REACH',
            desc: 'European chemical regulation restricting hazardous substances. Our range includes REACH-compliant grades for EU exporters.',
            icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>`,
            style: 'hover:shadow-[#059669]/20 hover:border-[#059669]/30',
            bg: 'bg-gradient-to-br from-[#ECFDF5] to-white',
            text: 'text-[#059669]'
          },
          {
            name: 'Global Organic Textile Standard',
            abbr: 'GOTS',
            desc: 'We supply GOTS-approved auxiliary chemistry including wetting agents and softeners meeting Annex 6 inputs criteria.',
            icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z" /></svg>`,
            style: 'hover:shadow-[#047857]/20 hover:border-[#047857]/30',
            bg: 'bg-gradient-to-br from-[#D1FAE5] to-white',
            text: 'text-[#047857]'
          },
          {
            name: 'Bluesign System',
            abbr: 'bluesign',
            desc: 'The bluesign standard for sustainable chemical management. We source alternatives for certified outdoor apparel supply chains.',
            icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 002-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" /></svg>`,
            style: 'hover:shadow-[#0284C7]/20 hover:border-[#0284C7]/30',
            bg: 'bg-gradient-to-br from-[#E0F2FE] to-white',
            text: 'text-[#0284C7]'
          },
        ].map((cert, i) => (
          <div class={`rounded-3xl p-8 border border-gray-100 shadow-sm transition-all duration-300 hover:-translate-y-1 ${cert.style} ${cert.bg}`} data-aos="fade-up" data-aos-delay={i * 100}>
            <div class="flex items-start justify-between gap-4 mb-6">
              <div class={`w-16 h-16 rounded-2xl bg-white shadow-sm flex items-center justify-center border border-white/50 ${cert.text}`}>
                <Fragment set:html={cert.icon} />
              </div>
              <span class={`inline-block px-4 py-1.5 rounded-full text-xs font-bold uppercase tracking-wider bg-white shadow-sm border border-gray-100 ${cert.text}`}>
                {cert.abbr}
              </span>
            </div>
            <h3 class="text-2xl font-bold text-[#1A1A2E] mb-3">{cert.name}</h3>
            <p class="text-gray-600 leading-relaxed text-sm">
              {cert.desc}
            </p>
          </div>
        ))}
      </div>

      <!-- Disclaimer Alert -->
      <div class="max-w-3xl mx-auto bg-slate-50 border border-gray-200 rounded-2xl p-6 flex items-start gap-4 shadow-sm" data-aos="fade-up">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-[#0099AF] shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
        <p class="text-sm text-gray-600 leading-relaxed">
          <strong class="text-[#1A1A2E]">Important Note:</strong> Certification status is product-specific. Not all products in our range are available in all compliance grades. Contact our team with your specific compliance requirements and we will confirm product availability and provide relevant documentation.
        </p>
      </div>

    </div>
  </section>

  <!-- ── CALL TO ACTION ─────────────────────────────────── -->
  <section class="border-t border-gray-100">
    <div class="grid grid-cols-1 md:grid-cols-2">
      <div class="bg-white p-12 md:p-24 flex items-center justify-center md:justify-end text-center md:text-left">
        <div class="max-w-md">
          <h2 class="text-3xl md:text-5xl font-extrabold text-[#1A1A2E] font-unison leading-tight mb-4">Compliance Questions?</h2>
          <p class="text-gray-500 mb-8 leading-relaxed">
            Share your buyer's compliance requirements and we'll confirm which grades of our products meet them and provide the relevant documentation.
          </p>
          <a href="/contact" class="inline-flex justify-center items-center px-8 py-4 rounded-xl bg-[#0099AF] text-white font-bold tracking-wide transition-all hover:bg-[#007A8A] hover:-translate-y-1 shadow-lg shadow-[#0099AF]/20 w-full sm:w-auto">
            Request Information
          </a>
        </div>
      </div>
      <div class="bg-[#1A1A2E] p-12 md:p-24 flex items-center justify-center md:justify-start text-center md:text-left relative overflow-hidden">
        <div class="absolute inset-0 opacity-10" style="background-image: radial-gradient(#ffffff 1px, transparent 1px); background-size: 24px 24px;"></div>
        <div class="max-w-md relative z-10">
          <div class="w-16 h-16 rounded-full bg-[#25D366]/20 text-[#25D366] flex items-center justify-center mb-6 mx-auto md:mx-0">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
          </div>
          <h2 class="text-3xl md:text-4xl font-extrabold text-white font-unison leading-tight mb-4">Or text us directly.</h2>
          <p class="text-gray-400 mb-8 leading-relaxed">
            Need an immediate answer? Send your query through WhatsApp.
          </p>
          <a href="https://wa.me/923183755197" target="_blank" rel="noopener noreferrer" class="inline-flex justify-center items-center px-8 py-4 rounded-xl bg-white text-[#1A1A2E] border border-transparent font-bold tracking-wide transition-all hover:bg-gray-100 hover:-translate-y-1 w-full sm:w-auto">
            WhatsApp Us
          </a>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>

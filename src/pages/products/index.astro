---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { products } from '../../data/products.js';

const categories = [
  {
    num: '01',
    key: 'screen-printing',
    href: '/products/screen-printing',
    title: 'Screen Printing',
    subtitle: 'Inks & Additives',
    description: 'Plastisol and water-based inks, specialty effect inks, and additives for garment and textile screen printing operations.',
    count: products['screen-printing'].subcategories.reduce((a, s) => a + s.products.length, 0),
    accentColor: '#0099AF',
    tags: ['Plastisol Inks', 'Water-Based Inks', 'Metallic & Glitter', 'High Density', 'Specialty Additives'],
    icon: `<svg width="28" height="28" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><rect x="2" y="5" width="20" height="11" rx="2"/><path d="M7 19h10M9.5 16v3M14.5 16v3"/><path d="M6 9.5h12M6 12.5h8"/></svg>`,
  },
  {
    num: '02',
    key: 'screen-chemicals-accessories',
    href: '/products/screen-chemicals-accessories',
    title: 'Screen Chemicals',
    subtitle: '& Accessories',
    description: 'Screen emulsions, degreasers, screen openers, mesh, squeegees, and all essentials for professional screen preparation.',
    count: 33,
    accentColor: '#D97706',
    tags: ['Emulsions', 'Degreasers', 'Screen Openers', 'Mesh & Squeegees', 'Accessories'],
    icon: `<svg width="28" height="28" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><path d="M10 2h4l1 6H9L10 2z"/><path d="M9 8c-2 1.5-4 3.5-4 7a7 7 0 0014 0c0-3.5-2-5.5-4-7"/><line x1="12" y1="8" x2="12" y2="13"/></svg>`,
  },
  {
    num: '03',
    key: 'digital-printing',
    href: '/products/digital-printing',
    title: 'Digital Printing',
    subtitle: 'Inks & Systems',
    description: 'Reactive, disperse, sublimation, acid, pigment, eco solvent, UV, and latex inks for textile inkjet and wide-format printing.',
    count: products['digital-printing'].subcategories.reduce((a, s) => a + s.products.length, 0),
    accentColor: '#0099AF',
    tags: ['Reactive & Acid', 'Sublimation', 'UV & Latex', 'Eco Solvent', 'DTF Inks'],
    icon: `<svg width="28" height="28" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><rect x="3" y="7" width="18" height="10" rx="2"/><path d="M7 7V5a2 2 0 012-2h6a2 2 0 012 2v2"/><circle cx="7.5" cy="12" r="1"/><path d="M11 12h5M11 15h3"/></svg>`,
  },
  {
    num: '04',
    key: 'textile-auxiliaries',
    href: '/products/textile-auxiliaries',
    title: 'Textile Auxiliaries',
    subtitle: 'Dyeing & Finishing',
    description: 'Wetting agents, leveling agents, softeners, finishing resins, enzymes, and functional chemicals for textile wet processing.',
    count: products['textile-auxiliaries'].subcategories.reduce((a, s) => a + s.products.length, 0),
    accentColor: '#D97706',
    tags: ['Pre-Treatment', 'Softeners', 'Finishing Resins', 'Enzymes', 'Functional Agents'],
    icon: `<svg width="28" height="28" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><path d="M12 3C8.5 3 5 6 5 10v4c0 4 3.1 7 7 7s7-3 7-7v-4c0-4-3.5-7-7-7z"/><path d="M8.5 10.5c1.5-1.2 5.5-1.2 7 0M8.5 14c1.5 1.2 5.5 1.2 7 0"/></svg>`,
  },
];

const totalProducts = categories.reduce((a, c) => a + c.count, 0);
---

<BaseLayout
  title="Products | SANMYRS — Printing Inks & Textile Chemicals, Karachi"
  description="Browse SANMYRS's complete range: screen printing inks, screen chemicals & accessories, digital printing inks, and textile auxiliaries. 80+ specialist products for Pakistan's textile industry."
>

  <!-- ═══════════════════════════════════════════
       HERO
  ════════════════════════════════════════════ -->
  <section class="prod-hero" aria-label="Products overview">
    <div class="hero-glow" aria-hidden="true"></div>
    <div class="prod-hero-inner">

      <div class="prod-hero-eyebrow">
        <span class="prod-eyebrow-dot" aria-hidden="true"></span>
        80+ Specialist Products
      </div>

      <h1 class="prod-hero-h1 font-unison">
        Our Product <span class="prod-hero-gradient">Range.</span>
      </h1>

      <p class="prod-hero-desc">
        Four categories. Every chemical your screen printing, digital printing, and textile processing operation needs — stocked in Karachi, dispatched fast.
      </p>

      <nav class="prod-quicknav" aria-label="Jump to category">
        {categories.map(cat => (
          <a href={cat.href} class="prod-quickpill" style={`--pill-accent:${cat.accentColor};`}>
            <span class="prod-quickpill-num">{cat.num}</span>
            {cat.title}
          </a>
        ))}
      </nav>

    </div>
  </section>


  <!-- ═══════════════════════════════════════════
       STATS STRIP
  ════════════════════════════════════════════ -->
  <section class="prod-stats-strip" aria-label="Product statistics">
    <div class="prod-container">
      <div class="prod-stats-grid">
        {[
          { value: String(totalProducts) + '+', label: 'Total Products' },
          { value: '4',   label: 'Categories' },
          { value: '18+', label: 'Years in Business' },
          { value: 'KHI', label: 'Ready Stock' },
        ].map(s => (
          <div class="prod-stat-item">
            <span class="prod-stat-value font-unison">{s.value}</span>
            <span class="prod-stat-label">{s.label}</span>
          </div>
        ))}
      </div>
    </div>
  </section>


  <!-- ═══════════════════════════════════════════
       CATEGORY CARDS
  ════════════════════════════════════════════ -->
  <section class="prod-cats-section" aria-labelledby="cats-heading">
    <div class="prod-container">

      <div class="prod-section-hd">
        <p class="prod-eyebrow-text">Browse by Category</p>
        <h2 id="cats-heading" class="prod-section-h2 font-unison">Find What You Need.</h2>
      </div>

      <div class="prod-cat-grid">
        {categories.map((cat, i) => (
          <a
            href={cat.href}
            class="prod-cat-card"
            style={`--cat-accent:${cat.accentColor};`}
            aria-label={`${cat.title} — ${cat.count} products`}
            data-aos="fade-up"
            data-aos-delay={String(i * 100)}
          >
            <!-- Top accent bar -->
            <div class="prod-cat-accent-top" aria-hidden="true"></div>

            <!-- Head row: ghost number + icon -->
            <div class="prod-cat-head">
              <span class="prod-cat-num font-unison" aria-hidden="true">{cat.num}</span>
              <span class="prod-cat-icon" aria-hidden="true" set:html={cat.icon}></span>
            </div>

            <!-- Title -->
            <div class="prod-cat-title-wrap">
              <h3 class="prod-cat-title font-unison">{cat.title}</h3>
              <span class="prod-cat-subtitle">{cat.subtitle}</span>
            </div>

            <!-- Count badge -->
            <span class="prod-cat-count">{cat.count} Products</span>

            <!-- Description -->
            <p class="prod-cat-desc">{cat.description}</p>

            <!-- Tags -->
            <div class="prod-cat-tags" aria-label="Includes">
              {cat.tags.map(tag => (
                <span class="prod-cat-tag">{tag}</span>
              ))}
            </div>

            <!-- CTA row -->
            <div class="prod-cat-cta" aria-hidden="true">
              <span>Browse Products</span>
              <svg width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
              </svg>
            </div>

          </a>
        ))}
      </div>

    </div>
  </section>


  <!-- ═══════════════════════════════════════════
       BOTTOM CTA
  ════════════════════════════════════════════ -->
  <section class="prod-cta-section" aria-label="Contact call to action">
    <div class="prod-container">
      <div class="prod-cta-inner">

        <div class="prod-cta-text">
          <p class="prod-cta-eyebrow">Can't Find It?</p>
          <h2 class="prod-cta-h2 font-unison">We source specialty chemicals on request.</h2>
          <p class="prod-cta-sub">
            If you need a product not listed here — a specific grade, formulation, or specialty chemical — contact our team. We source on request for regular customers.
          </p>
        </div>

        <div class="prod-cta-actions">
          <a href="/contact" class="prod-btn-white">Get in Touch</a>
          <a href="https://wa.me/923183755197"
             target="_blank"
             rel="noopener noreferrer"
             class="prod-btn-ghost-white"
             aria-label="Contact us on WhatsApp">
            <svg viewBox="0 0 24 24" fill="currentColor" width="16" height="16" style="color:#4ade80;flex-shrink:0;" aria-hidden="true">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
            </svg>
            WhatsApp Us
          </a>
        </div>

      </div>
    </div>
  </section>

</BaseLayout>


<style>
/* ─────────────────────────────────────────────
   TOKENS
───────────────────────────────────────────── */
:root {
  --teal:       #0099AF;
  --teal-dark:  #007A8A;
  --teal-light: #00C4D4;
  --amber:      #D97706;
  --navy:       #1A1A2E;
  --gold:       #F5A623;
  --page-bg:    #F8FAFC;
  --surface:    #FFFFFF;
  --heading:    #0F172A;
  --body:       #475569;
  --border:     #E2E8F0;
}

/* ─────────────────────────────────────────────
   CONTAINER
───────────────────────────────────────────── */
.prod-container {
  max-width: 80rem;
  margin: 0 auto;
  padding: 0 clamp(16px, 4vw, 32px);
}

/* ─────────────────────────────────────────────
   HERO
───────────────────────────────────────────── */
.prod-hero {
  position: relative;
  background: #1A1A2E;
  overflow: hidden;
  padding: clamp(64px, 10vw, 100px) 0 clamp(48px, 6vw, 72px);
}

.hero-glow {
  position: absolute;
  inset: 0;
  pointer-events: none;
  background: radial-gradient(ellipse 55% 90% at 105% -15%, rgba(0,153,175,0.18) 0%, transparent 60%);
}

.prod-hero-inner {
  position: relative;
  max-width: 80rem;
  margin: 0 auto;
  padding: 0 clamp(16px, 4vw, 32px);
}

.prod-hero-eyebrow {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  background: rgba(0,153,175,0.12);
  border: 1px solid rgba(0,153,175,0.28);
  color: #0099AF;
  font-size: 0.7rem;
  font-weight: 700;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  padding: 0.3rem 0.9rem;
  border-radius: 4px;
  margin-bottom: 1.25rem;
}

.prod-eyebrow-dot {
  display: inline-block;
  width: 6px;
  height: 6px;
  border-radius: 50%;
  background: #F5A623;
  flex-shrink: 0;
}

.prod-hero-h1 {
  font-family: 'UnisonPro', 'Outfit', sans-serif;
  font-size: clamp(2.5rem, 5.5vw, 4rem);
  font-weight: 800;
  color: white;
  line-height: 1.08;
  letter-spacing: -0.02em;
  margin: 0 0 1.25rem;
}

.prod-hero-gradient {
  background: linear-gradient(90deg, #00C4D4, #0099AF);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.prod-hero-desc {
  font-size: clamp(1rem, 2vw, 1.1rem);
  color: rgba(255,255,255,0.65);
  line-height: 1.7;
  max-width: 540px;
  margin: 0;
}

/* Quick-nav pills */
.prod-quicknav {
  display: flex;
  flex-wrap: wrap;
  gap: 10px;
  margin-top: 2rem;
}

.prod-quickpill {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  padding: 8px 18px;
  border-radius: 6px;
  background: rgba(255,255,255,0.06);
  border: 1px solid rgba(255,255,255,0.12);
  color: rgba(255,255,255,0.82);
  font-size: 13px;
  font-weight: 600;
  text-decoration: none;
  cursor: pointer;
  transition: background 0.18s ease, border-color 0.18s ease;
}

.prod-quickpill:hover {
  background: rgba(0,153,175,0.18);
  border-color: rgba(0,153,175,0.4);
}

.prod-quickpill-num {
  font-size: 10px;
  font-weight: 700;
  color: #F5A623;
  letter-spacing: 0.06em;
}

/* ─────────────────────────────────────────────
   STATS STRIP
───────────────────────────────────────────── */
.prod-stats-strip {
  background: #1A1A2E;
  border-bottom: 1px solid rgba(255,255,255,0.07);
  padding: 0;
}

.prod-stats-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 0;
}

@media (min-width: 640px) {
  .prod-stats-grid { grid-template-columns: repeat(4, 1fr); }
}

.prod-stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4px;
  padding: 28px 16px;
  border-right: 1px solid rgba(255,255,255,0.07);
  text-align: center;
}

.prod-stat-item:last-child { border-right: none; }

@media (max-width: 639px) {
  .prod-stat-item:nth-child(2) { border-right: none; }
  .prod-stat-item:nth-child(3) { border-top: 1px solid rgba(255,255,255,0.07); }
  .prod-stat-item:nth-child(4) { border-top: 1px solid rgba(255,255,255,0.07); }
}

.prod-stat-value {
  font-size: clamp(1.8rem, 3vw, 2.4rem);
  font-weight: 800;
  color: #0099AF;
  line-height: 1;
}

.prod-stat-label {
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 0.06em;
  text-transform: uppercase;
  color: rgba(255,255,255,0.45);
}

/* ─────────────────────────────────────────────
   SECTION HEADER
───────────────────────────────────────────── */
.prod-cats-section {
  background: #F8FAFC;
  padding: clamp(64px, 8vw, 96px) 0;
}

.prod-section-hd {
  margin-bottom: 48px;
}

.prod-eyebrow-text {
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: #0099AF;
  margin: 0 0 10px;
}

.prod-section-h2 {
  font-size: clamp(1.9rem, 3.8vw, 3rem);
  font-weight: 800;
  color: #0F172A;
  margin: 0;
  line-height: 1.1;
}

/* ─────────────────────────────────────────────
   CATEGORY CARDS GRID
───────────────────────────────────────────── */
.prod-cat-grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: 24px;
  align-items: start;
}

@media (min-width: 640px) {
  .prod-cat-grid { grid-template-columns: repeat(2, 1fr); }
}

@media (min-width: 1024px) {
  .prod-cat-grid { grid-template-columns: repeat(2, 1fr); gap: 28px; }
}

/* Card — entire element is <a> */
.prod-cat-card {
  position: relative;
  display: flex;
  flex-direction: column;
  background: #FFFFFF;
  border: 1px solid #E2E8F0;
  border-top: 3px solid var(--cat-accent, #0099AF);
  border-radius: 16px;
  overflow: hidden;
  padding: 32px 28px 24px;
  text-decoration: none;
  color: inherit;
  cursor: pointer;
  transition: box-shadow 0.22s ease, transform 0.18s ease, border-color 0.18s ease;
}

.prod-cat-card:hover {
  box-shadow: 0 16px 40px rgba(0,0,0,0.09);
  transform: translateY(-3px);
  border-left-color: var(--cat-accent, #0099AF);
  border-right-color: var(--cat-accent, #0099AF);
  border-bottom-color: var(--cat-accent, #0099AF);
}

.prod-cat-card:focus-visible {
  outline: 3px solid #0099AF;
  outline-offset: 3px;
}

/* Top accent bar (already done via border-top, this hidden) */
.prod-cat-accent-top { display: none; }

/* Head row: ghost number + icon */
.prod-cat-head {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 20px;
}

.prod-cat-num {
  font-size: clamp(2.2rem, 3.5vw, 2.5rem);
  font-weight: 800;
  line-height: 1;
  color: var(--cat-accent, #0099AF);
  opacity: 0.15;
  letter-spacing: -0.03em;
  user-select: none;
}

.prod-cat-icon {
  width: 52px;
  height: 52px;
  background: color-mix(in srgb, var(--cat-accent, #0099AF) 10%, transparent);
  border: 1px solid color-mix(in srgb, var(--cat-accent, #0099AF) 20%, transparent);
  border-radius: 12px;
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--cat-accent, #0099AF);
  flex-shrink: 0;
}

/* Title block */
.prod-cat-title-wrap {
  margin-bottom: 12px;
}

.prod-cat-title {
  font-size: clamp(1.25rem, 2vw, 1.35rem);
  font-weight: 800;
  color: #0F172A;
  line-height: 1.15;
  margin: 0 0 2px;
}

.prod-cat-subtitle {
  font-size: 13px;
  color: #475569;
  font-weight: 500;
}

/* Count badge */
.prod-cat-count {
  display: inline-block;
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 0.05em;
  text-transform: uppercase;
  color: var(--cat-accent, #0099AF);
  background: color-mix(in srgb, var(--cat-accent, #0099AF) 8%, transparent);
  border: 1px solid color-mix(in srgb, var(--cat-accent, #0099AF) 18%, transparent);
  padding: 3px 10px;
  border-radius: 4px;
  margin-bottom: 16px;
}

/* Description */
.prod-cat-desc {
  font-size: 14px;
  line-height: 1.7;
  color: #475569;
  margin: 0 0 20px;
  flex: 1;
}

/* Tags */
.prod-cat-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 6px;
  margin-bottom: 20px;
}

.prod-cat-tag {
  font-size: 11px;
  font-weight: 600;
  color: #64748b;
  background: #F8FAFC;
  border: 1px solid #E2E8F0;
  padding: 3px 9px;
  border-radius: 4px;
}

/* CTA row */
.prod-cat-cta {
  display: flex;
  align-items: center;
  gap: 6px;
  font-size: 13px;
  font-weight: 700;
  color: var(--cat-accent, #0099AF);
  border-top: 1px solid #E2E8F0;
  padding-top: 16px;
  margin-top: auto;
  transition: gap 0.15s ease;
}

.prod-cat-card:hover .prod-cat-cta { gap: 10px; }

/* ─────────────────────────────────────────────
   CTA SECTION
───────────────────────────────────────────── */
.prod-cta-section {
  background: #1A1A2E;
  border-top: 3px solid #0099AF;
  padding: clamp(40px, 6vw, 64px) 0;
}

.prod-cta-inner {
  display: flex;
  flex-direction: column;
  gap: 2rem;
  align-items: flex-start;
}

@media (min-width: 768px) {
  .prod-cta-inner {
    flex-direction: row;
    align-items: center;
    justify-content: space-between;
  }
}

.prod-cta-eyebrow {
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: rgba(255,255,255,0.5);
  margin: 0 0 8px;
}

.prod-cta-h2 {
  font-size: clamp(1.5rem, 3vw, 2.2rem);
  font-weight: 800;
  color: white;
  margin: 0 0 12px;
  line-height: 1.15;
}

.prod-cta-sub {
  font-size: 14px;
  line-height: 1.75;
  color: rgba(255,255,255,0.65);
  max-width: 480px;
  margin: 0;
}

.prod-cta-text { flex: 1; min-width: 0; }

.prod-cta-actions {
  display: flex;
  flex-direction: column;
  gap: 12px;
  flex-shrink: 0;
}

@media (min-width: 480px) {
  .prod-cta-actions { flex-direction: row; flex-wrap: wrap; }
}

@media (min-width: 768px) {
  .prod-cta-actions { flex-direction: column; }
}

/* Buttons */
.prod-btn-white,
.prod-btn-ghost-white {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  min-height: 44px;
  padding: 11px 26px;
  font-size: 14px;
  font-weight: 700;
  border-radius: 6px;
  text-decoration: none;
  cursor: pointer;
  transition: background 0.18s ease, opacity 0.18s ease, transform 0.15s ease;
  white-space: nowrap;
}

.prod-btn-white {
  background: #FFFFFF;
  color: #1A1A2E;
  border: 1.5px solid #FFFFFF;
}

.prod-btn-white:hover {
  opacity: 0.9;
  transform: translateY(-1px);
}

.prod-btn-ghost-white {

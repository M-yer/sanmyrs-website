---
import ProductLayout from '../../../layouts/ProductLayout.astro';
import ProductCard from '../../../components/ProductCard.astro';
import { products } from '../../../data/products.js';

const category = products['screen-printing'];
const totalProducts = category.subcategories.reduce((a, s) => a + s.products.length, 0);
---

<ProductLayout
  title="Screen Printing Inks & Additives | SANMYRS"
  description="Browse SANMYRS's complete screen printing range: plastisol inks, water-based inks, specialty effect inks, and additives for garment and textile printing. Karachi, Pakistan."
  breadcrumbs={[
    { label: 'Products', href: '/products' },
    { label: 'Screen Printing', href: '/products/screen-printing' },
  ]}
>

  <!-- ── Header ── -->
  <header class="sp-header">
    <div class="sp-header-glow" aria-hidden="true"></div>
    <div class="sp-header-inner">
      <div class="sp-header-left">
        <p class="sp-eyebrow">Screen Printing</p>
        <h1 class="sp-h1 font-unison">Inks &amp; Additives</h1>
        <p class="sp-desc">Plastisol and water-based inks, specialty effects, and additives for garment decorators and textile screen printers.</p>
      </div>
      <div class="sp-header-right">
        <span class="sp-stat-num font-unison">{totalProducts}</span>
        <span class="sp-stat-label">Products</span>
      </div>
    </div>
  </header>

  <!-- ── Pill Nav ── -->
  <div class="sp-nav">
    <div class="sp-nav-inner">
      <div class="sp-pills-scroll">
        {category.subcategories.map((sub, i) => (
          <button class="pill-btn" data-index={String(i)}
            style={`background:${i===0?'#0099AF':'transparent'}; color:${i===0?'white':'#4A4A4A'}; border-color:${i===0?'#0099AF':'#d1d5db'}; cursor:${i===0?'default':'pointer'};`}>
            {sub.name}
            <span class="pill-count">{sub.products.length}</span>
          </button>
        ))}
      </div>
    </div>
  </div>

  <!-- ── Product Grid ── -->
  <div class="sp-body">
    {category.subcategories.map((sub, i) => (
      <div class="subcategory-section" data-index={String(i)} style={i===0?'display:block;':'display:none;'}>
        <div class="product-grid" style="display:grid; gap:20px; align-items:start;">
          {sub.products.map(product => (
            <ProductCard name={product.name} description={product.description}
              slug={product.slug} category="screen-printing" image={product.image}/>
          ))}
        </div>
      </div>
    ))}
  </div>

  <!-- ── CTA ── -->
  <div class="sp-cta">
    <div class="sp-cta-inner">
      <div class="sp-cta-text">
        <h3 class="sp-cta-h3 font-unison">Need a recommendation or sample?</h3>
        <p class="sp-cta-p">Our team can identify the right ink system for your fabric type, press setup, and production requirements.</p>
      </div>
      <div class="sp-cta-btns">
        <a href="/contact" class="sp-btn-primary">Request a Sample</a>
        <a href="https://wa.me/923183755197" target="_blank" rel="noopener noreferrer" class="sp-btn-ghost">WhatsApp Us</a>
      </div>
    </div>
  </div>

</ProductLayout>

<style>
  :root {
    --teal: #0099AF;
    --teal-dk: #007A8A;
    --navy: #1A1A2E;
    --page-bg: #F8FAFC;
    --surface: #FFFFFF;
    --heading: #0F172A;
    --body: #475569;
    --border: #E2E8F0;
  }

  /* HEADER */
  .sp-header {
    position: relative;
    background: #1A1A2E;
    overflow: hidden;
    padding: clamp(40px, 6vw, 64px) 0;
  }

  .sp-header-glow {
    position: absolute;
    inset: 0;
    pointer-events: none;
    background: radial-gradient(ellipse 60% 100% at 110% -10%, rgba(0,153,175,0.16) 0%, transparent 60%);
  }

  .sp-header-inner {
    position: relative;
    max-width: 80rem;
    margin: 0 auto;
    padding: 0 clamp(16px, 4vw, 32px);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
  }

  .sp-header-left { flex: 1; min-width: 0; }

  .sp-eyebrow {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #0099AF;
    margin: 0 0 8px;
  }

  .sp-h1 {
    font-size: clamp(1.6rem, 3.5vw, 2.4rem);
    font-weight: 800;
    color: white;
    margin: 0 0 12px;
    line-height: 1.12;
  }

  .sp-desc {
    color: rgba(255,255,255,0.60);
    font-size: 14px;
    line-height: 1.65;
    margin: 0;
    max-width: 34rem;
  }

  .sp-header-right {
    flex-shrink: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    background: rgba(0,153,175,0.10);
    border: 1px solid rgba(0,153,175,0.22);
    border-radius: 14px;
    padding: 20px 32px;
    text-align: center;
    min-width: 110px;
  }

  .sp-stat-num {
    font-size: clamp(2rem, 3.5vw, 2.8rem);
    font-weight: 800;
    color: #0099AF;
    line-height: 1;
  }

  .sp-stat-label {
    font-size: 11px;
    font-weight: 600;
    color: rgba(255,255,255,0.45);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin-top: 5px;
  }

  /* NAV */
  .sp-nav {
    background: #FFFFFF;
    border-bottom: 1px solid #E2E8F0;
    position: sticky;
    top: 64px;
    z-index: 30;
  }

  .sp-nav-inner {
    max-width: 80rem;
    margin: 0 auto;
    padding: 0 clamp(16px, 4vw, 32px);
  }

  .sp-pills-scroll {
    display: flex;
    flex-wrap: nowrap;
    gap: 6px;
    overflow-x: auto;
    scrollbar-width: none;
    -webkit-overflow-scrolling: touch;
    padding: 10px 0;
  }

  .sp-pills-scroll::-webkit-scrollbar { display: none; }

  .pill-btn {
    flex-shrink: 0;
    display: inline-flex;
    align-items: center;
    gap: 7px;
    padding: 8px 18px;
    border-radius: 8px;
    border: 1px solid;
    font-size: 13px;
    font-weight: 500;
    cursor: pointer;
    transition: background 0.15s, color 0.15s, border-color 0.15s;
    line-height: 1.3;
    white-space: nowrap;
  }

  .pill-count {
    font-size: 11px;
    font-weight: 700;
    opacity: 0.7;
  }

  /* BODY */
  .sp-body {
    background: #F8FAFC;
    padding: clamp(28px, 4vw, 48px) clamp(16px, 4vw, 32px);
  }

  .subcategory-section {
    max-width: 80rem;
    margin: 0 auto;
  }

  .product-grid { grid-template-columns: repeat(1, minmax(0, 1fr)); }

  @media (min-width: 640px) {
    .product-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }
  }

  @media (min-width: 1024px) {
    .product-grid { grid-template-columns: repeat(4, minmax(0, 1fr)); }
  }

  /* CTA */
  .sp-cta {
    background: #1A1A2E;
    border-top: 3px solid #0099AF;
    padding: clamp(36px, 5vw, 56px) 0;
  }

  .sp-cta-inner {
    max-width: 80rem;
    margin: 0 auto;
    padding: 0 clamp(16px, 4vw, 32px);
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
  }

  .sp-cta-text { flex: 1; min-width: 0; }

  .sp-cta-h3 {
    font-size: clamp(1rem, 2vw, 1.25rem);
    font-weight: 800;
    color: white;
    margin: 0 0 8px;
  }

  .sp-cta-p {
    color: rgba(255,255,255,0.60);
    font-size: 14px;
    line-height: 1.65;
    margin: 0;
  }

  .sp-cta-btns {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    flex-shrink: 0;
  }

  .sp-btn-primary,
  .sp-btn-ghost {
    display: inline-flex;
    align-items: center;
    min-height: 44px;
    padding: 10px 24px;
    font-size: 14px;
    font-weight: 700;
    border-radius: 6px;
    text-decoration: none;
    cursor: pointer;
    transition: background 0.18s, border-color 0.18s;
    white-space: nowrap;
  }

  .sp-btn-primary {
    background: #0099AF;
    color: white;
    border: 1.5px solid #0099AF;
  }

  .sp-btn-primary:hover {
    background: #007A8A;
    border-color: #007A8A;
  }

  .sp-btn-ghost {
    background: rgba(255,255,255,0.08);
    color: white;
    border: 1.5px solid rgba(255,255,255,0.18);
  }

  .sp-btn-ghost:hover { background: rgba(255,255,255,0.15); }
</style>

<script is:inline>
  document.addEventListener('DOMContentLoaded', function () {
    var pills = document.querySelectorAll('.pill-btn');
    var sections = document.querySelectorAll('.subcategory-section');
    if (!pills.length) return;
    pills.forEach(function (pill) {
      pill.addEventListener('click', function () {
        var idx = this.getAttribute('data-index');
        pills.forEach(function (p) {
          p.style.background='transparent'; p.style.color='#4A4A4A'; p.style.borderColor='#d1d5db'; p.style.cursor='pointer';
        });
        this.style.background='#0099AF'; this.style.color='white';
        this.style.borderColor='#0099AF'; this.style.cursor='default';
        sections.forEach(function (s) { s.style.display='none'; });
        var t = document.querySelector('.subcategory-section[data-index="'+idx+'"]');
        if (t) t.style.display='block';
      });
    });
  });
</script>

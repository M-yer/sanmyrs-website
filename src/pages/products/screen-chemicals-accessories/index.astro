---
import ProductLayout from '../../../layouts/ProductLayout.astro';
import ProductCard from '../../../components/ProductCard.astro';
import { products } from '../../../data/products.js';

const category = products['screen-chemicals-accessories'];
const totalProducts = category.subcategories.reduce((a, s) => a + s.products.length, 0);
---

<ProductLayout
  title="Chemicals & Accessories | SANMYRS"
  description="Essential screen making chemicals, emulsions, mesh, and squeegees for professional screen printing prepress and production. Karachi, Pakistan."
  breadcrumbs={[
    { label: 'Products', href: '/products' },
    { label: 'Chemicals & Accessories', href: '/products/screen-chemicals-accessories' },
  ]}
>

  <!-- ── NEOMINIMALIST HEADER ── -->
  <header class="relative pt-16 pb-10 lg:pt-20 lg:pb-12 bg-white border-b border-gray-100 overflow-hidden">
    <div class="absolute inset-0 z-0">
      <div class="absolute -top-40 -right-40 w-[600px] h-[600px] bg-[#0099AF] rounded-full blur-[150px] opacity-10 pointer-events-none"></div>
    </div>

    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10 flex flex-col md:flex-row md:items-end gap-8">
      <div class="flex-1" data-aos="fade-right">
        <div class="inline-flex items-center gap-2 mb-4">
          <span class="w-8 h-[2px] bg-[#0099AF]"></span>
          <span class="text-xs font-bold uppercase tracking-widest text-[#0099AF]">Category</span>
        </div>
        <h1 class="text-5xl lg:text-7xl font-extrabold text-[#1A1A2E] tracking-tight leading-[1.05] font-unison mb-6">
          Chemicals <br/>
          <span class="text-gray-400">&amp; Accessories</span>
        </h1>
        <p class="text-lg text-gray-500 max-w-2xl leading-relaxed">
          Essential screen making chemicals, emulsions, mesh, and squeegees for professional screen printing prepress and production.
        </p>
      </div>
      
      <div class="shrink-0 flex items-center gap-4 bg-white p-6 rounded-2xl border border-gray-100 shadow-sm" data-aos="fade-left" data-aos-delay="100">
        <div class="text-4xl font-black text-[#1A1A2E] font-unison">{totalProducts}</div>
        <div class="text-xs font-bold uppercase tracking-widest text-gray-400 leading-tight">Total<br/>Products</div>
      </div>
    </div>
  </header>

  <!-- ── MINIMALIST TAB NAVIGATION ── -->
  <div class="sticky top-0 z-40 bg-white/80 backdrop-blur-md border-b border-gray-200 shadow-sm">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex flex-nowrap gap-8 overflow-x-auto scrollbar-hide py-4">
        {category.subcategories.map((sub, i) => (
          <button 
            class={`tab-btn relative shrink-0 text-sm font-bold uppercase tracking-wider transition-colors pb-1 ${i === 0 ? 'text-[#1A1A2E]' : 'text-gray-400 hover:text-[#0099AF]'}`}
            data-index={String(i)}
          >
            {sub.name} <span class="ml-1 text-xs opacity-60">({sub.products.length})</span>
            <span class={`tab-indicator absolute bottom-[-17px] left-0 w-full h-[2px] bg-[#0099AF] transition-opacity ${i === 0 ? 'opacity-100' : 'opacity-0'}`}></span>
          </button>
        ))}
      </div>
    </div>
  </div>

  <!-- ── PRODUCT GRID ── -->
  <div class="bg-white py-16 lg:py-24 min-h-[50vh]">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      {category.subcategories.map((sub, i) => (
        <div class="subcategory-section animate-fade-in" data-index={String(i)} style={i===0?'display:block;':'display:none;'}>
          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6 lg:gap-8">
            {sub.products.map((product, pi) => (
              <div data-aos="fade-up" data-aos-delay={String((pi % 4) * 75)}>
                <ProductCard
                  name={product.name}
                  description={product.description}
                  slug={product.slug}
                  category="screen-chemicals-accessories"
                  image={product.image}
                  accentColor="#EC008C"
                />
              </div>
            ))}
          </div>
        </div>
      ))}
    </div>
  </div>

</ProductLayout>

<style>
.scrollbar-hide::-webkit-scrollbar { display: none; }
.scrollbar-hide { -ms-overflow-style: none; scrollbar-width: none; }
@keyframes fadeIn {
  from { opacity: 0; transform: translateY(10px); }
  to { opacity: 1; transform: translateY(0); }
}
.animate-fade-in { animation: fadeIn 0.4s ease-out forwards; }
</style>

<script is:inline src="/js/pill-nav.js"></script>

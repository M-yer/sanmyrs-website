---
import ProductLayout from '../../../layouts/ProductLayout.astro';
import { products } from '../../../data/products.js';

export async function getStaticPaths() {
  const category = products['screen-chemicals-accessories'];
  const paths = [];
  for (const sub of category.subcategories) {
    for (const product of sub.products) {
      paths.push({
        params: { slug: product.slug },
        props: { product: { ...product, subcategory: sub.name } },
      });
    }
  }
  return paths;
}

const { product } = Astro.props;
const categorySlug = 'screen-chemicals-accessories';
const categoryLabel = 'Screen Chemicals & Accessories';

// Related products (same subcategory, max 3, excluding current)
const relatedProducts = [];
for (const sub of products[categorySlug].subcategories) {
  if (sub.name === product.subcategory) {
    for (const p of sub.products) {
      if (p.slug !== product.slug && relatedProducts.length < 3) {
        relatedProducts.push(p);
      }
    }
  }
}

const schema = {
  "@context": "https://schema.org",
  "@type": "Product",
  "name": product.name,
  "description": product.description,
  "brand": { "@type": "Brand", "name": "SANMYRS" },
  "offers": {
    "@type": "Offer",
    "availability": "https://schema.org/InStock",
    "priceCurrency": "PKR",
    "seller": { "@type": "Organization", "name": "SANMYRS" }
  }
};
---

<ProductLayout
  title={product.metaTitle || `${product.name} | SANMYRS`}
  description={product.metaDescription || product.description.split('.')[0] + '.'}
  schema={schema}
  breadcrumbs={[
    { label: 'Products', href: '/products' },
    { label: categoryLabel, href: `/products/${categorySlug}` },
    { label: product.name, href: `/products/${categorySlug}/${product.slug}` },
  ]}
>
  <!-- ── Product Header ── -->
  <header class="pd-header">
    <div class="pd-header-dots" aria-hidden="true">
      <svg width="100%" height="100%" xmlns="http://www.w3.org/2000/svg">
        <defs><pattern id="pdh" width="32" height="32" patternUnits="userSpaceOnUse">
          <circle cx="1" cy="1" r="1" fill="rgba(0,153,175,0.18)"/>
        </pattern></defs>
        <rect width="100%" height="100%" fill="url(#pdh)"/>
      </svg>
    </div>
    <div class="pd-header-inner">
      <span class="pd-sub-badge">{product.subcategory}</span>
      <h1 class="pd-h1 font-unison">{product.name}</h1>
      <p class="pd-hdesc">{product.description.split('.')[0]}.</p>
    </div>
  </header>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-10">

      <!-- Main Content -->
      <div class="lg:col-span-2">
        <!-- Product Header -->
        {product.image ? (
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-6">
            <div style="background:#F5F7F6; border-radius:16px; display:flex; align-items:center; justify-content:center; padding:24px; min-height:280px;">
              <img
                src={product.image}
                alt={product.name}
                style="max-width:100%; max-height:320px; object-fit:contain; border-radius:8px; display:block;"
              />
            </div>
            <div class="bg-white rounded-2xl border border-gray-200 p-8 flex flex-col justify-center">
              <span class="inline-block text-xs font-semibold text-primary bg-primary/10 px-3 py-1 rounded-full mb-4">
                {product.subcategory}
              </span>
              <h1 class="text-3xl font-extrabold text-primary mb-6 font-unison">{product.name}</h1>
              <p class="text-body-text leading-relaxed text-base">{product.description}</p>
            </div>
          </div>
        ) : (
          <div class="bg-white rounded-2xl border border-gray-200 p-8 mb-6">
            <span class="inline-block text-xs font-semibold text-primary bg-primary/10 px-3 py-1 rounded-full mb-4">
              {product.subcategory}
            </span>
            <h1 class="text-3xl font-extrabold text-primary mb-6 font-unison">{product.name}</h1>
            <p class="text-body-text leading-relaxed text-base">{product.description}</p>
          </div>
        )}

        <!-- Applications -->
        <div class="bg-white rounded-2xl border border-gray-200 p-8 mb-6">
          <h2 class="text-xl font-bold text-primary mb-6 flex items-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2" />
            </svg>
            Key Applications
          </h2>
          <ul class="space-y-3">
            {product.uses.map((use: string) => (
              <li class="flex items-start gap-3">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-primary flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
                <span class="text-body-text text-sm">{use}</span>
              </li>
            ))}
          </ul>
        </div>

        <!-- Why SANMYRS -->
        <div class="bg-navy rounded-2xl p-8 text-white">
          <h2 class="text-lg font-bold mb-4">Why Order From SANMYRS?</h2>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            {[
              'Consistent batch-to-batch quality',
              'Technical support and guidance',
              'Fast dispatch from Karachi stock',
              'Competitive pricing for all order sizes',
            ].map(text => (
              <div class="flex items-center gap-2 text-sm text-gray-200">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-primary flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg>
                {text}
              </div>
            ))}
          </div>
        </div>
      </div>

      <!-- Sidebar -->
      <div class="lg:col-span-1 space-y-6">
        <div class="bg-white rounded-2xl border border-gray-200 p-7 sticky top-24">
          <h3 class="text-lg font-bold text-primary mb-2">Inquire About This Product</h3>
          <p class="text-body-text text-sm mb-6">
            Contact our team to request pricing, availability, a technical data sheet, or a sample of {product.name}.
          </p>

          <a
            href={`/contact?product=${encodeURIComponent(product.name)}`}
            class="block w-full text-center px-6 py-3 bg-primary text-white font-semibold rounded-xl hover:bg-primary-dark transition-colors duration-200 cursor-pointer mb-3"
          >
            Send an Inquiry
          </a>

          <a
            href={`https://wa.me/923183755197?text=${encodeURIComponent('Hi SANMYRS, I am interested in ' + product.name + '. Please share pricing and availability.')}`}
            target="_blank"
            rel="noopener noreferrer"
            class="flex items-center justify-center gap-2 w-full px-6 py-3 border border-gray-200 text-primary font-medium rounded-xl hover:bg-page-bg transition-colors duration-200 cursor-pointer text-sm"
          >
            <svg viewBox="0 0 24 24" fill="currentColor" class="w-5 h-5 text-[#25D366]">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
            </svg>
            WhatsApp Direct
          </a>

          <div class="mt-5 pt-5 border-t border-gray-100 text-center">
            <p class="text-xs text-gray-400">
              Based in Karachi, Pakistan<br/>
              F-126, Lucknow Society, Korangi
            </p>
          </div>
        </div>
      </div>
    </div>

    <!-- Related Products -->
    {relatedProducts.length > 0 && (
      <div class="mt-14">
        <h2 class="text-2xl font-bold text-primary mb-6 font-unison">Related Products</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
          {relatedProducts.map((p: any) => (
            <a href={`/products/${categorySlug}/${p.slug}`} class="bg-white rounded-xl border border-gray-200 p-6 hover:shadow-md hover:border-primary transition-all duration-200 block no-underline">
              <h3 class="font-semibold text-primary mb-2">{p.name}</h3>
              <p class="text-body-text text-sm mb-4">{p.description.split('.')[0]}.</p>
              <span class="text-primary font-medium text-sm hover:text-primary-dark transition-colors duration-150 inline-flex items-center gap-1">
                View Details
                <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                </svg>
              </span>
            </a>
          ))}
        </div>
      </div>
    )}
  </div>
</ProductLayout>

<style>
  .pd-header { position:relative; background:#1A1A2E; overflow:hidden; padding:clamp(32px,5vw,52px) 0; }
  .pd-header-dots { position:absolute; inset:0; pointer-events:none; }
  .pd-header-inner { position:relative; max-width:80rem; margin:0 auto; padding:0 clamp(16px,4vw,32px); }
  .pd-sub-badge { display:inline-flex; align-items:center; font-size:11px; font-weight:700; letter-spacing:.1em; text-transform:uppercase; color:#0099AF; background:rgba(0,153,175,0.12); border:1px solid rgba(0,153,175,0.25); padding:5px 14px; border-radius:100px; margin-bottom:12px; }
  .pd-h1 { font-size:clamp(1.5rem,3.5vw,2.6rem); font-weight:800; color:white; margin:0 0 12px; line-height:1.1; letter-spacing:-0.01em; }
  .pd-hdesc { color:rgba(255,255,255,0.6); font-size:14px; line-height:1.7; margin:0; max-width:42rem; }
</style>

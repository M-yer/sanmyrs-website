---
import ProductLayout from '../../../layouts/ProductLayout.astro';
import { products } from '../../../data/products.js';

export async function getStaticPaths() {
  const category = products['digital-printing'];
  const paths = [];
  for (const sub of category.subcategories) {
    for (const product of sub.products) {
      paths.push({
        params: { slug: product.slug },
        props: { product: { ...product, subcategory: sub.name } },
      });
    }
  }
  return paths;
}

const { product } = Astro.props;
const categorySlug = 'digital-printing';
const categoryLabel = 'Digital Printing';

const relatedProducts = [];
for (const sub of products[categorySlug].subcategories) {
  if (sub.name === product.subcategory) {
    for (const p of sub.products) {
      if (p.slug !== product.slug && relatedProducts.length < 3) {
        relatedProducts.push(p);
      }
    }
  }
}

const schema = {
  "@context": "https://schema.org",
  "@type": "Product",
  "name": product.name,
  "description": product.description,
  "brand": { "@type": "Brand", "name": "SANMYRS" },
  "offers": {
    "@type": "Offer",
    "availability": "https://schema.org/InStock",
    "priceCurrency": "PKR",
    "seller": { "@type": "Organization", "name": "SANMYRS" }
  }
};
---

<ProductLayout
  title={product.metaTitle || `${product.name} | SANMYRS`}
  description={product.metaDescription || product.description.split('.')[0] + '.'}
  schema={schema}
  breadcrumbs={[
    { label: 'Products', href: '/products' },
    { label: categoryLabel, href: `/products/${categorySlug}` },
    { label: product.name, href: `/products/${categorySlug}/${product.slug}` },
  ]}
>

  <!-- ── SPLIT LAYOUT PRODUCT HERO ── -->
  <div class="bg-white pt-12 pb-16 lg:pt-20 lg:pb-24 overflow-hidden relative border-b border-gray-100">
    <div class="absolute inset-0 z-0 pointer-events-none">
      <div class="absolute top-0 right-0 w-[50vh] h-[50vh] bg-[#0099AF] rounded-full blur-[100px] opacity-10 translate-x-1/2 -translate-y-1/2"></div>
    </div>

    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20 items-start">
        
        <!-- LEFT: Img / Carousel -->
        <div class="lg:sticky lg:top-32 w-full rounded-3xl bg-white border border-gray-100 p-8 sm:p-12 flex flex-col items-center justify-center min-h-[400px] lg:min-h-[500px]">
          {product.images && product.images.length > 0 ? (
            <div id="carousel-wrap" data-variants={JSON.stringify(product.images)} style="width:100%;">
              <div style="position:relative; display:flex; align-items:center; gap:8px; min-height:400px;">
                <button id="carousel-prev" class="shrink-0 bg-white border border-gray-200 rounded-full w-10 h-10 flex items-center justify-center text-xl text-navy hover:text-primary transition-colors cursor-pointer shadow-sm hover:shadow-md">&#8249;</button>
                <div style="flex:1; text-align:center;">
                  <div id="zoom-container" style="position:relative; display:inline-block; cursor:crosshair;">
                    <img id="carousel-main" src={product.images[0].src} alt={product.name} style="max-height:400px; max-width:100%; object-fit:contain; display:block; margin:0 auto; user-select:none; mix-blend-mode:multiply;" />
                    <div id="zoom-lens" style="position:absolute; width:150px; height:150px; border-radius:50%; border:2px solid rgba(0,153,175,0.7); background-repeat:no-repeat; pointer-events:none; display:none; box-shadow:0 0 0 3px rgba(0,153,175,0.15), 0 6px 24px rgba(0,0,0,0.22); z-index:10; background-color:white;"></div>
                  </div>
                  <p id="carousel-label" class="mt-4 text-xs font-bold text-gray-500 uppercase tracking-widest">{product.images[0].label}</p>
                </div>
                <button id="carousel-next" class="shrink-0 bg-white border border-gray-200 rounded-full w-10 h-10 flex items-center justify-center text-xl text-navy hover:text-primary transition-colors cursor-pointer shadow-sm hover:shadow-md">&#8250;</button>
              </div>
              <div style="display:flex; gap:8px; overflow-x:auto; scrollbar-width:none; justify-content:center; flex-wrap:wrap; margin-top:24px;">
                {product.images.map((img:any, idx:number) => (
                  <button class="carousel-thumb relative w-14 h-14 bg-white border border-gray-200 rounded-xl flex border-2 items-center justify-center cursor-pointer transition-all hover:border-[#0099AF]" data-idx={String(idx)} title={img.label}>
                    <img src={img.src} alt={img.label} style="max-width:40px; max-height:40px; object-fit:contain; mix-blend-mode:multiply;" />
                  </button>
                ))}
              </div>
            </div>
          ) : product.image ? (
            <img src={product.image} alt={product.name} class="w-full max-h-[400px] object-contain drop-shadow-sm mix-blend-multiply" />
          ) : (
            <div class="text-gray-400 font-medium tracking-wide">Image Not Available</div>
          )}
        </div>

        <!-- RIGHT: Product Details -->
        <div class="flex flex-col justify-center lg:py-4">
          <div class="mb-10 animate-fade-in" style="animation-duration:0.5s;">
            <span class="inline-flex items-center gap-2 mb-4">
              <span class="w-8 h-[2px] bg-[#0099AF]"></span>
              <span class="text-xs font-bold uppercase tracking-widest text-[#0099AF]">{product.subcategory}</span>
            </span>
            <h1 class="text-4xl sm:text-5xl lg:text-5xl font-extrabold text-[#1A1A2E] tracking-tight leading-[1.05] font-unison mb-6">
              {product.name}
            </h1>
            <p class="text-lg text-gray-500 leading-relaxed">
              {product.description}
            </p>
          </div>

          <!-- USES Grid -->
          {product.uses && product.uses.length > 0 && (
            <div class="mb-10 animate-fade-in" style="animation-duration:0.7s;">
              <h3 class="text-sm font-bold text-[#1A1A2E] uppercase tracking-wider mb-5">Key Applications</h3>
              <ul class="grid grid-cols-1 sm:grid-cols-2 gap-y-4 gap-x-6">
                {product.uses.map((use:string) => (
                  <li class="flex items-start gap-3">
                    <svg class="w-5 h-5 text-[#0099AF] shrink-0 mt-0.5 opacity-80" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg>
                    <span class="text-sm text-gray-600 font-medium leading-relaxed">{use}</span>
                  </li>
                ))}
              </ul>
            </div>
          )}

          <!-- Inquiry CTAs -->
          <div class="flex flex-col sm:flex-row gap-4 mb-10 animate-fade-in" style="animation-duration:0.8s;">
            <a href={`/contact?product=${encodeURIComponent(product.name)}`} class="flex-1 flex justify-center items-center px-6 py-4 bg-[#1A1A2E] text-white font-bold rounded-xl hover:bg-[#2A2A4A] transition-all shadow-[0_8px_30px_rgb(26,26,46,0.15)] hover:shadow-[0_8px_30px_rgb(26,26,46,0.25)] hover:-translate-y-0.5 text-sm tracking-wide">
              Request Info & Pricing
            </a>
            <a href={`https://wa.me/923183755197?text=${encodeURIComponent('Hi SANMYRS, I am interested in ' + product.name + '. Please share pricing and availability.')}`} target="_blank" rel="noopener noreferrer" class="flex-1 flex justify-center items-center gap-2 px-6 py-4 bg-white border border-gray-200 text-[#1A1A2E] font-bold rounded-xl hover:border-[#25D366] hover:text-[#25D366] transition-all hover:bg-[#25D366]/5 text-sm tracking-wide">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-5 h-5 text-[#25D366]">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
              </svg>
              Direct Chat
            </a>
          </div>

          <!-- Trust Badges -->
          <div class="px-5 py-4 bg-white rounded-xl border border-gray-100 animate-fade-in" style="animation-duration:0.9s;">
             <div class="flex flex-wrap gap-x-6 gap-y-3 justify-between items-center text-xs font-bold text-gray-500 uppercase tracking-wide">
               <span class="flex items-center gap-1.5"><svg class="w-4 h-4 text-[#0099AF]" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" /></svg> Quality Verified</span>
               <span class="flex items-center gap-1.5"><svg class="w-4 h-4 text-[#0099AF]" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" /></svg> Fast Dispatch</span>
               <span class="flex items-center gap-1.5"><svg class="w-4 h-4 text-[#0099AF]" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M13 10V3L4 14h7v7l9-11h-7z" /></svg> Expert Tech Support</span>
             </div>
          </div>
        </div>

      </div>
    </div>
  </div>

  <!-- ── RELATED PRODUCTS ── -->
  {relatedProducts.length > 0 && (
    <div class="bg-white py-16 lg:py-24">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <h2 class="font-unison text-3xl font-bold text-[#1A1A2E] mb-10 text-center lg:text-left">Frequently Bought Together</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
          {relatedProducts.map((p: any) => (
            <a href={`/products/${categorySlug}/${p.slug}`} class="block bg-white rounded-2xl border border-gray-100 p-8 hover:shadow-xl hover:shadow-gray-200/50 hover:border-[#0099AF]/30 transition-all duration-300 cursor-pointer no-underline group hover:-translate-y-1">
              <span class="inline-block text-[10px] font-bold tracking-widest uppercase text-gray-400 mb-2">{categoryLabel}</span>
              <h3 class="font-bold text-lg text-[#1A1A2E] mb-3 group-hover:text-[#0099AF] transition-colors">{p.name}</h3>
              <p class="text-gray-500 text-sm leading-relaxed">{p.description.split('.')[0]}.</p>
            </a>
          ))}
        </div>
      </div>
    </div>
  )}

  <style>
    @keyframes fadeIn {
      from { opacity: 0; transform: translateY(10px); }
      to { opacity: 1; transform: translateY(0); }
    }
    .animate-fade-in { animation: fadeIn 0.4s ease-out forwards; }
  </style>

</ProductLayout>

<script is:inline>
  document.addEventListener('DOMContentLoaded', function () {
    var wrap = document.getElementById('carousel-wrap');
    if (!wrap) return;
    var images;
    try { images = JSON.parse(wrap.getAttribute('data-variants') || '[]'); } catch (e) { return; }
    if (!images.length) return;

    var mainImg = document.getElementById('carousel-main');
    var labelEl = document.getElementById('carousel-label');
    var thumbs = document.querySelectorAll('.carousel-thumb');
    var current = 0;

    var params = new URLSearchParams(window.location.search);
    var variant = params.get('variant');
    if (variant) {
      var fromParam = images.findIndex(function (v) { return v.label === variant; });
      if (fromParam >= 0) current = fromParam;
    }

    function goTo(idx) {
      current = ((idx % images.length) + images.length) % images.length;
      if (mainImg) mainImg.src = images[current].src;
      if (labelEl) labelEl.textContent = images[current].label;
      thumbs.forEach(function (t, i) {
        if(i === current) {
          t.style.borderColor = '#0099AF';
        } else {
          t.style.borderColor = '#e5e7eb';
        }
      });
    }

    goTo(current);

    var prevBtn = document.getElementById('carousel-prev');
    var nextBtn = document.getElementById('carousel-next');
    if (prevBtn) prevBtn.addEventListener('click', function () { goTo(current - 1); });
    if (nextBtn) nextBtn.addEventListener('click', function () { goTo(current + 1); });
    thumbs.forEach(function (t) {
      t.addEventListener('click', function () { goTo(parseInt(this.getAttribute('data-idx'))); });
    });

    // Magnifier lens
    var zoomContainer = document.getElementById('zoom-container');
    var lens = document.getElementById('zoom-lens');
    if (zoomContainer && lens && mainImg) {
      var Z = 2.5;
      function updateLens(e) {
        var iRect = mainImg.getBoundingClientRect();
        var cRect = zoomContainer.getBoundingClientRect();
        var x = e.clientX - iRect.left;
        var y = e.clientY - iRect.top;
        x = Math.max(0, Math.min(x, iRect.width));
        y = Math.max(0, Math.min(y, iRect.height));
        var lw = lens.offsetWidth, lh = lens.offsetHeight;
        lens.style.left = ((x - lw / 2) + (iRect.left - cRect.left)) + 'px';
        lens.style.top  = ((y - lh / 2) + (iRect.top  - cRect.top))  + 'px';
        lens.style.backgroundImage    = 'url("' + mainImg.src + '")';
        lens.style.backgroundSize     = (iRect.width * Z) + 'px ' + (iRect.height * Z) + 'px';
        lens.style.backgroundPosition = (-(x * Z - lw / 2)) + 'px ' + (-(y * Z - lh / 2)) + 'px';
      }
      zoomContainer.addEventListener('mouseenter', function () { lens.style.display = 'block'; });
      zoomContainer.addEventListener('mouseleave', function () { lens.style.display = 'none'; });
      zoomContainer.addEventListener('mousemove', updateLens);
    }
  });
</script>

---
import ProductLayout from '../../../layouts/ProductLayout.astro';
import { products } from '../../../data/products.js';

const category = products['digital-printing'];
const totalProducts = category.subcategories.reduce((a, s) => a + s.products.length, 0);
---

<ProductLayout
  title="Digital Printing Inks | SANMYRS"
  description="Reactive, disperse, sublimation, acid, pigment, eco solvent, UV, and latex inks for digital textile and graphic printing. SANMYRS, Karachi, Pakistan."
  breadcrumbs={[
    { label: 'Products', href: '/products' },
    { label: 'Digital Printing', href: '/products/digital-printing' },
  ]}
>
  <!-- Header -->
  <div style="background:#7A2A37; padding:clamp(32px,6vw,56px) 0;">
    <div style="max-width:80rem; margin:0 auto; padding:0 24px;">
      <div style="display:flex; flex-wrap:wrap; align-items:center; justify-content:space-between; gap:16px;">
        <div>
          <h1 class="font-glancyr" style="font-size:clamp(1.75rem,5vw,2.25rem); font-weight:800; color:#F5A623; margin:0 0 8px 0;">Digital Printing</h1>
          <p style="color:#d1d5db; max-width:36rem; margin:0;">
            High-performance inks for textile digital printing systems and wide-format graphic inkjet printers, covering all major dye and ink chemistries.
          </p>
        </div>
        <span style="background:rgba(0,153,175,0.2); color:#0099AF; font-size:13px; font-weight:600; padding:6px 16px; border-radius:999px; border:1px solid rgba(0,153,175,0.3); white-space:nowrap;">
          {totalProducts} Products
        </span>
      </div>
    </div>
  </div>

  <!-- Sticky Nav -->
  <div style="background:white; border-bottom:1px solid #e5e7eb; position:sticky; top:64px; z-index:30;">
    <div style="max-width:80rem; margin:0 auto; padding:12px 24px 0;">

      <!-- Level 1: Main category pills -->
      <div style="display:flex; flex-wrap:nowrap; gap:8px; overflow-x:auto; scrollbar-width:none; padding-bottom:12px;">
        {category.subcategories.map((sub, i) => (
          <button
            class="main-pill"
            data-cat={String(i)}
            style={`flex-shrink:0; padding:6px 16px; border-radius:999px; border:1px solid; font-size:13px; font-weight:500; cursor:pointer; transition:background 0.15s, color 0.15s, border-color 0.15s; background:${i === 0 ? '#0099AF' : 'white'}; color:${i === 0 ? 'white' : '#1A1A2E'}; border-color:${i === 0 ? '#0099AF' : '#e5e7eb'};`}
          >
            {sub.name} ({sub.products.length})
          </button>
        ))}
      </div>

      <!-- Level 2: Sub-pills per main category -->
      {category.subcategories.map((sub, i) => (
        <div
          class="sub-pill-bar"
          data-cat={String(i)}
          style={`display:${i === 0 ? 'flex' : 'none'}; flex-wrap:nowrap; gap:8px; overflow-x:auto; scrollbar-width:none; padding-bottom:12px; border-top:1px solid #f3f4f6;`}
        >
          {sub.products.map((product, j) => (
            <button
              class="sub-pill"
              data-cat={String(i)}
              data-prod={String(j)}
              style={`flex-shrink:0; margin-top:10px; padding:5px 14px; border-radius:999px; border:1px solid; font-size:12px; font-weight:500; cursor:pointer; transition:background 0.15s, color 0.15s, border-color 0.15s; background:${j === 0 ? '#0099AF' : 'white'}; color:${j === 0 ? 'white' : '#4A4A4A'}; border-color:${j === 0 ? '#0099AF' : '#e5e7eb'};`}
            >
              {product.name}
            </button>
          ))}
        </div>
      ))}

    </div>
  </div>

  <!-- Product Sections -->
  <div style="max-width:80rem; margin:0 auto; padding:48px 24px;">
    {category.subcategories.map((sub, i) => (
      <div class="cat-section" data-cat={String(i)} style={i === 0 ? 'display:block;' : 'display:none;'}>
        {sub.products.map((product, j) => (
          <div class="prod-item" data-cat={String(i)} data-prod={String(j)} style={j === 0 ? 'display:block;' : 'display:none;'}>

            <!-- Product Header -->
            <div style="display:flex; flex-wrap:wrap; align-items:center; justify-content:space-between; gap:12px; margin-bottom:28px;">
              <div>
                <h2 class="font-glancyr" style="font-size:1.4rem; font-weight:700; color:#1A1A2E; margin:0 0 4px 0;">{product.name}</h2>
                <p style="color:#6b7280; font-size:13px; margin:0;">{product.images ? product.images.length : 1} variants available</p>
              </div>
              <a href={`/products/digital-printing/${product.slug}`} style="padding:8px 20px; background:#0099AF; color:white; font-weight:600; border-radius:10px; text-decoration:none; font-size:13px; white-space:nowrap;">
                View Details →
              </a>
            </div>

            <!-- Color Image Grid -->
            {product.images ? (
              <div class="color-grid">
                {product.images.map(img => (
                  <a href={`/products/digital-printing/${product.slug}`} style="display:block; text-decoration:none; background:white; border-radius:12px; border:1px solid #e5e7eb; padding:16px 12px; text-align:center; transition:box-shadow 0.15s, transform 0.15s; cursor:pointer;" onmouseover="this.style.boxShadow='0 4px 16px rgba(0,0,0,0.1)';this.style.transform='translateY(-2px)'" onmouseout="this.style.boxShadow='none';this.style.transform='translateY(0)'">
                    <img
                      src={img.src}
                      alt={`${product.name} — ${img.label}`}
                      loading="lazy"
                      style="max-height:140px; width:auto; max-width:100%; object-fit:contain; display:block; margin:0 auto 10px;"
                    />
                    <p style="font-size:11px; font-weight:600; color:#4A4A4A; margin:0; text-transform:uppercase; letter-spacing:0.03em;">{img.label}</p>
                  </a>
                ))}
              </div>
            ) : (
              <div style="text-align:center; padding:48px; color:#9ca3af;">No images available</div>
            )}

          </div>
        ))}
      </div>
    ))}
  </div>

  <!-- CTA -->
  <div style="background:white; border-top:1px solid #e5e7eb; padding:48px 0;">
    <div style="max-width:48rem; margin:0 auto; padding:0 24px; text-align:center;">
      <h3 style="font-size:1.125rem; font-weight:700; color:#1A1A2E; margin:0 0 12px 0;">Unsure which ink suits your printer?</h3>
      <p style="color:#4A4A4A; margin:0 0 24px 0;">Tell us your printer model and substrate — we'll recommend the correct ink chemistry and provide technical data sheets.</p>
      <div style="display:flex; flex-wrap:wrap; gap:12px; justify-content:center;">
        <a href="/contact" style="padding:10px 24px; background:#0099AF; color:white; font-weight:600; border-radius:12px; text-decoration:none; font-size:14px;">Get a Recommendation</a>
        <a href="https://wa.me/923183755197" target="_blank" rel="noopener noreferrer" style="padding:10px 24px; border:1px solid #0099AF; color:#0099AF; font-weight:600; border-radius:12px; text-decoration:none; font-size:14px;">WhatsApp Us</a>
      </div>
    </div>
  </div>
</ProductLayout>

<style>
  .color-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 16px;
  }
  @media (min-width: 480px)  { .color-grid { grid-template-columns: repeat(3, minmax(0, 1fr)); } }
  @media (min-width: 640px)  { .color-grid { grid-template-columns: repeat(4, minmax(0, 1fr)); } }
  @media (min-width: 1024px) { .color-grid { grid-template-columns: repeat(6, minmax(0, 1fr)); } }
  div::-webkit-scrollbar { display: none; }
</style>

<script is:inline>
  document.addEventListener('DOMContentLoaded', function () {
    var mainPills = document.querySelectorAll('.main-pill');
    var subPillBars = document.querySelectorAll('.sub-pill-bar');
    var catSections = document.querySelectorAll('.cat-section');

    function activateMainPill(catIdx) {
      mainPills.forEach(function (p) {
        p.style.background = 'white'; p.style.color = '#1A1A2E'; p.style.borderColor = '#e5e7eb';
      });
      var active = document.querySelector('.main-pill[data-cat="' + catIdx + '"]');
      if (active) { active.style.background = '#0099AF'; active.style.color = 'white'; active.style.borderColor = '#0099AF'; }

      subPillBars.forEach(function (bar) { bar.style.display = 'none'; });
      var bar = document.querySelector('.sub-pill-bar[data-cat="' + catIdx + '"]');
      if (bar) bar.style.display = 'flex';

      catSections.forEach(function (s) { s.style.display = 'none'; });
      var section = document.querySelector('.cat-section[data-cat="' + catIdx + '"]');
      if (section) section.style.display = 'block';

      activateSubPill(catIdx, 0);
    }

    function activateSubPill(catIdx, prodIdx) {
      var subPills = document.querySelectorAll('.sub-pill[data-cat="' + catIdx + '"]');
      subPills.forEach(function (p) {
        p.style.background = 'white'; p.style.color = '#4A4A4A'; p.style.borderColor = '#e5e7eb';
      });
      var active = document.querySelector('.sub-pill[data-cat="' + catIdx + '"][data-prod="' + prodIdx + '"]');
      if (active) { active.style.background = '#0099AF'; active.style.color = 'white'; active.style.borderColor = '#0099AF'; }

      var prodItems = document.querySelectorAll('.prod-item[data-cat="' + catIdx + '"]');
      prodItems.forEach(function (item) { item.style.display = 'none'; });
      var target = document.querySelector('.prod-item[data-cat="' + catIdx + '"][data-prod="' + prodIdx + '"]');
      if (target) target.style.display = 'block';
    }

    mainPills.forEach(function (pill) {
      pill.addEventListener('click', function () { activateMainPill(this.getAttribute('data-cat')); });
    });

    document.querySelectorAll('.sub-pill').forEach(function (pill) {
      pill.addEventListener('click', function () { activateSubPill(this.getAttribute('data-cat'), this.getAttribute('data-prod')); });
    });
  });
</script>

---
import ProductLayout from '../../../layouts/ProductLayout.astro';
import { products } from '../../../data/products.js';

const category = products['digital-printing'];
const totalProducts = category.subcategories.reduce((a, s) => a + s.products.length, 0);
---

<ProductLayout
  title="Digital Printing Inks | SANMYRS"
  description="Reactive, disperse, sublimation, acid, pigment, eco solvent, UV, and latex inks for digital textile and graphic printing. SANMYRS, Karachi, Pakistan."
  breadcrumbs={[
    { label: 'Products', href: '/products' },
    { label: 'Digital Printing', href: '/products/digital-printing' },
  ]}
>

  <!-- ── Header ── -->
  <header class="relative pt-24 pb-16 lg:pt-32 lg:pb-24 bg-white border-b border-gray-100 overflow-hidden">
    <div class="absolute inset-0 z-0">
      <div class="absolute -top-40 -right-40 w-[600px] h-[600px] bg-[#F7D000] rounded-full blur-[150px] opacity-10 pointer-events-none"></div>
    </div>
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10 flex flex-col md:flex-row md:items-end justify-between gap-8">
      <div class="max-w-3xl" data-aos="fade-right">
        <div class="inline-flex items-center gap-2 mb-4">
          <span class="w-8 h-[2px] bg-[#F7D000]"></span>
          <span class="text-xs font-bold uppercase tracking-widest text-[#F7D000]">Category</span>
        </div>
        <h1 class="text-5xl lg:text-7xl font-extrabold text-[#1A1A2E] tracking-tight leading-[1.05] font-unison mb-6">
          Digital Printing <br/>
          <span class="text-gray-400">Inks &amp; Systems</span>
        </h1>
        <p class="text-lg text-gray-500 max-w-2xl leading-relaxed">
          High-performance inks for textile digital printing systems and wide-format graphic inkjet printers, covering all major dye and ink chemistries.
        </p>
      </div>
      <div class="shrink-0 flex items-center gap-4 bg-white p-6 rounded-2xl border border-gray-100 shadow-sm" data-aos="fade-left" data-aos-delay="100">
        <div class="text-4xl font-black text-[#1A1A2E] font-unison">{totalProducts}</div>
        <div class="text-xs font-bold uppercase tracking-widest text-gray-400 leading-tight">Total<br/>Products</div>
      </div>
    </div>
  </header>

  <!-- ── Sticky Nav (two-level) ── -->
  <div class="cat-nav">
    <div class="cat-nav-inner">
      <div class="cat-pills-scroll" style="padding-bottom:8px;">
        {category.subcategories.map((sub, i) => (
          <button class="main-pill" data-cat={String(i)}
            style={`background:${i===0?'#0099AF':'transparent'}; color:${i===0?'white':'#4A4A4A'}; border-color:${i===0?'#0099AF':'#d1d5db'};`}>
            {sub.name}
            <span class="pill-count">{sub.products.length}</span>
          </button>
        ))}
      </div>
      {category.subcategories.map((sub, i) => (
        <div class="sub-pill-bar" data-cat={String(i)}
          style={`display:${i===0?'flex':'none'}; flex-wrap:nowrap; gap:6px; overflow-x:auto; scrollbar-width:none; padding-bottom:10px; border-top:1px solid #f3f4f6;`}>
          {sub.products.map((product, j) => (
            <button class="sub-pill" data-cat={String(i)} data-prod={String(j)}
              style={`flex-shrink:0; margin-top:8px; padding:5px 14px; border-radius:6px; border:1px solid; font-size:12px; font-weight:500; cursor:pointer; transition:background .15s,color .15s,border-color .15s; background:${j===0?'#0099AF':'transparent'}; color:${j===0?'white':'#4A4A4A'}; border-color:${j===0?'#0099AF':'#d1d5db'};`}>
              {product.name}
            </button>
          ))}
        </div>
      ))}
    </div>
  </div>

  <!-- ── Product Sections ── -->
  <div class="cat-body">
    {category.subcategories.map((sub, i) => (
      <div class="cat-section" data-cat={String(i)} style={i===0?'display:block;':'display:none;'}>
        {sub.products.map((product, j) => (
          <div class="prod-item" data-cat={String(i)} data-prod={String(j)} style={j===0?'display:block;':'display:none;'}>
            <div class="prod-item-head">
              <div>
                <h2 class="prod-item-h2 font-unison">{product.name}</h2>
                <p class="prod-item-meta">{product.images ? product.images.length : 1} variants available</p>
              </div>
              <a href={`/products/digital-printing/${product.slug}`} class="cat-btn-sm">View Details →</a>
            </div>
            {product.images ? (
              <div class="color-grid">
                {product.images.map(img => (
                  <a href={`/products/digital-printing/${product.slug}?variant=${encodeURIComponent(img.label)}`} class="color-card" data-aos="fade-up">
                    <img src={img.src} alt={`${product.name} — ${img.label}`} loading="lazy" class="color-card-img"/>
                    <p class="color-card-label">{img.label}</p>
                  </a>
                ))}
              </div>
            ) : (
              <div style="text-align:center; padding:48px; color:#9ca3af;">No images available</div>
            )}
          </div>
        ))}
      </div>
    ))}
  </div>

  <!-- ── CTA ── -->
  <div class="cat-cta">
    <div class="cat-cta-inner">
      <div class="cat-cta-text">
        <h3 class="cat-cta-h3 font-unison">Unsure which ink suits your printer?</h3>
        <p class="cat-cta-p">Tell us your printer model and substrate — we'll recommend the correct ink chemistry and provide technical data sheets.</p>
      </div>
      <div class="cat-cta-btns">
        <a href="/contact" class="cat-btn-primary">Get a Recommendation</a>
        <a href="https://wa.me/923183755197" target="_blank" rel="noopener noreferrer" class="cat-btn-ghost">WhatsApp Us</a>
      </div>
    </div>
  </div>

</ProductLayout>

<style>
  :root { --teal:#0099AF; --teal-dk:#007A8A; --navy:#1A1A2E; --page-bg:#F5F7F6; --border:#e5e7eb; }
  .cat-nav { background:white; border-bottom:1px solid var(--border); position:sticky; top:64px; z-index:30; }
  .cat-nav-inner { max-width:80rem; margin:0 auto; padding:10px clamp(16px,4vw,32px) 0; }
  .cat-pills-scroll { display:flex; flex-wrap:nowrap; gap:6px; overflow-x:auto; scrollbar-width:none; -webkit-overflow-scrolling:touch; padding-top:0; }
  .cat-pills-scroll::-webkit-scrollbar { display:none; }
  .main-pill { flex-shrink:0; display:inline-flex; align-items:center; gap:7px; padding:7px 16px; border-radius:6px; border:1px solid; font-size:13px; font-weight:500; cursor:pointer; transition:background .15s,color .15s,border-color .15s; line-height:1.3; }
  .pill-count { font-size:11px; font-weight:700; opacity:.7; }
  .cat-body { background:var(--page-bg); padding:clamp(28px,4vw,48px) clamp(16px,4vw,32px); }
  .cat-section, .prod-item { max-width:80rem; margin:0 auto; }
  .prod-item-head { display:flex; flex-wrap:wrap; align-items:center; justify-content:space-between; gap:12px; margin-bottom:24px; }
  .prod-item-h2 { font-size:clamp(1rem,2vw,1.3rem); font-weight:700; color:var(--navy); margin:0 0 3px; }
  .prod-item-meta { color:#6b7280; font-size:13px; margin:0; }
  .cat-btn-sm { display:inline-flex; align-items:center; min-height:38px; padding:7px 18px; background:var(--teal); color:white; font-size:13px; font-weight:600; border-radius:6px; text-decoration:none; border:none; cursor:pointer; white-space:nowrap; transition:background .15s; }
  .cat-btn-sm:hover { background:var(--teal-dk); }
  .color-grid { display:grid; grid-template-columns:repeat(1,minmax(0,1fr)); gap:16px; }
  @media(min-width:640px)  { .color-grid { grid-template-columns:repeat(2,minmax(0,1fr)); } }
  @media(min-width:1024px) { .color-grid { grid-template-columns:repeat(4,minmax(0,1fr)); } }
  .color-card { display:block; text-decoration:none; background:white; border-radius:8px; border:1px solid var(--border); padding:14px 10px; text-align:center; cursor:pointer; transition:box-shadow .15s,transform .15s,border-color .15s; }
  .color-card:hover { box-shadow:0 4px 16px rgba(0,0,0,.08); transform:translateY(-2px); border-color:var(--teal); }
  .color-card-img { max-height:130px; width:auto; max-width:100%; object-fit:contain; display:block; margin:0 auto 8px; }
  .color-card-label { font-size:11px; font-weight:600; color:#4A4A4A; margin:0; text-transform:uppercase; letter-spacing:.03em; }
  .cat-cta { background:var(--navy); border-top:1px solid rgba(255,255,255,.06); padding:clamp(36px,5vw,56px) 0; }
  .cat-cta-inner { max-width:80rem; margin:0 auto; padding:0 clamp(16px,4vw,32px); display:flex; flex-wrap:wrap; align-items:center; justify-content:space-between; gap:24px; }
  .cat-cta-text { flex:1; min-width:0; }
  .cat-cta-h3 { font-size:clamp(1rem,2vw,1.25rem); font-weight:800; color:white; margin:0 0 8px; }
  .cat-cta-p { color:rgba(255,255,255,.55); font-size:13.5px; line-height:1.65; margin:0; }
  .cat-cta-btns { display:flex; flex-wrap:wrap; gap:10px; flex-shrink:0; }
  .cat-btn-primary, .cat-btn-ghost { display:inline-flex; align-items:center; min-height:42px; padding:9px 22px; font-size:13.5px; font-weight:700; border-radius:6px; text-decoration:none; cursor:pointer; transition:background .18s; white-space:nowrap; }
  .cat-btn-primary { background:var(--teal); color:white; border:1.5px solid var(--teal); }
  .cat-btn-primary:hover { background:var(--teal-dk); border-color:var(--teal-dk); }
  .cat-btn-ghost { background:rgba(255,255,255,.08); color:white; border:1.5px solid rgba(255,255,255,.18); }
  .cat-btn-ghost:hover { background:rgba(255,255,255,.15); }
  div::-webkit-scrollbar { display:none; }
  @media(prefers-reduced-motion:reduce) { .color-card { transform:none !important; transition:none; } }
</style>

<script is:inline>
  document.addEventListener('DOMContentLoaded', function () {
    var mainPills = document.querySelectorAll('.main-pill');
    var subPillBars = document.querySelectorAll('.sub-pill-bar');
    var catSections = document.querySelectorAll('.cat-section');
    function activateMainPill(catIdx) {
      mainPills.forEach(function(p){ p.style.background='transparent'; p.style.color='#4A4A4A'; p.style.borderColor='#d1d5db'; });
      var a=document.querySelector('.main-pill[data-cat="'+catIdx+'"]');
      if(a){a.style.background='#0099AF';a.style.color='white';a.style.borderColor='#0099AF';}
      subPillBars.forEach(function(b){b.style.display='none';});
      var bar=document.querySelector('.sub-pill-bar[data-cat="'+catIdx+'"]');
      if(bar)bar.style.display='flex';
      catSections.forEach(function(s){s.style.display='none';});
      var sec=document.querySelector('.cat-section[data-cat="'+catIdx+'"]');
      if(sec)sec.style.display='block';
      activateSubPill(catIdx,0);
      if(window.AOS) window.AOS.refresh();
    }
    function activateSubPill(catIdx,prodIdx) {
      var subs=document.querySelectorAll('.sub-pill[data-cat="'+catIdx+'"]');
      subs.forEach(function(p){p.style.background='transparent';p.style.color='#4A4A4A';p.style.borderColor='#d1d5db';});
      var a=document.querySelector('.sub-pill[data-cat="'+catIdx+'"][data-prod="'+prodIdx+'"]');
      if(a){a.style.background='#0099AF';a.style.color='white';a.style.borderColor='#0099AF';}
      var items=document.querySelectorAll('.prod-item[data-cat="'+catIdx+'"]');
      items.forEach(function(item){item.style.display='none';});
      var t=document.querySelector('.prod-item[data-cat="'+catIdx+'"][data-prod="'+prodIdx+'"]');
      if(t)t.style.display='block';
      if(window.AOS) window.AOS.refresh();
    }
    mainPills.forEach(function(pill){pill.addEventListener('click',function(){activateMainPill(this.getAttribute('data-cat'));});});
    document.querySelectorAll('.sub-pill').forEach(function(pill){pill.addEventListener('click',function(){activateSubPill(this.getAttribute('data-cat'),this.getAttribute('data-prod'));});});
  });
</script>

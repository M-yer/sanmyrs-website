---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Contact SANMYRS | Inquire About Products — Karachi, Pakistan"
  description="Contact SANMYRS to inquire about screen printing inks, digital printing inks, or textile auxiliaries. Located in Karachi, Pakistan. WhatsApp: +92 318 3755197."
>

  <!-- ── HERO ─────────────────────────────────────────── -->
  <section class="ct-hero">
    <div class="ct-hero__glow" aria-hidden="true"></div>
    <div class="ct-container">
      <div class="ct-hero__inner" data-aos="fade-up">
        <div class="ct-eyebrow-pill">
          <span class="ct-gold-dot" aria-hidden="true"></span>
          Get In Touch
        </div>
        <h1 class="ct-hero__h1 font-unison">Send an Inquiry.</h1>
        <p class="ct-hero__sub">
          Product pricing, technical data sheets, samples, or process advice —
          our team responds within one working day.
        </p>
        <div class="ct-hero__accent-line" aria-hidden="true"></div>
      </div>
    </div>
  </section>

  <!-- ── TRUST STRIP ────────────────────────────────────── -->
  <div class="ct-trust-strip">
    <div class="ct-container">
      <div class="ct-trust-strip__inner" data-aos="fade-up" data-aos-delay="80">

        <!-- 24hr Response -->
        <div class="ct-trust-item">
          <div class="ct-trust-item__icon">
            <svg xmlns="http://www.w3.org/2000/svg" class="ct-icon" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          </div>
          <span class="ct-trust-item__label">24hr Response</span>
        </div>

        <div class="ct-trust-divider" aria-hidden="true"></div>

        <!-- 18+ Years Experience -->
        <div class="ct-trust-item">
          <div class="ct-trust-item__icon">
            <svg xmlns="http://www.w3.org/2000/svg" class="ct-icon" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z" />
            </svg>
          </div>
          <span class="ct-trust-item__label">18+ Years Experience</span>
        </div>

        <div class="ct-trust-divider" aria-hidden="true"></div>

        <!-- Direct WhatsApp -->
        <div class="ct-trust-item">
          <div class="ct-trust-item__icon ct-trust-item__icon--wa">
            <svg xmlns="http://www.w3.org/2000/svg" class="ct-icon" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
            </svg>
          </div>
          <span class="ct-trust-item__label">Direct WhatsApp</span>
        </div>

      </div>
    </div>
  </div>

  <!-- ── MAIN FORM SECTION ──────────────────────────────── -->
  <section class="ct-main">
    <div class="ct-container">
      <div class="ct-main__grid">

        <!-- LEFT: info cards -->
        <div class="ct-info-col">

          <!-- WhatsApp Card -->
          <div class="ct-info-card" data-aos="fade-up" data-aos-delay="80">
            <h3 class="ct-info-card__title">
              <svg xmlns="http://www.w3.org/2000/svg" class="ct-info-card__title-icon ct-wa-icon" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
              </svg>
              WhatsApp — Fastest Response
            </h3>
            <p class="ct-info-card__body">
              For urgent product inquiries, price requests, or to speak directly with our team.
              We typically respond within 1–2 hours during business hours.
            </p>
            <a
              href="https://wa.me/923183755197"
              target="_blank"
              rel="noopener noreferrer"
              class="ct-wa-btn"
            >
              <svg xmlns="http://www.w3.org/2000/svg" class="ct-wa-btn__icon" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
              </svg>
              Chat on WhatsApp: +92 318 3755197
            </a>
          </div>

          <!-- Location Card -->
          <div class="ct-info-card" data-aos="fade-up" data-aos-delay="160">
            <h3 class="ct-info-card__title">
              <svg xmlns="http://www.w3.org/2000/svg" class="ct-info-card__title-icon" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
              </svg>
              Our Location
            </h3>
            <div class="ct-location-row">
              <svg xmlns="http://www.w3.org/2000/svg" class="ct-location-pin" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
              </svg>
              <address class="ct-address">
                F-126, Lucknow Society<br/>
                Korangi Industrial Area<br/>
                Karachi, Pakistan
              </address>
            </div>
            <div class="ct-map-placeholder">
              <svg xmlns="http://www.w3.org/2000/svg" class="ct-map-placeholder__icon" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7" />
              </svg>
              <span class="ct-map-placeholder__text">Korangi, Karachi</span>
              <a
                href="https://www.google.com/maps/search/Korangi+Industrial+Area+Karachi"
                target="_blank"
                rel="noopener noreferrer"
                class="ct-map-link"
              >
                View on Google Maps
              </a>
            </div>
          </div>

          <!-- Business Hours Card -->
          <div class="ct-info-card" data-aos="fade-up" data-aos-delay="240">
            <h3 class="ct-info-card__title">
              <svg xmlns="http://www.w3.org/2000/svg" class="ct-info-card__title-icon" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
              Business Hours
            </h3>
            <div class="ct-hours-table">
              {[
                { day: 'Monday \u2013 Friday', hours: '9:00 AM \u2013 6:00 PM', open: true },
                { day: 'Saturday',             hours: '9:00 AM \u2013 2:00 PM', open: true },
                { day: 'Sunday',               hours: 'Closed',                  open: false },
              ].map(row => (
                <div class="ct-hours-row">
                  <span class="ct-hours-row__day">{row.day}</span>
                  <span class={row.open ? 'ct-hours-row__time ct-hours-row__time--open' : 'ct-hours-row__time ct-hours-row__time--closed'}>{row.hours}</span>
                </div>
              ))}
            </div>
          </div>

        </div>

        <!-- RIGHT: form card -->
        <div class="ct-form-card" data-aos="fade-up" data-aos-delay="80">
          <div class="ct-form-card__top-accent" aria-hidden="true"></div>
          <div class="ct-form-card__body">

            <h2 class="ct-form-card__h2 font-unison">Send an Inquiry</h2>
            <p class="ct-form-card__sub">
              Fill in the form below and our team will respond within one working day.
              For urgent requests, WhatsApp us directly.
            </p>

            <form
              action="https://formspree.io/f/xzdkbblv"
              method="POST"
              class="ct-form"
            >

              <!-- Name + Company row -->
              <div class="ct-form__row-2">
                <div class="ct-form__field">
                  <label for="ct-name" class="ct-form__label">
                    Full Name <span class="ct-form__required" aria-hidden="true">*</span>
                  </label>
                  <input
                    type="text"
                    id="ct-name"
                    name="name"
                    required
                    placeholder="Your full name"
                    class="ct-form__input"
                  />
                </div>
                <div class="ct-form__field">
                  <label for="ct-company" class="ct-form__label">
                    Company Name
                  </label>
                  <input
                    type="text"
                    id="ct-company"
                    name="company"
                    placeholder="Your company"
                    class="ct-form__input"
                  />
                </div>
              </div>

              <!-- Email -->
              <div class="ct-form__field">
                <label for="ct-email" class="ct-form__label">
                  Email Address <span class="ct-form__required" aria-hidden="true">*</span>
                </label>
                <input
                  type="email"
                  id="ct-email"
                  name="email"
                  required
                  placeholder="your@email.com"
                  class="ct-form__input"
                />
              </div>

              <!-- Phone -->
              <div class="ct-form__field">
                <label for="ct-phone" class="ct-form__label">
                  Phone / WhatsApp
                </label>
                <input
                  type="tel"
                  id="ct-phone"
                  name="phone"
                  placeholder="+92 3XX XXXXXXX"
                  class="ct-form__input"
                />
              </div>

              <!-- Product of Interest -->
              <div class="ct-form__field">
                <label for="ct-product" class="ct-form__label">
                  Product of Interest
                </label>
                <select id="ct-product" name="product" class="ct-form__input ct-form__select">
                  <option value="">Select a category...</option>
                  <optgroup label="Screen Printing">
                    <option>Plastisol Inks</option>
                    <option>Water-Based Inks</option>
                    <option>Plastisol Additives</option>
                    <option>Water-Based Additives</option>
                  </optgroup>
                  <optgroup label="Digital Printing">
                    <option>Reactive / Acid / Disperse / Pigment Textile Inks</option>
                    <option>Sublimation Inks</option>
                    <option>Eco Solvent / Solvent / UV / Latex Inks</option>
                  </optgroup>
                  <optgroup label="Textile Auxiliaries">
                    <option>Dyeing Auxiliaries</option>
                    <option>Softeners &amp; Finishing Chemicals</option>
                  </optgroup>
                  <option value="other">Other / Not sure</option>
                </select>
              </div>

              <!-- Message -->
              <div class="ct-form__field">
                <label for="ct-message" class="ct-form__label">
                  Message <span class="ct-form__required" aria-hidden="true">*</span>
                </label>
                <textarea
                  id="ct-message"
                  name="message"
                  required
                  rows="5"
                  placeholder="Tell us about your requirements — product name, quantity, application, fabric type, or any technical questions..."
                  class="ct-form__input ct-form__textarea"
                ></textarea>
              </div>

              <!-- Submit -->
              <button type="submit" class="ct-form__submit">
                Send Inquiry
              </button>

              <!-- Privacy note -->
              <p class="ct-form__privacy">
                By submitting this form you agree to be contacted by SANMYRS regarding your inquiry.
              </p>

            </form>
          </div>
        </div>

      </div>
    </div>
  </section>

</BaseLayout>

<style>
  /* ── Container ───────────────────────────────────────── */
  .ct-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 clamp(16px, 4vw, 32px);
  }

  /* ── HERO ────────────────────────────────────────────── */
  .ct-hero {
    position: relative;
    background: #1A1A2E;
    overflow: hidden;
    padding: clamp(80px, 12vw, 130px) 0 clamp(64px, 8vw, 96px);
  }

  .ct-hero__glow {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }
  .ct-hero__glow::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse 55% 90% at 105% -15%, rgba(0,153,175,0.18) 0%, transparent 60%);
  }

  .ct-hero__inner {
    position: relative;
    z-index: 1;
    max-width: 680px;
  }

  .ct-eyebrow-pill {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    background: rgba(0,153,175,0.15);
    border: 1px solid rgba(0,153,175,0.3);
    color: #0099AF;
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    padding: 0.3rem 0.85rem;
    border-radius: 4px;
    margin-bottom: 1.25rem;
  }

  .ct-gold-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: #F5A623;
    flex-shrink: 0;
  }

  .ct-hero__h1 {
    font-size: clamp(2.8rem, 6vw, 4.5rem);
    font-weight: 800;
    color: #ffffff;
    line-height: 1.05;
    margin: 0 0 1.25rem;
  }

  .ct-hero__sub {
    color: rgba(255,255,255,0.65);
    font-size: clamp(1rem, 2vw, 1.15rem);
    line-height: 1.7;
    max-width: 540px;
    margin: 0;
  }

  .ct-hero__accent-line {
    width: 3rem;
    height: 3px;
    background: #0099AF;
    border-radius: 2px;
    margin-top: 2rem;
  }

  /* ── TRUST STRIP ─────────────────────────────────────── */
  .ct-trust-strip {
    background: #ffffff;
    border-bottom: 1px solid #E2E8F0;
    padding: 1.25rem 0;
  }

  .ct-trust-strip__inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
  }
  @media (min-width: 640px) {
    .ct-trust-strip__inner {
      flex-direction: row;
      justify-content: center;
      gap: 2rem;
    }
  }

  .ct-trust-item {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
  }

  .ct-trust-item__icon {
    width: 20px;
    height: 20px;
    color: #0099AF;
    flex-shrink: 0;
  }

  .ct-trust-item__icon--wa {
    color: #25D366;
  }

  .ct-icon {
    width: 20px;
    height: 20px;
  }

  .ct-trust-item__label {
    font-size: 0.875rem;
    font-weight: 600;
    color: #0F172A;
  }

  .ct-trust-divider {
    display: none;
  }
  @media (min-width: 640px) {
    .ct-trust-divider {
      display: block;
      width: 1px;
      height: 1.25rem;
      background: #E2E8F0;
      flex-shrink: 0;
    }
  }

  /* ── MAIN FORM SECTION ──────────────────────────────── */
  .ct-main {
    background: #F8FAFC;
    padding: clamp(56px, 7vw, 80px) 0;
  }

  .ct-main__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
    align-items: start;
  }
  @media (min-width: 1024px) {
    .ct-main__grid {
      grid-template-columns: 1fr 1.3fr;
    }
  }

  /* ── Info Column ─────────────────────────────────────── */
  .ct-info-col {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    order: 2;
  }
  @media (min-width: 1024px) {
    .ct-info-col { order: 1; }
  }

  .ct-info-card {
    background: #ffffff;
    border: 1px solid #E2E8F0;
    border-radius: 16px;
    padding: 1.5rem;
    transition: box-shadow 200ms ease;
  }
  .ct-info-card:hover {
    box-shadow: 0 8px 24px rgba(0,0,0,0.07);
  }

  .ct-info-card__title {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-family: 'UnisonPro', 'Outfit', sans-serif;
    font-size: 0.9rem;
    font-weight: 700;
    color: #0F172A;
    margin: 0 0 0.75rem;
  }

  .ct-info-card__title-icon {
    width: 18px;
    height: 18px;
    color: #0099AF;
    flex-shrink: 0;
  }

  .ct-wa-icon {
    color: #25D366 !important;
  }

  .ct-info-card__body {
    font-size: 0.875rem;
    color: #475569;
    line-height: 1.65;
    margin: 0 0 1rem;
  }

  .ct-wa-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    width: 100%;
    padding: 0.8rem 1rem;
    background: #25D366;
    color: #ffffff;
    font-weight: 700;
    font-size: 0.875rem;
    border-radius: 8px;
    text-decoration: none;
    transition: background 200ms ease, transform 150ms ease;
  }
  .ct-wa-btn:hover {
    background: #128C7E;
    transform: translateY(-1px);
  }

  .ct-wa-btn__icon {
    width: 16px;
    height: 16px;
    flex-shrink: 0;
  }

  .ct-location-row {
    display: flex;
    align-items: flex-start;
    gap: 0.5rem;
    font-size: 0.875rem;
    color: #475569;
    margin-bottom: 1rem;
  }

  .ct-location-pin {
    width: 16px;
    height: 16px;
    color: #0099AF;
    flex-shrink: 0;
    margin-top: 0.1rem;
  }

  .ct-address {
    font-style: normal;
    line-height: 1.65;
  }


---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Contact SANMYRS | Inquire About Products — Karachi, Pakistan"
  description="Contact SANMYRS to inquire about screen printing inks, digital printing inks, or textile auxiliaries. Located in Karachi, Pakistan. WhatsApp: +92 318 3755197."
>

  <!-- ── NEOMINIMALIST MAP HERO ────────────────────────── -->
  <section class="relative pt-32 pb-64 lg:pt-40 lg:pb-72 bg-slate-50 overflow-hidden">
    <!-- Decorative Map Pattern Background -->
    <div class="absolute inset-0 z-0 opacity-[0.03] pointer-events-none" style="background-image: url('data:image/svg+xml,%3Csvg width=\'60\' height=\'60\' viewBox=\'0 0 60 60\' xmlns=\'http://www.w3.org/2000/svg\'%3E%3Cpath d=\'M54.627 0l.83.83v58.34h-58.34l-.83-.83L0 0h54.627zm-52.96 57.51h55.007V1.66H1.667v55.85zM22.5 12.5h15v15h-15v-15zm-2.5-2.5v20h20v-20h-20z\' fill=\'%231A1A2E\' fill-rule=\'evenodd\'/%3E%3C/svg%3E');"></div>
    
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10 text-center">
      <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-white border border-gray-200 shadow-sm mb-6" data-aos="fade-up">
        <span class="w-2 h-2 rounded-full bg-[#25D366] animate-pulse"></span>
        <span class="text-xs font-bold uppercase tracking-widest text-[#1A1A2E]">Fast Response</span>
      </div>
      <h1 class="text-5xl lg:text-7xl font-extrabold text-[#1A1A2E] tracking-tight leading-[1.05] mb-6 font-unison" data-aos="fade-up" data-aos-delay="100">
        Let's Talk <span class="text-transparent bg-clip-text bg-gradient-to-r from-[#1A1A2E] to-[#0099AF]">Chemistry.</span>
      </h1>
      <p class="text-lg lg:text-xl text-gray-600 leading-relaxed max-w-2xl mx-auto" data-aos="fade-up" data-aos-delay="150">
        Product pricing, technical data sheets, samples, or process advice — our team responds within one working day.
      </p>
    </div>
  </section>

  <!-- ── FLOATING CONTACT BLOCK ─────────────────────────── -->
  <section class="relative -mt-48 lg:-mt-56 z-20 pb-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      
      <div class="bg-white rounded-[2rem] shadow-2xl border border-gray-100 overflow-hidden">
        <div class="grid grid-cols-1 lg:grid-cols-12 flex-col-reverse lg:flex-row">
          
          <!-- LEFT: Info Cards (Navy Block) -->
          <div class="lg:col-span-5 bg-[#1A1A2E] p-10 lg:p-14 text-white relative overflow-hidden flex flex-col justify-between">
            <div class="absolute top-0 left-0 w-full h-1 bg-gradient-to-r from-[#0099AF] to-[#007A8A]"></div>
            
            <!-- Background Glow -->
            <div class="absolute -bottom-24 -left-24 w-96 h-96 bg-[#0099AF] rounded-full blur-[100px] opacity-30 pointer-events-none"></div>

            <div class="relative z-10 space-y-12">
              <div>
                <h2 class="text-3xl font-bold font-unison mb-4">Contact Info</h2>
                <p class="text-gray-400 text-sm leading-relaxed max-w-sm">Fill out the form or reach us directly via WhatsApp. Direct communication yields the fastest technical support.</p>
              </div>

              <!-- WhatsApp Action -->
              <a href="https://wa.me/923183755197" target="_blank" rel="noopener noreferrer" class="group flex items-start gap-4 p-5 rounded-2xl bg-white/5 border border-white/10 hover:bg-white/10 transition-colors">
                <div class="w-12 h-12 shrink-0 rounded-full bg-[#25D366]/20 flex items-center justify-center text-[#25D366] group-hover:scale-110 transition-transform">
                  <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
                </div>
                <div>
                  <h3 class="font-bold text-white mb-1">WhatsApp Chat</h3>
                  <p class="text-[#25D366] font-bold text-lg leading-none">+92 318 3755197</p>
                  <p class="text-xs text-gray-400 mt-2">Fastest response for urgent queries</p>
                </div>
              </a>

              <!-- Location -->
              <div class="flex items-start gap-4 p-1">
                <div class="w-12 h-12 shrink-0 rounded-full bg-white/5 flex items-center justify-center text-[#0099AF]">
                   <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" /><path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
                </div>
                <div>
                  <h3 class="font-bold text-white mb-2">Our Location</h3>
                  <address class="text-gray-400 text-sm not-italic leading-relaxed">
                    F-126, Lucknow Society,<br/>
                    Korangi Industrial Area,<br/>
                    Karachi, Pakistan
                  </address>
                  <a href="https://www.google.com/maps/search/Korangi+Industrial+Area+Karachi" target="_blank" rel="noopener noreferrer" class="inline-block mt-3 text-sm font-bold text-[#0099AF] hover:text-white transition-colors">View on Google Maps →</a>
                </div>
              </div>

              <!-- Hours -->
              <div class="flex items-start gap-4 p-1">
                <div class="w-12 h-12 shrink-0 rounded-full bg-white/5 flex items-center justify-center text-[#0099AF]">
                  <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
                </div>
                <div class="w-full">
                  <h3 class="font-bold text-white mb-3">Business Hours</h3>
                  <div class="space-y-2 text-sm">
                    <div class="flex justify-between items-center pb-2 border-b border-white/10">
                      <span class="text-gray-300">Mon &ndash; Fri</span>
                      <span class="text-[#0099AF] font-bold">9:00 AM &ndash; 6:00 PM</span>
                    </div>
                    <div class="flex justify-between items-center pb-2 border-b border-white/10">
                      <span class="text-gray-300">Saturday</span>
                      <span class="text-[#0099AF] font-bold">9:00 AM &ndash; 2:00 PM</span>
                    </div>
                    <div class="flex justify-between items-center">
                      <span class="text-gray-300">Sunday</span>
                      <span class="text-gray-500">Closed</span>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>

          <!-- RIGHT: Form -->
          <div class="lg:col-span-7 bg-white p-10 lg:p-14">
            <h2 class="text-2xl font-bold text-[#1A1A2E] mb-2 font-unison">Send an Inquiry</h2>
            <p class="text-gray-500 text-sm mb-8">All fields marked with an asterisk (*) are required.</p>

            <form action="https://formspree.io/f/xzdkbblv" method="POST" class="space-y-6">
              
              <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <!-- Name -->
                <div class="relative">
                  <label for="ct-name" class="block text-xs font-bold text-gray-700 uppercase tracking-widest mb-2">Full Name <span class="text-red-500">*</span></label>
                  <input type="text" id="ct-name" name="name" required placeholder="John Doe" 
                    class="w-full bg-slate-50 border border-gray-200 text-gray-900 text-sm rounded-xl focus:ring-[#0099AF] focus:border-[#0099AF] block p-3.5 transition-colors placeholder:text-gray-400">
                </div>
                
                <!-- Company -->
                <div class="relative">
                  <label for="ct-company" class="block text-xs font-bold text-gray-700 uppercase tracking-widest mb-2">Company</label>
                  <input type="text" id="ct-company" name="company" placeholder="Acme Textiles Ltd." 
                    class="w-full bg-slate-50 border border-gray-200 text-gray-900 text-sm rounded-xl focus:ring-[#0099AF] focus:border-[#0099AF] block p-3.5 transition-colors placeholder:text-gray-400">
                </div>
              </div>

              <!-- Email -->
              <div class="relative">
                <label for="ct-email" class="block text-xs font-bold text-gray-700 uppercase tracking-widest mb-2">Email Address <span class="text-red-500">*</span></label>
                <input type="email" id="ct-email" name="email" required placeholder="john@example.com" 
                  class="w-full bg-slate-50 border border-gray-200 text-gray-900 text-sm rounded-xl focus:ring-[#0099AF] focus:border-[#0099AF] block p-3.5 transition-colors placeholder:text-gray-400">
              </div>

              <!-- Phone -->
              <div class="relative">
                <label for="ct-phone" class="block text-xs font-bold text-gray-700 uppercase tracking-widest mb-2">Phone / WhatsApp</label>
                <input type="tel" id="ct-phone" name="phone" placeholder="+92 3XX XXXXXXX" 
                  class="w-full bg-slate-50 border border-gray-200 text-gray-900 text-sm rounded-xl focus:ring-[#0099AF] focus:border-[#0099AF] block p-3.5 transition-colors placeholder:text-gray-400">
              </div>

              <!-- Product -->
              <div class="relative">
                <label for="ct-product" class="block text-xs font-bold text-gray-700 uppercase tracking-widest mb-2">Product of Interest</label>
                <select id="ct-product" name="product" 
                  class="w-full bg-slate-50 border border-gray-200 text-gray-900 text-sm rounded-xl focus:ring-[#0099AF] focus:border-[#0099AF] block p-3.5 transition-colors appearance-none cursor-pointer pr-10">
                  <option value="">Select a category...</option>
                  <optgroup label="Screen Printing">
                    <option>Plastisol Inks</option>
                    <option>Water-Based Inks</option>
                    <option>Plastisol Additives</option>
                    <option>Water-Based Additives</option>
                  </optgroup>
                  <optgroup label="Digital Printing">
                    <option>Reactive / Acid / Disperse / Pigment Textile Inks</option>
                    <option>Sublimation Inks</option>
                    <option>Eco Solvent / Solvent / UV / Latex Inks</option>
                  </optgroup>
                  <optgroup label="Textile Auxiliaries">
                    <option>Dyeing Auxiliaries</option>
                    <option>Softeners &amp; Finishing Chemicals</option>
                  </optgroup>
                  <option value="other">Other / Not sure</option>
                </select>
                <!-- Custom chevron -->
                <div class="absolute inset-y-0 right-0 flex items-center pr-4 mt-6 pointer-events-none text-gray-500">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" /></svg>
                </div>
              </div>

              <!-- Message -->
              <div class="relative">
                <label for="ct-message" class="block text-xs font-bold text-gray-700 uppercase tracking-widest mb-2">Message <span class="text-red-500">*</span></label>
                <textarea id="ct-message" name="message" required rows="5" placeholder="Tell us about your requirements — product name, quantity, application, fabric type, or any technical questions..." 
                  class="w-full bg-slate-50 border border-gray-200 text-gray-900 text-sm rounded-xl focus:ring-[#0099AF] focus:border-[#0099AF] block p-3.5 transition-colors placeholder:text-gray-400 resize-none"></textarea>
              </div>

              <!-- Submit -->
              <div class="pt-2">
                <button type="submit" class="w-full inline-flex justify-center items-center px-8 py-4 rounded-xl bg-[#0099AF] text-white font-bold tracking-wide transition-all hover:bg-[#007A8A] hover:-translate-y-0.5 shadow-lg shadow-[#0099AF]/20">
                  Send Inquiry
                  <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 ml-2" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" /></svg>
                </button>
              </div>

              <p class="text-xs text-center text-gray-400 mt-4 leading-relaxed">
                By submitting this form you agree to be contacted by SANMYRS regarding your inquiry.
              </p>

            </form>
          </div>
          
        </div>
      </div>
    </div>
  </section>

</BaseLayout>

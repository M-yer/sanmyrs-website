---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Contact SANMYRS | Inquire About Products — Karachi, Pakistan"
  description="Contact SANMYRS to inquire about screen printing inks, digital printing inks, or textile auxiliaries. Located in Karachi, Pakistan. WhatsApp: +92 318 3755197."
>

  <!-- ═══════════════════════════════════════════
       HERO — navy bg, dot grid + checker patterns
       ═══════════════════════════════════════════ -->
  <section class="relative overflow-hidden" style="background:#1A1A2E;">

    <!-- Dot grid pattern -->
    <svg
      aria-hidden="true"
      class="absolute inset-0 w-full h-full"
      xmlns="http://www.w3.org/2000/svg"
      style="pointer-events:none;"
    >
      <defs>
        <pattern id="contact-dots" x="0" y="0" width="32" height="32" patternUnits="userSpaceOnUse">
          <circle cx="16" cy="16" r="1.4" fill="rgba(0,153,175,0.18)" />
        </pattern>
      </defs>
      <rect width="100%" height="100%" fill="url(#contact-dots)" />
    </svg>

    <!-- Checker / triangle accent pattern -->
    <svg
      aria-hidden="true"
      class="absolute inset-0 w-full h-full"
      xmlns="http://www.w3.org/2000/svg"
      style="pointer-events:none;"
    >
      <defs>
        <pattern id="contact-checker" x="0" y="0" width="64" height="64" patternUnits="userSpaceOnUse">
          <polygon points="0,0 64,0 0,64" fill="none" stroke="rgba(255,255,255,0.05)" stroke-width="1" />
          <polygon points="64,0 64,64 0,64" fill="none" stroke="rgba(255,255,255,0.05)" stroke-width="1" />
        </pattern>
      </defs>
      <rect width="100%" height="100%" fill="url(#contact-checker)" />
    </svg>

    <!-- Hero content -->
    <div class="relative z-10 max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-24 sm:py-32 text-center">

      <!-- Eyebrow pill -->
      <div
        class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full text-xs font-semibold tracking-widest uppercase text-white mb-6"
        style="border:1px solid rgba(255,255,255,0.18); background:rgba(255,255,255,0.06); backdrop-filter:blur(6px);"
        data-aos="fade-up"
        data-aos-delay="80"
      >
        <span class="w-1.5 h-1.5 rounded-full flex-shrink-0" style="background:#F5A623;"></span>
        Get In Touch
      </div>

      <!-- H1 -->
      <h1
        class="font-unison font-bold text-white leading-tight mb-5"
        style="font-size:clamp(2.5rem,6vw,4rem);"
        data-aos="fade-up"
        data-aos-delay="160"
      >
        Send an
        <span style="background:linear-gradient(125deg,#00c4d4,#0099AF);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;">
          Inquiry.
        </span>
      </h1>

      <!-- Subtitle -->
      <p
        class="text-base sm:text-lg max-w-xl mx-auto"
        style="color:rgba(255,255,255,0.7);"
        data-aos="fade-up"
        data-aos-delay="240"
      >
        Product pricing, technical data sheets, samples, or process advice —
        our team responds within one working day.
      </p>

    </div>
  </section>


  <!-- ═══════════════════════════════════════════
       TRUST STRIP — white bg, 3 items
       ═══════════════════════════════════════════ -->
  <div class="bg-white border-b border-gray-100 py-6">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div
        class="flex flex-col sm:flex-row items-center justify-center gap-6 sm:gap-10"
        data-aos="fade-up"
        data-aos-delay="80"
      >

        <!-- 24hr Response -->
        <div class="inline-flex items-center gap-2 text-sm font-medium text-body-text">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 flex-shrink-0" style="color:#0099AF;" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
          24hr Response
        </div>

        <!-- Divider (hidden on mobile) -->
        <div class="hidden sm:block w-px h-5 bg-gray-200 flex-shrink-0"></div>

        <!-- 18+ Years Experience -->
        <div class="inline-flex items-center gap-2 text-sm font-medium text-body-text">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 flex-shrink-0" style="color:#0099AF;" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z" />
          </svg>
          18+ Years Experience
        </div>

        <!-- Divider (hidden on mobile) -->
        <div class="hidden sm:block w-px h-5 bg-gray-200 flex-shrink-0"></div>

        <!-- Direct WhatsApp Line -->
        <div class="inline-flex items-center gap-2 text-sm font-medium text-body-text">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 flex-shrink-0" style="color:#25D366;" viewBox="0 0 24 24" fill="currentColor">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
          </svg>
          Direct WhatsApp Line
        </div>

      </div>
    </div>
  </div>


  <!-- ═══════════════════════════════════════════
       MAIN FORM SECTION — 2-col grid
       ═══════════════════════════════════════════ -->
  <section class="bg-page-bg" style="padding-top:clamp(56px,7vw,80px); padding-bottom:clamp(56px,7vw,80px);">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

      <div class="grid grid-cols-1 lg:grid-cols-[1fr_1.2fr] gap-12 items-start">


        <!-- ─────────────────────────────────────
             LEFT COLUMN — CONTACT INFO
             order-2 on mobile, order-1 on desktop
             ───────────────────────────────────── -->
        <div class="order-2 lg:order-1 space-y-6">

          <!-- WhatsApp Card -->
          <div
            class="bg-white rounded-xl border border-gray-200 p-6"
            data-aos="fade-up"
            data-aos-delay="80"
          >
            <h3 class="font-unison text-base font-bold mb-1 flex items-center gap-2" style="color:#1A1A2E;">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 flex-shrink-0" style="color:#25D366;" viewBox="0 0 24 24" fill="currentColor">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
              </svg>
              WhatsApp — Fastest Response
            </h3>
            <p class="text-sm text-body-text mb-5 leading-relaxed">
              For urgent product inquiries, price requests, or to speak directly with our team. We typically respond within 1–2 hours during business hours.
            </p>
            <a
              href="https://wa.me/923183755197"
              target="_blank"
              rel="noopener noreferrer"
              class="flex items-center justify-center gap-2 w-full px-5 py-3.5 text-white font-bold rounded-lg transition-colors duration-200 cursor-pointer text-sm"
              style="background:#25D366;"
              onmouseover="this.style.background='#128C7E'"
              onmouseout="this.style.background='#25D366'"
            >
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 flex-shrink-0" viewBox="0 0 24 24" fill="white">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
              </svg>
              Chat on WhatsApp: +92 318 3755197
            </a>
          </div>

          <!-- Location Card -->
          <div
            class="bg-white rounded-xl border border-gray-200 p-6"
            data-aos="fade-up"
            data-aos-delay="160"
          >
            <h3 class="font-unison text-base font-bold mb-4 flex items-center gap-2" style="color:#1A1A2E;">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 flex-shrink-0" style="color:#0099AF;" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
              </svg>
              Our Location
            </h3>

            <div class="flex items-start gap-3 text-sm text-body-text mb-5">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 flex-shrink-0 mt-0.5" style="color:#0099AF;" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
              </svg>
              <address class="not-italic leading-relaxed">
                F-126, Lucknow Society<br/>
                Korangi Industrial Area<br/>
                Karachi, Pakistan
              </address>
            </div>

            <!-- Map placeholder -->
            <div
              class="rounded-lg border border-gray-200 flex flex-col items-center justify-center gap-2 text-body-text"
              style="background:#F5F7F6; height:10rem;"
            >
              <svg xmlns="http://www.w3.org/2000/svg" class="w-9 h-9" style="color:#d1d5db;" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7" />
              </svg>
              <span class="text-sm text-body-text">Korangi, Karachi</span>
              <a
                href="https://www.google.com/maps/search/Korangi+Industrial+Area+Karachi"
                target="_blank"
                rel="noopener noreferrer"
                class="text-xs font-medium transition-colors duration-150"
                style="color:#0099AF;"
                onmouseover="this.style.color='#007A8A'"
                onmouseout="this.style.color='#0099AF'"
              >
                View on Google Maps
              </a>
            </div>
          </div>

          <!-- Business Hours Card -->
          <div
            class="bg-white rounded-xl border border-gray-200 p-6"
            data-aos="fade-up"
            data-aos-delay="240"
          >
            <h3 class="font-unison text-base font-bold mb-4 flex items-center gap-2" style="color:#1A1A2E;">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 flex-shrink-0" style="color:#0099AF;" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
              Business Hours
            </h3>
            <div class="text-sm text-body-text">
              {[
                { day: 'Monday – Friday', hours: '9:00 AM – 6:00 PM', open: true },
                { day: 'Saturday',        hours: '9:00 AM – 2:00 PM', open: true },
                { day: 'Sunday',          hours: 'Closed',             open: false },
              ].map(row => (
                <div class="flex justify-between items-center py-2.5 border-b border-gray-100 last:border-0">
                  <span class="font-medium" style="color:#1A1A2E;">{row.day}</span>
                  <span style={row.open ? 'color:#0099AF; font-weight:600;' : 'color:#9ca3af;'}>{row.hours}</span>
                </div>
              ))}
            </div>
          </div>

        </div>


        <!-- ─────────────────────────────────────
             RIGHT COLUMN — FORM CARD
             order-1 on mobile, order-2 on desktop
             ───────────────────────────────────── -->
        <div
          class="order-1 lg:order-2 bg-white rounded-xl border border-gray-200 shadow-sm overflow-hidden"
          data-aos="fade-up"
          data-aos-delay="80"
        >
          <!-- Teal left-accent bar -->
          <div class="flex">
            <div class="w-1 flex-shrink-0" style="background:#0099AF;"></div>
            <div class="flex-1 p-8">

              <h2 class="font-unison font-bold text-2xl mb-1" style="color:#0099AF;">
                Send an Inquiry
              </h2>
              <p class="text-sm text-body-text mb-6 leading-relaxed">
                Fill in the form below and our team will respond within one working day.
                For urgent requests, WhatsApp us directly.
              </p>

              <form
                action="https://formspree.io/f/xzdkbblv"
                method="POST"
                class="space-y-5"
              >

                <!-- Name + Company row -->
                <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
                  <div>
                    <label for="name" class="block text-sm font-medium mb-1.5" style="color:#0099AF;">
                      Full Name <span class="text-red-500">*</span>
                    </label>
                    <input
                      type="text"
                      id="name"
                      name="name"
                      required
                      placeholder="Your full name"
                      class="w-full px-4 py-3 bg-white border border-gray-200 rounded-lg text-body-text text-sm focus:outline-none focus:ring-2 focus:border-primary transition-colors duration-150"
                      style="--tw-ring-color:rgba(0,153,175,0.3);"
                    />
                  </div>
                  <div>
                    <label for="company" class="block text-sm font-medium mb-1.5" style="color:#0099AF;">
                      Company Name
                    </label>
                    <input
                      type="text"
                      id="company"
                      name="company"
                      placeholder="Your company"
                      class="w-full px-4 py-3 bg-white border border-gray-200 rounded-lg text-body-text text-sm focus:outline-none focus:ring-2 focus:border-primary transition-colors duration-150"
                      style="--tw-ring-color:rgba(0,153,175,0.3);"
                    />
                  </div>
                </div>

                <!-- Email -->
                <div>
                  <label for="email" class="block text-sm font-medium mb-1.5" style="color:#0099AF;">
                    Email Address <span class="text-red-500">*</span>
                  </label>
                  <input
                    type="email"
                    id="email"
                    name="email"
                    required
                    placeholder="your@email.com"
                    class="w-full px-4 py-3 bg-white border border-gray-200 rounded-lg text-body-text text-sm focus:outline-none focus:ring-2 focus:border-primary transition-colors duration-150"
                    style="--tw-ring-color:rgba(0,153,175,0.3);"
                  />
                </div>

                <!-- Phone -->
                <div>
                  <label for="phone" class="block text-sm font-medium mb-1.5" style="color:#0099AF;">
                    Phone / WhatsApp
                  </label>
                  <input
                    type="tel"
                    id="phone"
                    name="phone"
                    placeholder="+92 3XX XXXXXXX"
                    class="w-full px-4 py-3 bg-white border border-gray-200 rounded-lg text-body-text text-sm focus:outline-none focus:ring-2 focus:border-primary transition-colors duration-150"
                    style="--tw-ring-color:rgba(0,153,175,0.3);"
                  />
                </div>

                <!-- Product of Interest -->
                <div>
                  <label for="product" class="block text-sm font-medium mb-1.5" style="color:#0099AF;">
                    Product of Interest
                  </label>
                  <select
                    id="product"
                    name="product"
                    class="w-full px-4 py-3 bg-white border border-gray-200 rounded-lg text-body-text text-sm focus:outline-none focus:ring-2 focus:border-primary transition-colors duration-150 cursor-pointer"
                    style="--tw-ring-color:rgba(0,153,175,0.3);"
                  >
                    <option value="">Select a category...</option>
                    <optgroup label="Screen Printing">
                      <option>Plastisol Inks</option>
                      <option>Water-Based Inks</option>
                      <option>Plastisol Additives</option>
                      <option>Water-Based Additives</option>
                    </optgroup>
                    <optgroup label="Digital Printing">
                      <option>Reactive / Acid / Disperse / Pigment Textile Inks</option>
                      <option>Sublimation Inks</option>
                      <option>Eco Solvent / Solvent / UV / Latex Inks</option>
                    </optgroup>
                    <optgroup label="Textile Auxiliaries">
                      <option>Dyeing Auxiliaries</option>
                      <option>Softeners &amp; Finishing Chemicals</option>
                    </optgroup>
                    <option value="other">Other / Not sure</option>
                  </select>
                </div>

                <!-- Message -->
                <div>
                  <label for="message" class="block text-sm font-medium mb-1.5" style="color:#0099AF;">
                    Message <span class="text-red-500">*</span>
                  </label>
                  <textarea
                    id="message"
                    name="message"
                    required
                    rows="5"
                    placeholder="Tell us about your requirements — product name, quantity, application, fabric type, or any technical questions..."
                    class="w-full px-4 py-3 bg-white border border-gray-200 rounded-lg text-body-text text-sm focus:outline-none focus:ring-2 focus:border-primary transition-colors duration-150 resize-none"
                    style="--tw-ring-color:rgba(0,153,175,0.3);"
                  ></textarea>
                </div>

                <!-- Submit -->
                <button
                  type="submit"
                  class="w-full py-4 text-white font-bold rounded-lg transition-colors duration-200 cursor-pointer text-base"
                  style="background:#0099AF;"
                  onmouseover="this.style.background='#007A8A'"
                  onmouseout="this.style.background='#0099AF'"
                >
                  Send Inquiry
                </button>

                <!-- Privacy note -->
                <p class="text-xs text-gray-400 text-center mt-3">
                  By submitting this form you agree to be contacted by SANMYRS regarding your inquiry.
                </p>

              </form>
            </div>
          </div>
        </div>

      </div>
    </div>
  </section>

</BaseLayout>

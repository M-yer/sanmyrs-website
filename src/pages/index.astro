---
import BaseLayout from '../layouts/BaseLayout.astro';

const schema = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "name": "SANMYRS",
  "url": "https://www.sanmyrs.com",
  "telephone": "+92-318-3755197",
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "F-126, Lucknow Society, Korangi",
    "addressLocality": "Karachi",
    "addressCountry": "PK"
  },
  "contactPoint": {
    "@type": "ContactPoint",
    "telephone": "+92-318-3755197",
    "contactType": "sales"
  }
};

const categories = [
  {
    title: 'Screen Printing',
    href: '/products/screen-printing',
    count: '38 Products',
    accentColor: '#00AEEF',
    tags: ['Plastisol Inks', 'Water-Based', 'Specialty Effects', 'Additives'],
    desc: 'Plastisol & water-based inks, specialty effects, and additives for garment and textile screen printing.',
    icon: `<svg width="26" height="26" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.6" aria-hidden="true"><rect x="2" y="5" width="20" height="11" rx="2"/><path d="M7 19h10M9.5 16v3M14.5 16v3"/><path d="M6 9.5h12M6 12.5h8"/></svg>`,
    image: '/images/cat-screen.png'
  },
  {
    title: 'Screen Chemicals & Accessories',
    href: '/products/screen-chemicals-accessories',
    count: '33 Products',
    accentColor: '#EC008C',
    tags: ['Emulsions', 'Degreasers', 'Mesh & Squeegees', 'Accessories'],
    desc: 'Emulsions, degreasers, screen openers, mesh, squeegees and all essentials for screen preparation.',
    icon: `<svg width="26" height="26" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.6" aria-hidden="true"><path d="M10 2h4l1 6H9L10 2z"/><path d="M9 8c-2 1.5-4 3.5-4 7a7 7 0 0014 0c0-3.5-2-5.5-4-7"/><line x1="12" y1="8" x2="12" y2="13"/></svg>`,
    image: '/images/cat-chemicals.png'
  },
  {
    title: 'Digital Printing',
    href: '/products/digital-printing',
    count: '14 Products',
    accentColor: '#F7D000',
    tags: ['Reactive & Acid', 'Sublimation', 'UV & Eco Solvent', 'DTF'],
    desc: 'Reactive, disperse, sublimation, UV, and latex inks for textile inkjet and wide-format printers.',
    icon: `<svg width="26" height="26" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.6" aria-hidden="true"><rect x="3" y="7" width="18" height="10" rx="2"/><path d="M7 7V5a2 2 0 012-2h6a2 2 0 012 2v2"/><circle cx="7.5" cy="12" r="1"/><path d="M11 12h5"/><path d="M11 15h3"/></svg>`,
    image: '/images/cat-digital.png'
  },
  {
    title: 'Textile Auxiliaries',
    href: '/products/textile-auxiliaries',
    count: '22 Products',
    accentColor: '#00A651',
    tags: ['Pre-Treatment', 'Softeners', 'Functional Finishes', 'Enzymes'],
    desc: 'Pre-treatment agents, softeners, and finishing chemicals used in garment and textile printing operations.',
    icon: `<svg width="26" height="26" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.6" aria-hidden="true"><path d="M12 3C8.5 3 5 6 5 10v4c0 4 3.1 7 7 7s7-3 7-7v-4c0-4-3.5-7-7-7z"/><path d="M8.5 10.5c1.5-1.2 5.5-1.2 7 0"/><path d="M8.5 14c1.5 1.2 5.5 1.2 7 0"/></svg>`,
    image: '/images/cat-textile.png'
  },
];

const stats = [
  { value: '18+', label: 'Years in Business', icon: `<svg width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8" aria-hidden="true"><path d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>` },
  { value: '80+', label: 'Products in Stock', icon: `<svg width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8" aria-hidden="true"><path d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/></svg>` },
  { value: '500+', label: 'Clients Served', icon: `<svg width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8" aria-hidden="true"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 00-3-3.87M16 3.13a4 4 0 010 7.75"/></svg>` },
  { value: 'KHI', label: 'Ready Stock, Karachi', icon: `<svg width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8" aria-hidden="true"><path d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>` },
];

const whyPoints = [
  {
    title: 'Verified Quality',
    body: 'Every product tested for performance consistency before dispatch. Your production runs predictably, without defects.',
    icon: `<svg width="24" height="24" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.6" aria-hidden="true"><path d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>`,
  },
  {
    title: 'Technical Support',
    body: 'Application guidance, troubleshooting, and process recommendations. Not just product supply — real expertise.',
    icon: `<svg width="24" height="24" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.6" aria-hidden="true"><path d="M18.364 5.636l-3.536 3.536m0 5.656l3.536 3.536M9.172 9.172L5.636 5.636m3.536 9.192l-3.536 3.536M21 12a9 9 0 11-18 0 9 9 0 0118 0zm-5 0a4 4 0 11-8 0 4 4 0 018 0z"/></svg>`,
  },
  {
    title: 'Fast Fulfillment',
    body: "Ready stock of core products in Karachi's industrial corridor. Same-day and next-day order fulfillment available.",
    icon: `<svg width="24" height="24" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.6" aria-hidden="true"><path d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>`,
  },
];

const industries = [
  'Screen Printing Studios', 'Garment Decorators', 'Digital Print Bureaus',
  'Sportswear Printers', 'Workwear Producers', 'Uniform Manufacturers',
  'Print-on-Demand Studios', 'Industrial Print Shops', 'Apparel Branding Companies', 'Promotional Product Printers',
];

const trustBadges = [
  { label: 'ISO Compliant', detail: 'Certified Products' },
  { label: 'Since 2002', detail: '18+ Years Experience' },
  { label: 'Karachi Stock', detail: 'Same-Day Dispatch' },
  { label: 'B2B Focused', detail: 'Bulk Orders Welcome' },
];
---

<BaseLayout
  title="SANMYRS | Printing Inks & Textile Chemicals — Karachi, Pakistan"
  description="SANMYRS supplies professional screen printing inks, digital printing inks, and textile auxiliaries to Pakistan's textile and garment industry. 18+ years of expertise. Inquire from Karachi."
  schema={schema}
>

  <!-- ═══════════════════════════════════════════
       HERO
  ════════════════════════════════════════════ -->
  <section class="hero-wrap" aria-label="Hero">

    <!-- Subtle dot grid -->
    <svg class="hero-dots" aria-hidden="true" width="100%" height="100%" xmlns="http://www.w3.org/2000/svg">
      <defs>
        <pattern id="dotgrid" width="40" height="40" patternUnits="userSpaceOnUse">
          <circle cx="1" cy="1" r="1" fill="rgba(0,153,175,0.18)"/>
        </pattern>
      </defs>
      <rect width="100%" height="100%" fill="url(#dotgrid)"/>
    </svg>

    <!-- Teal glow — static, no animation -->
    <div class="hero-glow-top" aria-hidden="true"></div>
    <div class="hero-glow-bottom" aria-hidden="true"></div>

    <div class="hero-inner">

      <!-- ── Left col ── -->
      <div class="hero-text">

        <div data-aos="fade-down" class="hero-eyebrow">
          <span class="eyebrow-dot" aria-hidden="true"></span>
          Since 2002 &nbsp;·&nbsp; Karachi, Pakistan
        </div>

        <h1 data-aos="fade-up" data-aos-delay="80" class="hero-h1 font-unison">
          The Chemistry<br/>
          <span class="hero-h1-teal">Behind Every Print.</span>
        </h1>

        <p data-aos="fade-up" data-aos-delay="160" class="hero-desc">
          Pakistan's specialist supplier of screen printing inks, digital inks, and textile auxiliaries — trusted by 500+ printing companies and studios since 2002.
        </p>

        <div data-aos="fade-up" data-aos-delay="220" class="hero-actions">
          <a href="/products" class="btn-teal">Browse Products</a>
          <a href="/contact" class="btn-ghost">Request a Sample</a>
        </div>

        <!-- Trust badges row -->
        <div data-aos="fade-up" data-aos-delay="300" class="trust-row">
          {trustBadges.map(b => (
            <div class="trust-badge">
              <span class="trust-label">{b.label}</span>
              <span class="trust-detail">{b.detail}</span>
            </div>
          ))}
        </div>

      </div>

      <!-- ── Right col: image + stats ── -->
      <div data-aos="fade-left" data-aos-delay="180" class="hero-right">

        <!-- Image frame -->
        <div class="hero-img-frame">
          <div class="hero-img-inner overflow-hidden" role="img" aria-label="SANMYRS industrial chemical printing production">
            <img src="/images/home-hero.png" alt="SANMYRS premium ink chemistry" class="w-full h-full object-cover" />
          </div>

          <!-- Corner accent lines -->
          <span class="corner-tl" aria-hidden="true"></span>
          <span class="corner-br" aria-hidden="true"></span>
        </div>

        <!-- Stats strip under image -->
        <div class="stats-strip">
          {stats.map(s => (
            <div class="stat-item">
              <span class="stat-icon" set:html={s.icon}></span>
              <span class="stat-value font-unison">{s.value}</span>
              <span class="stat-label">{s.label}</span>
            </div>
          ))}
        </div>

      </div>

    </div>

    <!-- Angled bottom edge -->
    <div class="hero-edge" aria-hidden="true"></div>
  </section>


  <!-- ═══════════════════════════════════════════
       PRODUCT CATEGORIES
  ════════════════════════════════════════════ -->
  <section class="section-light" aria-labelledby="cats-heading">
    <div class="container">

      <div data-aos="fade-up" class="section-hd">
        <p class="eyebrow-text">What We Supply</p>
        <h2 id="cats-heading" class="section-h2 font-unison">
          Four Categories.<br/>Every Stage of Production.
        </h2>
      </div>

      <div class="cat-grid">
        {categories.map((cat, i) => (
          <a href={cat.href}
             data-aos="fade-up"
             data-aos-delay={String(i * 70)}
             class="cat-card"
             style={`--accent:${cat.accentColor};`}
             aria-label={`${cat.title} — ${cat.count}`}>

            <!-- Accent bar -->
            <div class="cat-bar" aria-hidden="true"></div>

            <div class="cat-body">
              <!-- Header row -->
              <div class="cat-header">
                <span class="cat-icon" aria-hidden="true" set:html={cat.icon}></span>
                <span class="cat-count">{cat.count}</span>
              </div>

              <!-- Image slot -->
              <div class="cat-img border-none overflow-hidden bg-white" role="img" aria-label={`${cat.title} product image`}>
                {cat.image ? (
                  <img src={cat.image} alt={cat.title} class="w-full h-full object-cover transition-transform duration-700 hover:scale-105" />
                ) : (
                  <svg width="28" height="28" fill="none" viewBox="0 0 24 24" stroke="rgba(0,0,0,0.12)" stroke-width="1" aria-hidden="true">
                    <rect x="3" y="3" width="18" height="18" rx="2"/>
                    <circle cx="8.5" cy="8.5" r="1.5"/>
                    <path d="M21 15l-5-5L5 21"/>
                  </svg>
                )}
              </div>

              <h3 class="cat-title font-unison">{cat.title}</h3>
              <p class="cat-desc">{cat.desc}</p>

              <div class="cat-tags" aria-label="Product subcategories">
                {cat.tags.map(tag => (
                  <span class="cat-tag">{tag}</span>
                ))}
              </div>

              <span class="cat-cta">
                View Products
                <svg width="13" height="13" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
              </span>
            </div>

          </a>
        ))}
      </div>

    </div>
  </section>


  <!-- ═══════════════════════════════════════════
       WHY SANMYRS
  ════════════════════════════════════════════ -->
  <section class="section-dark" aria-labelledby="why-heading">
    <div class="container">

      <div data-aos="fade-up" class="section-hd">
        <p class="eyebrow-text">Why SANMYRS</p>
        <h2 id="why-heading" class="section-h2 font-unison" style="color:white;">
          Built for Serious<br/>Production Runs.
        </h2>
        <p class="why-lead">
          18 years supplying Pakistan's printing industry means we know what production downtime costs and what ink consistency is worth.
        </p>
      </div>

      <div class="why-grid">
        {whyPoints.map((pt, i) => (
          <div data-aos="fade-up" data-aos-delay={String(i * 90)} class="why-card">
            <div class="why-icon-wrap" aria-hidden="true" set:html={pt.icon}></div>
            <h3 class="why-title">{pt.title}</h3>
            <p class="why-body">{pt.body}</p>
          </div>
        ))}
      </div>

      <div data-aos="fade-up" data-aos-delay="200" class="why-cta-row">
        <a href="/contact" class="btn-teal">Talk to Our Team</a>
        <a href="/products" class="btn-ghost">Browse All Products</a>
      </div>

    </div>
  </section>


  <!-- ═══════════════════════════════════════════
       INDUSTRIES TICKER
  ════════════════════════════════════════════ -->
  <section class="section-mid" aria-labelledby="ind-heading">
    <div class="container ticker-header">
      <div data-aos="fade-right">
        <p class="eyebrow-text">Who We Serve</p>
        <h2 id="ind-heading" class="section-h2 font-unison" style="font-size:clamp(1.5rem,3vw,2.2rem);">
          Trusted across<br/>Pakistan's industry.
        </h2>
      </div>
      <a href="/industries" data-aos="fade-left" class="btn-outline-teal">See all industries →</a>
    </div>

    <!-- Scrolling ticker — full width -->
    <div class="ticker-outer" aria-label="Industries we serve">
      <div class="ticker-track">
        <!-- Doubled for seamless loop -->
        {[...industries, ...industries].map(ind => (
          <span class="ticker-item">
            <span class="ticker-dot" aria-hidden="true"></span>
            {ind}
          </span>
        ))}
      </div>
    </div>
  </section>


  <!-- ═══════════════════════════════════════════
       CTA
  ════════════════════════════════════════════ -->
  <section class="cta-section" aria-label="Call to action">
    <div class="container">
      <div class="cta-inner">

        <div data-aos="fade-right" class="cta-text">
          <p class="eyebrow-text" style="color:rgba(255,255,255,0.55);">Get Started Today</p>
          <h2 class="cta-h2 font-unison">
            Ready to upgrade<br/>your production?
          </h2>
          <p class="cta-sub">
            Product recommendations, technical data sheets, or samples — we respond within 24 hours on working days.
          </p>
        </div>

        <div data-aos="fade-left" data-aos-delay="100" class="cta-actions">
          <a href="/contact" class="btn-white">Get a Quote</a>
          <a href="https://wa.me/923183755197"
             target="_blank"
             rel="noopener noreferrer"
             class="btn-ghost-white"
             aria-label="Contact us on WhatsApp">
            <svg viewBox="0 0 24 24" fill="currentColor" width="16" height="16" style="color:#4ade80;flex-shrink:0;" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            WhatsApp Us
          </a>
        </div>

      </div>
    </div>
  </section>

</BaseLayout>


<style>
/* ─────────────────────────────────────────────
   TOKENS
───────────────────────────────────────────── */
:root {
  --teal:        #0099AF;
  --teal-dark:   #007A8A;
  --teal-light:  #00C4D4;
  --amber:       #D97706;
  --amber-light: #F59E0B;
  --dark:        #112952;
  --dark-card:   #1A3660;
  --dark-border: rgba(255,255,255,0.07);
  --page-bg:     #F8FAFC;
  --text:        #0F172A;
  --muted:       #475569;
  --border:      #E2E8F0;
  --white:       #FFFFFF;
}

/* ─────────────────────────────────────────────
   RESET + BASE
───────────────────────────────────────────── */
*, *::before, *::after { box-sizing: border-box; }

.container {
  max-width: 80rem;
  margin: 0 auto;
  padding: 0 clamp(16px, 4vw, 32px);
}

.section-light { background: var(--page-bg); padding: clamp(64px, 8vw, 96px) 0; }
.section-dark  { background: var(--dark);    padding: clamp(64px, 8vw, 96px) 0; }
.section-mid   { background: var(--white);   padding: clamp(56px, 7vw, 80px) 0; }

.section-hd { margin-bottom: 48px; }
.eyebrow-text {
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--teal);
  margin: 0 0 10px;
}
.section-h2 {
  font-size: clamp(1.9rem, 3.8vw, 3rem);
  font-weight: 800;
  color: var(--text);
  margin: 0;
  line-height: 1.1;
}

/* ─────────────────────────────────────────────
   BUTTONS — min 44px touch targets
───────────────────────────────────────────── */
.btn-teal, .btn-ghost, .btn-outline-teal,
.btn-white, .btn-ghost-white {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  min-height: 44px;
  padding: 11px 28px;
  font-size: 14px;
  font-weight: 700;
  border-radius: 6px;
  text-decoration: none;
  cursor: pointer;
  transition: background 0.18s ease, color 0.18s ease, transform 0.15s ease, opacity 0.18s ease;
}
.btn-teal {
  background: var(--teal);
  color: var(--white);
  border: 1.5px solid var(--teal);
}
.btn-teal:hover { background: var(--teal-dark); border-color: var(--teal-dark); transform: translateY(-1px); }
.btn-teal:focus-visible { outline: 3px solid var(--teal); outline-offset: 3px; }

.btn-ghost {
  background: transparent;
  color: var(--white);
  border: 1.5px solid rgba(255,255,255,0.2);
}
.btn-ghost:hover { background: rgba(255,255,255,0.08); }
.btn-ghost:focus-visible { outline: 3px solid var(--white); outline-offset: 3px; }

.btn-outline-teal {
  background: transparent;
  color: var(--teal);
  border: 1.5px solid var(--teal);
}
.btn-outline-teal:hover { background: var(--teal); color: var(--white); }
.btn-outline-teal:focus-visible { outline: 3px solid var(--teal); outline-offset: 3px; }

.btn-white {
  background: var(--white);
  color: var(--dark);
  border: 1.5px solid var(--white);
}
.btn-white:hover { opacity: 0.9; transform: translateY(-1px); }
.btn-white:focus-visible { outline: 3px solid var(--white); outline-offset: 3px; }

.btn-ghost-white {
  background: rgba(255,255,255,0.1);
  color: var(--white);
  border: 1.5px solid rgba(255,255,255,0.18);
}
.btn-ghost-white:hover { background: rgba(255,255,255,0.18); }
.btn-ghost-white:focus-visible { outline: 3px solid rgba(255,255,255,0.6); outline-offset: 3px; }

/* Reduce motion */
@media (prefers-reduced-motion: reduce) {
  .btn-teal:hover, .btn-white:hover { transform: none; }
}

/* ─────────────────────────────────────────────
   HERO
───────────────────────────────────────────── */
.hero-wrap {
  background: var(--dark);
  position: relative;
  overflow: hidden;
  padding: clamp(72px, 9vw, 104px) 0 0;
}

.hero-dots {
  position: absolute;
  inset: 0;
  pointer-events: none;
  opacity: 0.6;
}

.hero-glow-top {
  position: absolute;
  top: -160px; right: -120px;
  width: 640px; height: 640px;
  background: radial-gradient(circle, rgba(0,153,175,0.12) 0%, transparent 68%);
  border-radius: 50%;
  pointer-events: none;
}
.hero-glow-bottom {
  position: absolute;
  bottom: -80px; left: -60px;
  width: 480px; height: 480px;
  background: radial-gradient(circle, rgba(217,119,6,0.08) 0%, transparent 68%);
  border-radius: 50%;
  pointer-events: none;
}

.hero-inner {
  position: relative;
  max-width: 80rem;
  margin: 0 auto;
  padding: 0 clamp(16px,4vw,32px) clamp(72px,9vw,112px);
  display: grid;
  grid-template-columns: 1fr;
  gap: 56px;
  align-items: center;
}
@media (min-width: 900px) { .hero-inner { grid-template-columns: 1fr 1fr; gap: 64px; } }

/* Eyebrow */
.hero-eyebrow {

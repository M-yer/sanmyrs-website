---
import BaseLayout from '../layouts/BaseLayout.astro';

const schema = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "name": "SANMYRS",
  "url": "https://www.sanmyrs.com",
  "telephone": "+92-318-3755197",
  "priceRange": "$$",
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "F-126, Lucknow Society, Korangi",
    "addressLocality": "Karachi",
    "addressCountry": "PK"
  },
  "contactPoint": {
    "@type": "ContactPoint",
    "telephone": "+92-318-3755197",
    "contactType": "sales"
  }
};
---
<BaseLayout
  title="SANMYRS | Printing Inks & Textile Chemicals — Karachi, Pakistan"
  description="SANMYRS supplies professional screen printing inks, digital printing inks, and textile auxiliaries to Pakistan's textile and garment industry. 18+ years of expertise. Inquire from Karachi."
  schema={schema}
>

  <!-- Hero Section -->
  <section class="relative overflow-hidden min-h-[600px] flex items-center" style="background-color:#7A2A37;">
    <!-- Geometric SVG Background -->
    <div class="absolute inset-0 opacity-40 pointer-events-none" aria-hidden="true">
      <svg width="100%" height="100%" xmlns="http://www.w3.org/2000/svg">
        <defs>
          <pattern id="grid" width="60" height="60" patternUnits="userSpaceOnUse">
            <path d="M 60 0 L 0 0 0 60" fill="none" stroke="white" stroke-width="1"/>
          </pattern>
        </defs>
        <rect width="100%" height="100%" fill="url(#grid)" />
        <circle cx="10%" cy="20%" r="120" fill="#0099AF" opacity="0.15"/>
        <circle cx="85%" cy="75%" r="200" fill="#0099AF" opacity="0.10"/>
        <circle cx="60%" cy="10%" r="80" fill="#0099AF" opacity="0.12"/>
        <polygon points="90%,5% 100%,25% 80%,25%" fill="#0099AF" opacity="0.08"/>
        <polygon points="5%,80% 15%,95% 0%,95%" fill="#0099AF" opacity="0.08"/>
      </svg>
    </div>

    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-24 text-center">
      <div class="inline-flex items-center gap-2 bg-primary/20 border border-primary/30 text-primary text-sm font-medium px-4 py-2 rounded-full mb-6">
        <span class="w-2 h-2 bg-primary rounded-full animate-pulse"></span>
        Trusted by Pakistan's Textile Industry Since 2002
      </div>

      <h1 class="font-glancyr text-4xl sm:text-5xl lg:text-6xl font-extrabold text-white leading-tight mb-6">
        Premium Inks &amp; Chemicals<br/>
        <span style="color:#F5A623;">For Every Print Process</span>
      </h1>

      <p class="text-lg sm:text-xl text-gray-300 max-w-2xl mx-auto mb-10 leading-relaxed">
        SANMYRS supplies screen printing inks, digital printing inks, and textile auxiliaries to manufacturers, garment decorators, and dyeing units across Pakistan.
      </p>

      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a
          href="/products"
          class="px-8 py-4 bg-primary text-white font-semibold rounded-xl hover:bg-primary-dark transition-colors duration-200 cursor-pointer text-base shadow-lg shadow-primary/30"
        >
          Browse Products
        </a>
        <a
          href="/contact"
          class="px-8 py-4 bg-white/10 text-white font-semibold rounded-xl hover:bg-white/20 transition-colors duration-200 cursor-pointer text-base border border-white/20"
        >
          Request a Sample
        </a>
      </div>

      <!-- Stats Row -->
      <div class="mt-16 grid grid-cols-2 sm:grid-cols-4 gap-6 max-w-3xl mx-auto">
        {[
          { value: '18+', label: 'Years in Business' },
          { value: '50+', label: 'Product SKUs' },
          { value: '4', label: 'Product Categories' },
          { value: '500+', label: 'Satisfied Clients' },
        ].map(stat => (
          <div class="text-center">
            <div class="text-3xl font-extrabold text-primary">{stat.value}</div>
            <div class="text-sm text-gray-400 mt-1">{stat.label}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Product Categories Section -->
  <section class="py-20 bg-page-bg">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="font-glancyr text-3xl sm:text-4xl font-bold text-primary mb-4">Our Product Range</h2>
        <p class="text-body-text max-w-xl mx-auto">
          Four comprehensive categories covering every stage of textile printing and dyeing production.
        </p>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8">
        {[
          {
            title: 'Screen Printing',
            href: '/products/screen-printing',
            icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" /></svg>`,
            description: 'Plastisol inks, water-based inks, and specialty additives for garment decoration and textile screen printing.',
            count: '38 Products',
            features: ['Plastisol Inks', 'Water-Based Inks', 'Specialty Effects', 'Additives'],
          },
          {
            title: 'Screen Chemicals & Accessories',
            href: '/products/screen-chemicals-accessories',
            icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z" /></svg>`,
            description: 'Screen emulsions, degreasers, screen openers, mesh, squeegees, and all essential chemicals for screen preparation.',
            count: '33 Products',
            features: ['Screen Emulsions', 'Screen Chemicals', 'Mesh & Squeegees', 'Accessories'],
          },
          {
            title: 'Digital Printing',
            href: '/products/digital-printing',
            icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>`,
            description: 'Reactive, disperse, sublimation, and UV inks for textile inkjet systems and wide-format graphic printers.',
            count: '14 Products',
            features: ['Reactive & Acid Inks', 'Sublimation Inks', 'UV & Eco Solvent', 'Pretreatments'],
          },
          {
            title: 'Textile Auxiliaries',
            href: '/products/textile-auxiliaries',
            icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z" /></svg>`,
            description: 'Comprehensive dyeing auxiliaries, softeners, and functional finishing chemicals for modern textile mills.',
            count: '22 Products',
            features: ['Dyeing Auxiliaries', 'Silicone Softeners', 'Functional Finishes', 'Enzymes'],
          },
        ].map(cat => (
          <a href={cat.href} class="bg-white rounded-2xl border border-gray-200 p-8 hover:shadow-xl hover:border-primary/30 transition-all duration-300 flex flex-col group" style="text-decoration:none;">
            <div class="w-16 h-16 bg-primary/10 rounded-2xl flex items-center justify-center text-primary mb-6 group-hover:bg-primary group-hover:text-white transition-colors duration-300">
              <Fragment set:html={cat.icon} />
            </div>
            <h3 class="text-xl font-bold text-primary mb-3">{cat.title}</h3>
            <p class="text-body-text text-sm leading-relaxed mb-5 flex-grow">{cat.description}</p>
            <div class="flex flex-wrap gap-2 mb-6">
              {cat.features.map(f => (
                <span class="text-xs bg-page-bg text-body-text px-3 py-1 rounded-full border border-gray-200">{f}</span>
              ))}
            </div>
            <div class="flex items-center justify-between">
              <span class="text-xs font-semibold text-primary bg-primary/10 px-3 py-1 rounded-full">{cat.count}</span>
              <span class="text-primary font-medium text-sm group-hover:text-primary-dark transition-colors duration-150 inline-flex items-center gap-1">
                View All
                <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                </svg>
              </span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Why SANMYRS Section -->
  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="font-glancyr text-3xl sm:text-4xl font-bold text-primary mb-4">Why Choose SANMYRS</h2>
        <p class="text-body-text max-w-xl mx-auto">
          Built on 18 years of supplying Pakistan's most demanding textile and printing operations.
        </p>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
        {[
          {
            icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z" /></svg>`,
            title: 'Verified Quality',
            body: 'Every product is tested for performance consistency before dispatch, ensuring your production runs predictably and without defects.',
          },
          {
            icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z" /></svg>`,
            title: 'Technical Support',
            body: 'Our experienced team provides application guidance, troubleshooting, and process recommendations — not just product supply.',
          },
          {
            icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" /></svg>`,
            title: 'Fast Turnaround',
            body: 'Located in Karachi\'s industrial corridor, we maintain ready stock of core products for same-day and next-day order fulfillment.',
          },
          {
            icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>`,
            title: 'Wide Product Range',
            body: 'From basic plastisol inks to advanced dyeing auxiliaries, SANMYRS covers every chemical need across screen printing, digital printing, and textile finishing.',
          },
        ].map(card => (
          <div class="bg-page-bg rounded-2xl p-6 border border-gray-200 hover:shadow-md transition-shadow duration-200">
            <div class="w-12 h-12 bg-primary/10 rounded-xl flex items-center justify-center text-primary mb-5">
              <Fragment set:html={card.icon} />
            </div>
            <h3 class="text-primary font-bold mb-3">{card.title}</h3>
            <p class="text-body-text text-sm leading-relaxed">{card.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Industries We Serve -->
  <section class="py-20 bg-page-bg">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="font-glancyr text-3xl sm:text-4xl font-bold text-primary mb-4">Industries We Serve</h2>
        <p class="text-body-text max-w-xl mx-auto">
          SANMYRS products are trusted across the full spectrum of Pakistan's textile and print manufacturing sector.
        </p>
      </div>

      <div class="grid grid-cols-2 sm:grid-cols-2 lg:grid-cols-4 gap-5">
        {[
          {
            icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 21a4 4 0 01-4-4V5a2 2 0 012-2h4a2 2 0 012 2v12a4 4 0 01-4 4zm0 0h12a2 2 0 002-2v-4a2 2 0 00-2-2h-2.343M11 7.343l1.657-1.657a2 2 0 012.828 0l2.829 2.829a2 2 0 010 2.828l-8.486 8.485M7 17h.01" /></svg>`,
            title: 'Screen Printing Studios',
            desc: 'T-shirt printers, garment decorators, and promotional merchandise producers.',
          },
          {
            icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-2 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" /></svg>`,
            title: 'Textile Mills',
            desc: 'Dyeing units, finishing departments, and knitting and weaving mills.',
          },
          {
            icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>`,
            title: 'Digital Print Studios',
            desc: 'Digital textile print bureaus, sublimation printers, and wide-format signage studios.',
          },
          {
            icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z" /></svg>`,
            title: 'Garment Manufacturers',
            desc: 'Apparel exporters, sportswear brands, and workwear manufacturers requiring specialist print and finishing chemicals.',
          },
        ].map(item => (
          <div class="bg-white rounded-2xl p-6 border border-gray-200 hover:border-primary/40 hover:shadow-md transition-all duration-200 text-center">
            <div class="w-14 h-14 bg-primary/10 rounded-2xl flex items-center justify-center text-primary mx-auto mb-4">
              <Fragment set:html={item.icon} />
            </div>
            <h3 class="text-primary font-semibold mb-2 text-sm sm:text-base">{item.title}</h3>
            <p class="text-body-text text-xs sm:text-sm leading-relaxed">{item.desc}</p>
          </div>
        ))}
      </div>

      <div class="text-center mt-8">
        <a href="/industries" class="text-primary font-medium hover:text-primary-dark transition-colors duration-150 inline-flex items-center gap-1">
          Learn More About Industries We Serve
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
          </svg>
        </a>
      </div>
    </div>
  </section>

  <!-- Contact CTA Banner -->
  <section class="py-20 bg-navy">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="font-glancyr text-3xl sm:text-4xl font-bold text-white mb-5">
        Ready to Upgrade Your Production?
      </h2>
      <p class="text-gray-300 text-lg mb-10 leading-relaxed">
        Contact our team for product recommendations, technical data sheets, or to request samples. We respond within 24 hours on working days.
      </p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a
          href="/contact"
          class="px-8 py-4 bg-primary text-white font-semibold rounded-xl hover:bg-primary-dark transition-colors duration-200 cursor-pointer text-base shadow-lg shadow-primary/30"
        >
          Get a Quote Today
        </a>
        <a
          href="https://wa.me/923183755197"
          target="_blank"
          rel="noopener noreferrer"
          class="px-8 py-4 bg-white/10 text-white font-semibold rounded-xl hover:bg-white/20 transition-colors duration-200 cursor-pointer text-base border border-white/20 inline-flex items-center gap-2"
        >
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-5 h-5 text-[#25D366]">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
          </svg>
          WhatsApp Us
        </a>
      </div>
    </div>
  </section>

</BaseLayout>

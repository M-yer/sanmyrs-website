---
const currentYear = new Date().getFullYear();
---

<footer class="bg-navy text-gray-300">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-14">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-10">

      <!-- Company Column -->
      <div>
        <a href="/" class="inline-block mb-4">
          <span class="text-2xl font-extrabold text-white tracking-tight">
            SAN<span class="text-primary">MYRS</span>
          </span>
        </a>
        <p class="text-sm text-gray-400 leading-relaxed mb-5">
          Specialist suppliers of screen printing inks, digital printing inks, and textile auxiliaries serving Pakistan's textile industry with 18+ years of expertise.
        </p>
        <address class="not-italic text-sm text-gray-400 leading-relaxed">
          <div class="flex items-start gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 mt-0.5 text-primary flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
            <span>F-126, Lucknow Society,<br />Korangi, Karachi, Pakistan</span>
          </div>
        </address>
      </div>

      <!-- Quick Links Column -->
      <div>
        <h3 class="text-white font-semibold text-sm uppercase tracking-wider mb-5">Quick Links</h3>
        <ul class="space-y-3 text-sm">
          {[
            { label: 'Products', href: '/products' },
            { label: 'Industries We Serve', href: '/industries' },
            { label: 'About SANMYRS', href: '/about' },
            { label: 'Certifications', href: '/certifications' },
            { label: 'Contact Us', href: '/contact' },
          ].map(link => (
            <li>
              <a href={link.href} class="text-gray-400 hover:text-primary transition-colors duration-150 flex items-center gap-1">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                </svg>
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Product Categories Column -->
      <div>
        <h3 class="text-white font-semibold text-sm uppercase tracking-wider mb-5">Product Categories</h3>
        <ul class="space-y-3 text-sm">
          {[
            { label: 'Screen Printing Inks', href: '/products/screen-printing' },
            { label: 'Digital Printing Inks', href: '/products/digital-printing' },
            { label: 'Textile Auxiliaries', href: '/products/textile-auxiliaries' },
          ].map(link => (
            <li>
              <a href={link.href} class="text-gray-400 hover:text-primary transition-colors duration-150 flex items-center gap-1">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                </svg>
                {link.label}
              </a>
            </li>
          ))}
        </ul>

        <div class="mt-8">
          <h3 class="text-white font-semibold text-sm uppercase tracking-wider mb-4">Get In Touch</h3>
          <a
            href="https://wa.me/923183755197"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 text-sm text-gray-400 hover:text-primary transition-colors duration-150"
          >
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-4 h-4 text-[#25D366]">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
            </svg>
            +92 318 3755197
          </a>
        </div>
      </div>

    </div>
  </div>

  <!-- Bottom Bar -->
  <div class="border-t border-white/10">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-5 flex flex-col sm:flex-row items-center justify-between gap-3 text-xs text-gray-500">
      <span>© {currentYear} SANMYRS. All rights reserved.</span>
      <span class="flex items-center gap-1">
        WhatsApp:
        <a href="https://wa.me/923183755197" class="text-gray-400 hover:text-primary transition-colors duration-150">
          +92 318 3755197
        </a>
      </span>
    </div>
  </div>
</footer>
